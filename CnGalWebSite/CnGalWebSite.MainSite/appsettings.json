{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Polly": "Warning",
      "CnGalWebSite.WebAssembly.Services.HttpService": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "Information"
    }
  },
  "MainSiteApi": {
    //"BaseAddress": "https://api.cngal.org/",
    "BaseAddress": "http://localhost:5003/",
    //"ImageApiPath": "https://api.cngal.top/",
    "ImageApiPath": "http://localhost:5098/",
    //"TaskApiPath": "https://task.cngal.top/",
    "TaskApiPath": "http://localhost:5099/"
  },
  "Oidc": {
    "Authority": "https://localhost:5001",
    "RequireHttpsMetadata": true,
    "PersistentLoginDays": 30,
    "RefreshLeadTimeMinutes": 5,
    "Scopes": [
      "openid",
      "profile",
      "role",
      "CnGalAPI",
      "TaskAPI",
      "FileAPI",
      "offline_access"
    ]
  },
  "AllowedHosts": "*"
