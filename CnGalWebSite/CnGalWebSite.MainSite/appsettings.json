{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "CnGalWebSite.WebAssembly.Services.HttpService": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "Information"
    }
  },
  "MainSiteApi": {
    //"BaseAddress": "https://api.cngal.org/",
    "BaseAddress": "http://localhost:5003/"
  },
  "Oidc": {
    "Authority": "https://localhost:5001",
    "MetadataAddress": "https://localhost:5001/.well-known/openid-configuration",
    "RequireHttpsMetadata": true,
    "PersistentLoginDays": 30,
    "RefreshLeadTimeMinutes": 5,
    "Scopes": [
      "openid",
      "profile",
      "role",
      "CnGalAPI",
      "TaskAPI",
      "FileAPI",
      "offline_access"
    ]
  },
  "AllowedHosts": "*"
}
