@using CnGalWebSite.MainSite.Shared.Services
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="zh-CN" data-theme="@InitialTheme">

<head>
    <script>
        (function () {
            function getCookieTheme() {
                var match = document.cookie.match(/(?:^|;\s*)cg-theme=([^;]*)/);
                return match ? match[1] : null;
            }

            function getLegacyTheme() {
                try {
                    return localStorage.getItem('cg-theme');
                } catch {
                    return null;
                }
            }

            var theme = getCookieTheme() || getLegacyTheme();
            if (theme === 'dark' || theme === 'light') {
                document.documentElement.setAttribute('data-theme', theme);
            } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="keywords" content="galgame,cngal,国产galgame,中文galgame,gal,二次元,国产gal,中文gal">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

    <link rel="icon" href="favicon.ico" type="image/x-icon">
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" href="icon-512.png">

    <meta name="sogou_site_verification" content="rdtePt6zM1"/>
    <meta name="shenma-site-verification" content="966d1197093bc0c3cb96125cfd07c5bc_1632156168">
    <meta name="360-site-verification" content="5640406dc9f1d06cee13b5f90b581abf"/>

    <base href="/"/>

    <!--开放搜索-->
    <link rel="search" type="application/opensearchdescription+xml" target="_blank" class="external-link" href="https://app.cngal.org/_content/CnGalWebSite.Shared/OpenSearch.xml" title="CnGal资料站"/>

    <ResourcePreloader/>
    <link rel="stylesheet" href="@Assets["_content/CnGalWebSite.MainSite.Shared/styles/design-tokens.css"]"/>
    <link rel="stylesheet" href="@Assets["CnGalWebSite.MainSite.styles.css"]"/>
    <ImportMap/>
    <HeadOutlet/>
</head>

<body>
<Routes/>
<script src="@Assets["_framework/blazor.web.js"]"></script>
<script>
    (function () {
        var circuitDead = false;

        function watchErrorUi() {
            var el = document.getElementById('blazor-error-ui');
            if (!el) return;
            new MutationObserver(function () {
                if (el.style.display && el.style.display !== 'none') {
                    circuitDead = true;
                }
            }).observe(el, { attributes: true, attributeFilter: ['style'] });
        }

        watchErrorUi();

        Blazor.addEventListener('enhancedload', function () {
            watchErrorUi();
            if (window.cngalTheme) {
                window.cngalTheme.apply();
            }
            if (circuitDead) {
                var modal = document.getElementById('components-reconnect-modal');
                if (modal) modal.className = 'components-reconnect-failed';
            }
        });
    })();

    window.downloadFileFromStream = async (fileName, contentStreamReference) => {
        const arrayBuffer = await contentStreamReference.arrayBuffer();
        const blob = new Blob([arrayBuffer]);
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = fileName ?? '';
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
    };

    window.cngalMiniMode = {
        setCookie: function (isMiniMode) {
            if (isMiniMode) {
                document.cookie = 'cg-mini-mode=true; path=/; max-age=31536000; samesite=lax';
                return;
            }
            document.cookie = 'cg-mini-mode=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; samesite=lax';
        },
        getCookie: function () {
            return document.cookie
                .split(';')
                .map(function (item) { return item.trim(); })
                .some(function (item) { return item === 'cg-mini-mode=true'; });
        }
    };

    window.cngalTheme = {
        apply: function () {
            var value = this.getCookie();
            if (value !== 'dark' && value !== 'light') {
                value = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches
                    ? 'dark'
                    : 'light';
            }

            document.documentElement.setAttribute('data-theme', value);
            return value;
        },
        setCookie: function (isDark) {
            var value = isDark ? 'dark' : 'light';
            document.cookie = 'cg-theme=' + value + '; path=/; max-age=31536000; samesite=lax';
            document.documentElement.setAttribute('data-theme', value);
        },
        getCookie: function () {
            var match = document.cookie.match(/(?:^|;\s*)cg-theme=([^;]*)/);
            return match ? match[1] : null;
        }
    };
</script>
</body>

</html>

@code {
    private string? InitialTheme
    {
        get
        {
            var theme = HttpContextAccessor.HttpContext?.Request.Cookies[ThemeConstants.CookieName];
            return theme is ThemeConstants.DarkValue or ThemeConstants.LightValue ? theme : null;
        }
    }
}
