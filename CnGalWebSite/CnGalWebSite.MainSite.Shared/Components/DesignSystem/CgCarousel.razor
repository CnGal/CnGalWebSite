@* ────────────────────────────────────────────────────────────
    CgCarousel — SSR 首帧 + 渐进增强轮播图
    ‑ 单张时：直接展示，无需脚本
    ‑ 多张时：SSR 渲染第一张作为静态首帧
      JS 增强后接管自动轮播、手动切换与恢复轮播
    ‑ 尊重 prefers-reduced-motion
   ──────────────────────────────────────────────────────────── *@

<div class="cg-carousel"
     style="aspect-ratio: @AspectRatio;"
     data-cg-carousel-duration="@SlideDurationSeconds">
    @if (Items is not null && Items.Count > 0)
    {
        var count = Items.Count;

        @if (count == 1)
        {
            var solo = Items[0];
            @if (!string.IsNullOrEmpty(solo.Link))
            {
                <a class="cg-carousel__slide cg-carousel__slide--solo"
                   href="@solo.Link"
                   target="@(IsExternalLink(solo.Link) ? "_blank" : null)"
                   rel="@(IsExternalLink(solo.Link) ? "noopener noreferrer" : null)"
                   aria-label="@solo.Alt">
                    <img class="cg-carousel__image"
                         src="@solo.Image"
                         alt="@solo.Alt"
                         loading="eager"
                         fetchpriority="high"
                         decoding="async"
                         width="@ImageWidth"
                         height="@ImageHeight" />
                </a>
            }
            else
            {
                <div class="cg-carousel__slide cg-carousel__slide--solo">
                    <img class="cg-carousel__image"
                         src="@solo.Image"
                         alt="@solo.Alt"
                         loading="eager"
                         fetchpriority="high"
                         decoding="async"
                         width="@ImageWidth"
                         height="@ImageHeight" />
                </div>
            }
        }
        else
        {
            @for (var i = 0; i < count; i++)
            {
                var item = Items[i];
                var activeClass = i == 0 ? " cg-carousel__slide--active" : "";

                <div class="cg-carousel__slide@(activeClass)">
                    @if (!string.IsNullOrEmpty(item.Link))
                    {
                        <a class="cg-carousel__link"
                           href="@item.Link"
                           target="@(IsExternalLink(item.Link) ? "_blank" : null)"
                           rel="@(IsExternalLink(item.Link) ? "noopener noreferrer" : null)"
                           aria-label="@item.Alt">
                            <img class="cg-carousel__image"
                                 src="@item.Image"
                                 alt="@item.Alt"
                                 loading="@(i == 0 ? "eager" : "lazy")"
                                 fetchpriority="@(i == 0 ? "high" : "low")"
                                 decoding="async"
                                 width="@ImageWidth"
                                 height="@ImageHeight" />
                        </a>
                    }
                    else
                    {
                        <img class="cg-carousel__image"
                             src="@item.Image"
                             alt="@item.Alt"
                             loading="@(i == 0 ? "eager" : "lazy")"
                             fetchpriority="@(i == 0 ? "high" : "low")"
                             decoding="async"
                             width="@ImageWidth"
                             height="@ImageHeight" />
                    }
                </div>
            }

            @* 导航按钮（位于幻灯片之上） *@
            <button type="button"
                    class="cg-carousel__btn cg-carousel__btn--prev"
                    aria-label="上一张">
                <CgMdiIcon Name="mdiChevronLeft" aria-hidden="true" />
            </button>

            <button type="button"
                    class="cg-carousel__btn cg-carousel__btn--next"
                    aria-label="下一张">
                <CgMdiIcon Name="mdiChevronRight" aria-hidden="true" />
            </button>
        }
    }
</div>

@if (Items is not null && Items.Count > 1)
{
    <script src="_content/CnGalWebSite.MainSite.Shared/scripts/cg-carousel.js"></script>
}

@code {
    /// <summary>轮播项列表</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<CgCarouselItem> Items { get; set; } = [];

    /// <summary>容器宽高比（CSS aspect-ratio 值）</summary>
    [Parameter]
    public string AspectRatio { get; set; } = "2048 / 400";

    /// <summary>每张幻灯片停留秒数</summary>
    [Parameter]
    public int SlideDurationSeconds { get; set; } = 5;

    /// <summary>图片原始宽度（性能提示）</summary>
    [Parameter]
    public int ImageWidth { get; set; } = 2048;

    /// <summary>图片原始高度（性能提示）</summary>
    [Parameter]
    public int ImageHeight { get; set; } = 400;

    /// <summary>轮播项数据模型</summary>
    public record CgCarouselItem(string Image, string? Link, string? Alt);

    private static bool IsExternalLink(string? link)
    {
        if (string.IsNullOrEmpty(link)) return false;
        return link.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || link.StartsWith("https://", StringComparison.OrdinalIgnoreCase);
    }
}
