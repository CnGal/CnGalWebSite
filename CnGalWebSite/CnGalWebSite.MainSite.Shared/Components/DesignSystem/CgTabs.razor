@* CgTabs — 通用 Tab 切换组件
   两种视觉 Variant：pill（药丸填充）/ underline（底部下划线）
   两种交互模式：
   1. CSS radio 模式（默认）：纯 CSS radio + label + :checked，无需 JS
   2. 链接模式（SSR 友好）：当设置 HrefTemplate 时，Tab 标签渲染为 <a> 链接 *@

<div class="cg-tabs cg-tabs--@Variant" id="@_resolvedId">
    @if (_useLinks)
    {
        @* ─── Link mode (SSR): 无 radio，直接通过 class 控制激活状态 ─── *@
        <nav class="cg-tabs__bar" role="tablist" aria-label="@AriaLabel">
            @for (var i = 0; i < Items.Count; i++)
            {
                var item = Items[i];
                var isActive = item.Key == _activeKey;
                <a class="cg-tabs__tab @(isActive ? "cg-tabs__tab--active" : "")"
                   href="@GetTabHref(item.Key)"
                   role="tab"
                   aria-selected="@(isActive ? "true" : "false")">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <CgMdiIcon Name="@item.Icon" aria-hidden="true" />
                    }
                    <span>@item.Label</span>
                    @if (!string.IsNullOrEmpty(item.Badge))
                    {
                        <span class="cg-tabs__badge">@item.Badge</span>
                    }
                </a>
            }
        </nav>

        @* 面板区：只渲染激活的面板 *@
        @if (PanelTemplate != null)
        {
            <section class="cg-tabs__panel cg-tabs__panel--active"
                     role="tabpanel"
                     id="@($"{_resolvedId}-panel-{_activeKey}")">
                @PanelTemplate(_activeKey)
            </section>
        }
    }
    else
    {
        @* ─── CSS radio mode（原始模式） ─── *@
        @for (var i = 0; i < Items.Count; i++)
        {
            var item = Items[i];
            var isDefault = item.Key == _activeKey;
            <input type="radio"
                   name="@_resolvedId"
                   id="@GetRadioId(item.Key)"
                   class="cg-tabs__radio"
                   checked="@isDefault"
                   @onchange="() => OnRadioChanged(item.Key)"
                   aria-hidden="true" />
        }

        <nav class="cg-tabs__bar" role="tablist" aria-label="@AriaLabel">
            @for (var i = 0; i < Items.Count; i++)
            {
                var item = Items[i];
                <label for="@GetRadioId(item.Key)"
                       class="cg-tabs__tab"
                       role="tab">
                    @if (!string.IsNullOrEmpty(item.Icon))
                    {
                        <CgMdiIcon Name="@item.Icon" aria-hidden="true" />
                    }
                    <span>@item.Label</span>
                    @if (!string.IsNullOrEmpty(item.Badge))
                    {
                        <span class="cg-tabs__badge">@item.Badge</span>
                    }
                </label>
            }
        </nav>

        @if (PanelTemplate != null)
        {
            @for (var i = 0; i < Items.Count; i++)
            {
                var item = Items[i];
                <section class="cg-tabs__panel"
                         role="tabpanel"
                         id="@($"{_resolvedId}-panel-{item.Key}")"
                         aria-labelledby="@GetRadioId(item.Key)">
                    @PanelTemplate(item.Key)
                </section>
            }
        }
    }
</div>

@code {
    /// <summary>
    /// 视觉变体："pill"（药丸填充）或 "underline"（底部下划线）。
    /// </summary>
    [Parameter]
    public string Variant { get; set; } = "pill";

    /// <summary>
    /// Tab 项列表。
    /// </summary>
    [Parameter]
    public IReadOnlyList<CgTabItem> Items { get; set; } = [];

    /// <summary>
    /// 默认激活 Tab 的 Key。未指定时取第一项。
    /// </summary>
    [Parameter]
    public string? DefaultActiveKey { get; set; }

    /// <summary>
    /// 无障碍标签，用于 tablist 的 aria-label。
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>
    /// 组件唯一标识，用于 radio name/id。未指定时自动生成。
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// 面板内容模板。context 参数为当前 Tab 的 Key。
    /// 所有面板均会渲染到 DOM，CSS 控制可见性。
    /// </summary>
    [Parameter]
    public RenderFragment<string>? PanelTemplate { get; set; }

    /// <summary>
    /// Tab 切换时回调（仅在交互渲染模式下触发，SSR 静态页不会触发）。
    /// </summary>
    [Parameter]
    public EventCallback<string> ActiveKeyChanged { get; set; }

    /// <summary>
    /// SSR 链接模式模板，例如 "/space/index/abc?tab={0}"。
    /// 设置此属性后 Tab 标签渲染为 &lt;a&gt; 链接，且仅渲染激活面板。
    /// </summary>
    [Parameter]
    public string? HrefTemplate { get; set; }

    private bool _useLinks => !string.IsNullOrEmpty(HrefTemplate);

    private string _resolvedId = string.Empty;
    private string _activeKey = string.Empty;
    private string? _prevDefaultActiveKey;

    protected override void OnInitialized()
    {
        _resolvedId = Id ?? $"cg-tabs-{Guid.NewGuid():N}";
        _activeKey = DefaultActiveKey ?? (Items.Count > 0 ? Items[0].Key : string.Empty);
        _prevDefaultActiveKey = DefaultActiveKey;
    }

    protected override void OnParametersSet()
    {
        // 链接模式下，或者当父组件显式更改了 DefaultActiveKey 时，更新当前激活项
        if (DefaultActiveKey != _prevDefaultActiveKey)
        {
            _prevDefaultActiveKey = DefaultActiveKey;
            if (!string.IsNullOrEmpty(DefaultActiveKey))
            {
                _activeKey = DefaultActiveKey;
            }
        }
    }

    private string GetTabHref(string key) => string.Format(HrefTemplate!, key);

    private async Task OnRadioChanged(string key)
    {
        _activeKey = key;
        if (ActiveKeyChanged.HasDelegate)
        {
            await ActiveKeyChanged.InvokeAsync(key);
        }
    }

    private string GetRadioId(string key) => $"{_resolvedId}-{key}";
}
