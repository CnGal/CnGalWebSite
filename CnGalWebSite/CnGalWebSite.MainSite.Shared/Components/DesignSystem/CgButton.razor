@if (!string.IsNullOrEmpty(Href))
{
    <a class="@CssClass" href="@(IsDisabled ? null : Href)" aria-disabled="@(IsDisabled ? "true" : null)" role="button" tabindex="@(IsDisabled ? -1 : 0)" @attributes="AdditionalAttributes">
        @ChildContent
    </a>
}
else
{
    <button class="@CssClass" type="@Type" disabled="@IsDisabled" aria-disabled="@(IsDisabled ? "true" : null)" @onclick="HandleClickAsync" @attributes="AdditionalAttributes">
        @if (_isLoading)
        {
            <CgProgressRing Size="sm" />
        }
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// 设置后按钮渲染为 &lt;a&gt; 标签。
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public string Type { get; set; } = "button";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Variant { get; set; } = "primary";

    /// <summary>
    /// 尺寸："default" | "sm"
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "default";

    /// <summary>
    /// 开启后，按钮在执行异步回调期间自动禁用并显示进度环。
    /// </summary>
    [Parameter]
    public bool Async { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _isLoading;

    private bool IsDisabled => Disabled || _isLoading;

    private async Task HandleClickAsync(MouseEventArgs args)
    {
        if (!Async)
        {
            await OnClick.InvokeAsync(args);
            return;
        }

        if (_isLoading)
        {
            return;
        }

        _isLoading = true;
        try
        {
            await OnClick.InvokeAsync(args);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string CssClass
    {
        get
        {
            var cls = $"cg-btn cg-btn--{Variant}";
            if (Size == "sm")
            {
                cls += " cg-btn--sm";
            }
            if (_isLoading)
            {
                cls += " cg-btn--loading";
            }
            if (IsDisabled)
            {
                cls += " cg-btn--disabled";
            }
            return cls;
        }
    }
}
