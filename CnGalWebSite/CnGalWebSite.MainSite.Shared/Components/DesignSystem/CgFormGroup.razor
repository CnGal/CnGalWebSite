<div class="cg-form-group">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="cg-form-group__label">
            @Label
            @if (Required)
            {
                <span class="cg-form-group__required" aria-hidden="true">*</span>
            }
        </label>
    }
    @ChildContent
</div>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
