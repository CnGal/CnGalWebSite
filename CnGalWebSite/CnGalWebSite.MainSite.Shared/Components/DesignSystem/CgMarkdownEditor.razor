@using Microsoft.JSInterop
@using Microsoft.Extensions.Configuration
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IConfiguration Configuration

<div class="cg-markdown-editor">
    @if (_loading)
    {
        <div class="cg-markdown-editor__loading">
            <CgProgressRing Size="lg" />
            <span class="cg-markdown-editor__loading-text">正在加载编辑器…</span>
        </div>
    }

    <div @ref="_containerRef" style="@(_loading ? "display:none" : null)"></div>

</div>

@code {

    private ElementReference _containerRef;
    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<CgMarkdownEditor>? _dotNetRef;
    private bool _initialized;
    private bool _loading;
    private string? _lastKnownValue;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            _loading = true;
            StateHasChanged();

            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/CnGalWebSite.MainSite.Shared/scripts/cg-markdown-editor.js");

            var imageApiBaseUrl = Configuration["MainSiteApi:ImageApiPath"] ?? string.Empty;

            _lastKnownValue = Value;
            await _jsModule.InvokeVoidAsync("initEditor", _dotNetRef, _containerRef, Value ?? string.Empty, Placeholder ?? string.Empty, imageApiBaseUrl);
            _initialized = true;
            _loading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || _jsModule is null)
        {
            return;
        }

        // 当外部参数变更时，同步到 JS 编辑器
        if (!string.Equals(Value, _lastKnownValue, StringComparison.Ordinal))
        {
            _lastKnownValue = Value;
            await _jsModule.InvokeVoidAsync("setValue", Value ?? string.Empty);
        }
    }

    /// <summary>
    /// 由 JS 调用：编辑器内容变更时通知 .NET
    /// </summary>
    [JSInvokable]
    public async Task OnEditorValueChanged(string value)
    {
        _lastKnownValue = value;
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("disposeEditor");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
            catch (JSException)
            {
            }
            catch (TaskCanceledException)
            {
            }
        }

        _dotNetRef?.Dispose();
    }
}
