@* CgBarChart — 基于 Canvas 的柱状图组件，通过 JS 模块渲染 *@
@inject IJSRuntime JsRuntime
@using Microsoft.JSInterop
@implements IAsyncDisposable

<div class="cg-bar-chart @CssClass" style="@Style">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <div class="cg-bar-chart__header">
            <span class="cg-bar-chart__title">@Title</span>
        </div>
    }
    <div class="cg-bar-chart__body">
        <canvas id="@_canvasId" width="500" height="@Height" style="width: 100%; height: @(Height)px; max-height: @(Height)px;"></canvas>
    </div>
</div>

@code {
    private string _canvasId = $"cg-bar-{Guid.NewGuid():N}";
    private IJSObjectReference? _chartModule;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public IReadOnlyList<string>? Labels { get; set; }

    [Parameter, EditorRequired]
    public IReadOnlyList<CgBarChartSeries>? Series { get; set; }

    [Parameter]
    public int Height { get; set; } = 250;

    [Parameter]
    public string? CssClass { get; set; }

    [Parameter]
    public string? Style { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _chartModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./_content/CnGalWebSite.MainSite.Shared/scripts/cg-bar-chart.js");
            await RenderChart();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_chartModule is not null)
        {
            await RenderChart();
        }
    }

    private async Task RenderChart()
    {
        if (_chartModule is null) return;

        var labels = Labels ?? [];
        var datasets = (Series ?? []).Select(s => new { label = s.Name, data = s.Data, color = s.Color }).ToList();

        await _chartModule.InvokeVoidAsync("render", _canvasId, labels, datasets, Title ?? "");
    }

    public async Task RefreshAsync()
    {
        await RenderChart();
    }

    public async ValueTask DisposeAsync()
    {
        if (_chartModule is not null)
        {
            try
            {
                await _chartModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already disconnected — JS interop unavailable, nothing to clean up
            }
        }
    }
}
