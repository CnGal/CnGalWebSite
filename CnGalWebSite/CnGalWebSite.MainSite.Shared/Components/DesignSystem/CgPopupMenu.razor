<div class="cg-popup-menu">
    <CgButton Variant="@TriggerVariant" OnClick="ToggleAsync">@TriggerText</CgButton>
    @if (_isOpen)
    {
        <ul class="cg-popup-menu-panel" role="menu">
            @foreach (var item in Items)
            {
                <li>
                    <button class="cg-popup-menu-item"
                            type="button"
                            role="menuitem"
                            @onclick="() => OnItemClickAsync(item.Key)">
                        @item.Value
                    </button>
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter]
    public string TriggerText { get; set; } = "更多操作";

    [Parameter]
    public string TriggerVariant { get; set; } = "secondary";

    [Parameter]
    public IEnumerable<KeyValuePair<string, string>> Items { get; set; } = [];

    [Parameter]
    public EventCallback<string> ItemSelected { get; set; }

    private bool _isOpen;

    private Task ToggleAsync(MouseEventArgs _)
    {
        _isOpen = !_isOpen;
        return Task.CompletedTask;
    }

    private async Task OnItemClickAsync(string key)
    {
        _isOpen = false;
        await ItemSelected.InvokeAsync(key);
    }
}
