@typeparam TValue

<input @key="_inputKey"
       class="cg-input"
       type="@InputType"
       value="@StringValue"
       placeholder="@Placeholder"
       disabled="@Disabled"
       @oninput="OnInput" />

@code {
    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    public EventCallback<TValue?> ValueChanged { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private int _inputKey;
    private string? _lastUserInput;

    private string InputType
    {
        get
        {
            var type = typeof(TValue);
            type = Nullable.GetUnderlyingType(type) ?? type;

            if (type == typeof(int) || type == typeof(long) || type == typeof(double) || type == typeof(float) || type == typeof(decimal))
            {
                return "number";
            }

            return "text";
        }
    }

    private string? StringValue => Value?.ToString();

    protected override void OnParametersSet()
    {
        var currentStr = Value?.ToString();
        if (_lastUserInput != null && currentStr != _lastUserInput)
        {
            _inputKey++;
            _lastUserInput = null;
        }
    }

    private Task OnInput(ChangeEventArgs args)
    {
        _lastUserInput = args.Value?.ToString();
        var converted = ConvertValue(_lastUserInput);
        return ValueChanged.InvokeAsync(converted);
    }

    private static TValue? ConvertValue(string? text)
    {
        if (string.IsNullOrEmpty(text))
        {
            return default;
        }

        var targetType = typeof(TValue);
        targetType = Nullable.GetUnderlyingType(targetType) ?? targetType;

        if (targetType == typeof(string))
        {
            return (TValue?)(object?)text;
        }

        try
        {
            return (TValue?)Convert.ChangeType(text, targetType);
        }
        catch
        {
            return default;
        }
    }
}
