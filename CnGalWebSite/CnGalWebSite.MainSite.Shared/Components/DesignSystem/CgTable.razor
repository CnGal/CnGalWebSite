@if (HasData)
{
    <div class="cg-table-wrap">
        <table class="cg-table">
            @ChildContent
        </table>
    </div>
}
else if (Empty != null)
{
    @Empty
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// 数据为空时显示的内容
    /// </summary>
    [Parameter]
    public RenderFragment? Empty { get; set; }

    /// <summary>
    /// 是否有数据（控制表格/空态切换）
    /// </summary>
    [Parameter]
    public bool HasData { get; set; } = true;
}
