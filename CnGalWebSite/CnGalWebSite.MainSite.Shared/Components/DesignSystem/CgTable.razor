@if (HasData)
{
    <div class="cg-table-wrap" style="@WrapStyle">
        <table class="cg-table">
            @ChildContent
        </table>
    </div>
}
else if (Empty != null)
{
    <div class="cg-table-empty">
        @Empty
    </div>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// 数据为空时显示的内容
    /// </summary>
    [Parameter]
    public RenderFragment? Empty { get; set; }

    /// <summary>
    /// 是否有数据（控制表格/空态切换）
    /// </summary>
    [Parameter]
    public bool HasData { get; set; } = true;

    /// <summary>
    /// 可选最大高度（如 "400px"），设置后表格区域可滚动，表头保持固定。
    /// </summary>
    [Parameter]
    public string? MaxHeight { get; set; }

    private string? WrapStyle => string.IsNullOrWhiteSpace(MaxHeight)
        ? null
        : $"max-height:{MaxHeight};overflow-y:auto";
}
