@* CgAlert — 通用提示组件，支持 Info / Success / Warning / Error 四种类型 *@
<div class="cg-alert cg-alert--@Variant" role="alert">
    @ChildContent
</div>

@code {
    /// <summary>
    /// 提示类型：info / success / warning / error
    /// </summary>
    [Parameter] public string Variant { get; set; } = "info";

    [Parameter] public RenderFragment? ChildContent { get; set; }
}
