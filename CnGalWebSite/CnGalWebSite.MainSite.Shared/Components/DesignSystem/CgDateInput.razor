<input class="cg-date-input"
       type="date"
       value="@ToDateString(Value)"
       disabled="@Disabled"
       @onchange="OnChanged" />

@code {
    [Parameter]
    public DateTime? Value { get; set; }

    [Parameter]
    public EventCallback<DateTime?> ValueChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private static string ToDateString(DateTime? value)
        => value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private Task OnChanged(ChangeEventArgs args)
    {
        var text = args.Value?.ToString();
        var result = DateTime.TryParse(text, out var date) ? date : (DateTime?)null;
        return ValueChanged.InvokeAsync(result);
    }
}
