@if (_isOpenInternal)
{
    <div class="cg-modal-mask @(_isClosing ? "cg-modal-closing" : "")" @onclick="OnMaskClick">
        <section class="cg-modal-panel @(_isClosing ? "cg-modal-panel-closing" : "")" style="@(Width != null ? $"width: {Width}; max-width: 92vw;": "")" @onclick:stopPropagation="true" role="dialog" aria-modal="true">
            <CgRenderFreeze Freeze="_isClosing">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <header class="cg-modal-header">
                        <h3>@Title</h3>
                    </header>
                }
                <div class="cg-modal-content">
                    @ChildContent
                </div>
                @if (Footer != null)
                {
                    <footer class="cg-modal-footer">
                        @Footer
                    </footer>
                }
            </CgRenderFreeze>
        </section>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Width { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// 弹窗底部操作栏（如取消/保存按钮），若不提供则不渲染
    /// </summary>
    [Parameter]
    public RenderFragment? Footer { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private bool _isOpenInternal;
    private bool _isClosing;

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            _isOpenInternal = true;
            _isClosing = false;
        }
        else if (!IsOpen && _isOpenInternal && !_isClosing)
        {
            _ = PlayCloseAnimationAsync();
        }
    }

    private async Task PlayCloseAnimationAsync()
    {
        _isClosing = true;
        await InvokeAsync(StateHasChanged);
        
        await Task.Delay(250);
        
        if (_isClosing)
        {
            _isOpenInternal = false;
            _isClosing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task OnMaskClick()
    {
        return CloseAsync();
    }

    private Task CloseAsync()
    {
        return OnClose.InvokeAsync();
    }
}
