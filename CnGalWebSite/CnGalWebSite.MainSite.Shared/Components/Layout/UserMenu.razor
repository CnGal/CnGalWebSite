@using CnGalWebSite.MainSite.Shared.Components.DesignSystem
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@using CnGalWebSite.SDK.MainSite.Abstractions

@rendermode InteractiveServer

@inject IMainSiteAuthRequestService AuthRequestService
@inject ISpaceQueryService SpaceQueryService

<CgPopupMenu>
    <TriggerContent>
        <button class="cg-action-btn" aria-label="用户菜单">
            @if (_avatarReady)
            {
                <img class="cg-user-menu-avatar"
                     src="@_avatarUrl"
                     alt="@($"{UserName ?? "用户"}头像")" />
            }
            else
            {
                <CgMdiIcon Name="mdiAccountCircleOutline" aria-hidden="true" />
            }
            @if (_unreadCount > 0)
            {
                <span class="cg-badge" aria-label="@($"{_unreadCount} 条未读消息")">@FormatBadge(_unreadCount)</span>
            }
        </button>
    </TriggerContent>
    <ChildContent>
        <div class="cg-menu-header">
            <div class="cg-menu-header__avatar">
                @if (_avatarReady)
                {
                    <img src="@_avatarUrl" alt="" />
                }
                else
                {
                    <CgMdiIcon Name="mdiAccountCircleOutline" aria-hidden="true" />
                }
            </div>
            <div class="cg-menu-header__info">
                <div class="cg-menu-header__name">@UserName</div>
                @if (!string.IsNullOrWhiteSpace(_personalSignature))
                {
                    <div class="cg-menu-header__hint">@_personalSignature</div>
                }
            </div>
        </div>
        <div class="cg-menu-divider"></div>
        <div class="cg-menu-list">
            <a class="cg-menu-item" href="@($"/space/index/{UserId}")">
                <span class="cg-menu-item__icon cg-menu-item__icon--blue">
                    <CgMdiIcon Name="mdiHomeOutline" aria-hidden="true" />
                </span>
                <span class="cg-menu-item__text">个人空间</span>
            </a>
            <a class="cg-menu-item" href="/space/messages">
                <span class="cg-menu-item__icon cg-menu-item__icon--amber">
                    <CgMdiIcon Name="mdiBellOutline" aria-hidden="true" />
                </span>
                <span class="cg-menu-item__text">消息通知</span>
                @if (_unreadCount > 0)
                {
                    <span class="cg-badge cg-badge--inline" aria-label="@($"{_unreadCount} 条未读")">@FormatBadge(_unreadCount)</span>
                }
            </a>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <a class="cg-menu-item" href="/admin">
                        <span class="cg-menu-item__icon cg-menu-item__icon--purple">
                            <CgMdiIcon Name="mdiShieldCrownOutline" aria-hidden="true" />
                        </span>
                        <span class="cg-menu-item__text">管理后台</span>
                    </a>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="cg-menu-divider"></div>
        <div class="cg-menu-list">
            <form class="cg-menu-form" method="post" action="@AuthRequestService.BuildLogoutUrl(CurrentReturnUrl)">
                <button class="cg-menu-item cg-menu-item--danger" type="submit">
                    <span class="cg-menu-item__icon cg-menu-item__icon--red">
                        <CgMdiIcon Name="mdiLogout" aria-hidden="true" />
                    </span>
                    <span class="cg-menu-item__text">退出登录</span>
                </button>
            </form>
        </div>
    </ChildContent>
</CgPopupMenu>

@code {
    [Parameter] public string? UserName { get; set; }
    [Parameter] public string? UserId { get; set; }
    [Parameter] public string CurrentReturnUrl { get; set; } = string.Empty;

    private string? _lastLoadedUserId;
    private string _avatarUrl = string.Empty;
    private string _personalSignature = string.Empty;
    private long _unreadCount;
    private bool _avatarReady => string.IsNullOrWhiteSpace(_avatarUrl) == false;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(UserId))
        {
            _avatarUrl = string.Empty;
            _lastLoadedUserId = null;
            _unreadCount = 0;
            return;
        }

        if (_lastLoadedUserId == UserId)
        {
            return;
        }

        _lastLoadedUserId = UserId;
        _avatarUrl = string.Empty;

        var spaceTask = SpaceQueryService.GetSpaceDetailAsync(UserId);
        var unreadTask = SpaceQueryService.GetUnreadMessageCountAsync();

        await Task.WhenAll(spaceTask, unreadTask);

        var result = spaceTask.Result;
        if (result.Success && result.Data != null)
        {
            _avatarUrl = string.IsNullOrWhiteSpace(result.Data.PhotoPath) ? string.Empty : result.Data.PhotoPath;
            _personalSignature = result.Data.PersonalSignature ?? string.Empty;
        }
        else
        {
            _avatarUrl = string.Empty;
            _personalSignature = string.Empty;
        }

        var unreadResult = unreadTask.Result;
        _unreadCount = unreadResult.Success ? unreadResult.Data : 0;
    }

    private static string FormatBadge(long count) => count > 99 ? "99+" : count.ToString();
}
