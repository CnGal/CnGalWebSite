@using CnGalWebSite.MainSite.Shared.Services
@inject NavigationManager NavigationManager
@inject IMainSiteAuthRequestService AuthRequestService
@inject IKanbanVisibilityService KanbanVisibilityService
@inject IKanbanSettingService KanbanSettingService
@inject IKanbanLive2DService Live2DService
@inject IJSRuntime JS

<nav class="floating-action-toolbar" aria-label="浮动工具栏">
    <div class="floating-action-toolbar__group">
        <button class="floating-action-toolbar__button"
                type="button"
                aria-label="社区交流"
                aria-haspopup="true">
            <CgMdiIcon Name="mdiLink" aria-hidden="true" />
            <span class="floating-action-toolbar__label">社区</span>
        </button>
        <div class="floating-action-toolbar__panel floating-action-toolbar__panel--community" role="group" aria-label="社区交流">
            <div class="floating-action-toolbar__panel-header">
                <CgMdiIcon Name="mdiWechat" aria-hidden="true" />
                <span>社区交流</span>
            </div>
            <CommunityLinksContent />
        </div>
    </div>

    <div class="floating-action-toolbar__group">
        <button class="floating-action-toolbar__button"
                type="button"
                aria-label="工具箱"
                aria-haspopup="true">
            <CgMdiIcon Name="mdiWrenchOutline" aria-hidden="true" />
            <span class="floating-action-toolbar__label">工具</span>
        </button>
        <div class="floating-action-toolbar__panel floating-action-toolbar__panel--tools" role="group" aria-label="工具箱">
            <div class="floating-action-toolbar__panel-header">
                <CgMdiIcon Name="mdiToolbox" aria-hidden="true" />
                <span>工具箱</span>
            </div>

            <AuthorizeView>
                <Authorized>
                    <div class="floating-action-toolbar__toolbox-actions">
                        <ToolboxDialogHost/>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="floating-action-toolbar__login" href="@AuthRequestService.BuildLoginUrl(CurrentReturnUrl)">
                        <CgMdiIcon Name="mdiLogin" aria-hidden="true" />
                        <span>登录后使用工具箱</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>

    <button class="floating-action-toolbar__button"
            type="button"
            aria-label="回到顶部"
            onclick="window.scrollTo({ top: 0, behavior: 'smooth' })">
        <CgMdiIcon Name="mdiArrowUp" aria-hidden="true" />
        <span class="floating-action-toolbar__label">顶部</span>
    </button>

    <button class="floating-action-toolbar__button"
            type="button"
            aria-label="切换为看板娘"
            title="切换为看板娘"
            @onclick="HandleSwitchToKanban">
        <CgMdiIcon Name="mdiSwapHorizontal" aria-hidden="true" />
        <span class="floating-action-toolbar__label">看板</span>
    </button>
</nav>

@code {
    private string CurrentReturnUrl => new Uri(NavigationManager.Uri).PathAndQuery;

    private async Task HandleSwitchToKanban()
    {
        try
        {
            // 计算看板娘位置，使按钮组底部与工具栏底部对齐（切换前后按钮位置不变）
            var pos = await JS.InvokeAsync<KanbanAlignmentResult>("eval",
                "(function(){var t=document.querySelector('.floating-action-toolbar');if(!t)return null;var r=t.getBoundingClientRect();var bw=48,g=12,ksW=" + KanbanSettingService.Kanban.Size.Width + ",ksH=" + KanbanSettingService.Kanban.Size.Height + ",w=window.innerWidth,h=window.innerHeight;var l=Math.round(Math.max(0,Math.min(r.right-ksW-g-bw,w-ksW)));var tp=Math.round(Math.max(0,Math.min(r.bottom-ksH,h-ksH)));return{left:l,top:tp};})()");

            if (pos is not null)
            {
                KanbanSettingService.Kanban.Position.Left = pos.Left;
                KanbanSettingService.Kanban.Position.Top = pos.Top;
                await KanbanSettingService.SaveAsync();

                // 同时设置内存位置，避免 KanbanRoot 首次渲染时闪现到 (0,0)
                Live2DService.Kanban.Position.Left = pos.Left;
                Live2DService.Kanban.Position.Top = pos.Top;
            }
        }
        catch
        {
            // JS 不可用时跳过对齐
        }

        await KanbanVisibilityService.SetShowKanbanAsync(true);
    }

    private class KanbanAlignmentResult
    {
        public int Left { get; set; }
        public int Top { get; set; }
    }
}
