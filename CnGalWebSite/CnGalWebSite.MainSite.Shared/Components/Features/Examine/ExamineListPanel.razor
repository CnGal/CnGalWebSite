@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.Core.Models

@inject IExamineQueryService ExamineQueryService
@inject IExamineCommandService ExamineCommandService
@inject ICgToastService ToastService
@inject NavigationManager NavigationManager

@* 审核列表面板（服务端分页） *@

<CgDataTable TItem="ExamineOverviewModel"
             Title="审核列表"
             OnServerQuery="LoadExaminesAsync"
             DefaultSortField="@nameof(ExamineOverviewModel.PassedTime)"
             DefaultSortDesc="true"
             @ref="_dataTable">

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="Id" Field="@nameof(ExamineOverviewModel.Id)" Width="80px" />

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="操作" Field="@nameof(ExamineOverviewModel.Operation)" Sortable="false">
        <ChildContent Context="item">
            @item.Operation.GetDisplayName()
        </ChildContent>
    </CgDataTableColumn>

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="状态" Field="@nameof(ExamineOverviewModel.IsPassed)" Sortable="false">
        <ChildContent Context="item">
            <ExamineStatusBadge IsPassed="@item.IsPassed" />
        </ChildContent>
    </CgDataTableColumn>

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="处理时间" Field="@nameof(ExamineOverviewModel.PassedTime)">
        <ChildContent Context="item">
            @(item.PassedTime?.ToString("yyyy-MM-dd HH:mm") ?? "—")
        </ChildContent>
    </CgDataTableColumn>

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="申请时间" Field="@nameof(ExamineOverviewModel.ApplyTime)">
        <ChildContent Context="item">
            @item.ApplyTime.ToString("yyyy-MM-dd HH:mm")
        </ChildContent>
    </CgDataTableColumn>

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="申请人" Sortable="false">
        <ChildContent Context="item">
            <a class="examine-user-link" href="/space/index/@item.ApplicationUserId">@(item.UserName ?? "—")</a>
        </ChildContent>
    </CgDataTableColumn>

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="处理人" Field="@nameof(ExamineOverviewModel.PassedAdminName)" Sortable="false" />

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="批注" Field="@nameof(ExamineOverviewModel.Comments)" Sortable="false" />

    <CgDataTableColumn TItem="ExamineOverviewModel" Title="操作" Sortable="false" Width="140px">
        <ChildContent Context="item">
            <div class="examine-actions">
                <button class="examine-action-btn examine-action-btn--view" title="查看" @onclick="() => LookItem(item)">
                    <CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" />
                </button>
                @if (item.IsPassed == null)
                {
                    <button class="examine-action-btn examine-action-btn--approve" title="通过" @onclick="() => ProcItem(item, true)">
                        <CgMdiIcon Name="mdiCheck" aria-hidden="true" />
                    </button>
                    <button class="examine-action-btn examine-action-btn--reject" title="驳回" @onclick="() => ProcItem(item, false)">
                        <CgMdiIcon Name="mdiClose" aria-hidden="true" />
                    </button>
                }
            </div>
        </ChildContent>
    </CgDataTableColumn>

</CgDataTable>

@code {
    private CgDataTable<ExamineOverviewModel>? _dataTable;

    private async Task<CgDataTableResult<ExamineOverviewModel>> LoadExaminesAsync(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? "",
            SortBy = string.IsNullOrWhiteSpace(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };

        var result = await ExamineQueryService.GetExaminesAsync(parameter);
        if (result.Success && result.Data != null)
        {
            return new CgDataTableResult<ExamineOverviewModel>(
                result.Data.Items.ToList(),
                result.Data.Total);
        }

        return new CgDataTableResult<ExamineOverviewModel>([], 0);
    }

    private void LookItem(ExamineOverviewModel model)
    {
        NavigationManager.NavigateTo($"/examine?Id={model.Id}");
    }

    private async Task ProcItem(ExamineOverviewModel model, bool isPassed)
    {
        var operationName = isPassed ? "通过审核" : "驳回审核";
        var result = await ExamineCommandService.ProcExamineAsync(model.Id, isPassed);
        if (result.Success)
        {
            ToastService.Show(operationName + "成功", variant: "success");
            if (_dataTable != null)
            {
                await _dataTable.RefreshAsync();
            }
        }
        else
        {
            ToastService.Show(operationName + "失败", result.Error?.Message, "error");
        }
    }
}
