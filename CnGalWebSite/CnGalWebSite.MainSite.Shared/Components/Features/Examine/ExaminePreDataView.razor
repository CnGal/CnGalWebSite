@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.Search

@* 展示 ExaminePreDataModel 的结构化内容 — 正文、图片、文本信息、关联、外链、音频 *@

@if (Model is not null)
{
    <div class="examine-pre-data-view">
        @* ── 正文 ── *@
        @if (!string.IsNullOrWhiteSpace(Model.MainPage))
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiTextBoxOutline" aria-hidden="true" />
                    正文
                </h5>
                <div class="examine-pre-data-view__section-body">
                    <CgHtmlContent Content="@Model.MainPage" />
                </div>
            </section>
        }

        @* ── 文本信息 ── *@
        @if (Model.Texts.Count > 0)
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiFormatListBulleted" aria-hidden="true" />
                    文本信息 (@Model.Texts.Count)
                </h5>
                <div class="examine-pre-data-view__section-body">
                    @foreach (var group in Model.Texts)
                    {
                        @if (!string.IsNullOrWhiteSpace(group.Modifier))
                        {
                            <div class="examine-pre-data-view__group-title">@group.Modifier</div>
                        }
                        <table class="examine-pre-data-view__table">
                            <thead>
                                <tr>
                                    <th>名称</th>
                                    <th>值</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var kv in group.Informations)
                                {
                                    <tr>
                                        <td>@kv.DisplayName</td>
                                        <td>@kv.DisplayValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>
        }

        @* ── 图片 ── *@
        @if (Model.Pictures.Count > 0)
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiImageMultipleOutline" aria-hidden="true" />
                    图片 (@Model.Pictures.Count)
                </h5>
                <div class="examine-pre-data-view__section-body">
                    <div class="examine-pre-data-view__image-grid">
                        @foreach (var pic in Model.Pictures)
                        {
                            <div class="examine-pre-data-view__image-item">
                                <img src="@pic.Url" alt="@(pic.Note ?? "")" loading="lazy" />
                                @if (!string.IsNullOrWhiteSpace(pic.Note))
                                {
                                    <span class="examine-pre-data-view__image-note">@pic.Note</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </section>
        }

        @* ── 关联 ── *@
        @if (Model.Relevances.Count > 0)
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiLinkVariant" aria-hidden="true" />
                    关联 (@Model.Relevances.Count)
                </h5>
                <div class="examine-pre-data-view__section-body">
                    <div class="examine-pre-data-view__tag-list">
                        @foreach (var rel in Model.Relevances)
                        {
                            var name = GetRelevanceName(rel);
                            if (!string.IsNullOrWhiteSpace(name))
                            {
                                <span class="examine-pre-data-view__tag">@name</span>
                            }
                        }
                    </div>
                </div>
            </section>
        }

        @* ── 外链 ── *@
        @if (Model.Outlinks.Count > 0)
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiOpenInNew" aria-hidden="true" />
                    外链 (@Model.Outlinks.Count)
                </h5>
                <div class="examine-pre-data-view__section-body">
                    <table class="examine-pre-data-view__table">
                        <thead>
                            <tr>
                                <th>名称</th>
                                <th>链接</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var link in Model.Outlinks)
                            {
                                <tr>
                                    <td>@link.DisplayName</td>
                                    <td>@link.DisplayValue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @* ── 音频 ── *@
        @if (Model.Audio.Count > 0)
        {
            <section class="examine-pre-data-view__section">
                <h5 class="examine-pre-data-view__section-title">
                    <CgMdiIcon Name="mdiMusicNoteOutline" aria-hidden="true" />
                    音频 (@Model.Audio.Count)
                </h5>
                <div class="examine-pre-data-view__section-body">
                    @foreach (var audio in Model.Audio)
                    {
                        <div class="examine-pre-data-view__audio-item">
                            <span>@audio.Name</span>
                            @if (!string.IsNullOrWhiteSpace(audio.Url))
                            {
                                <a href="@audio.Url" target="_blank" rel="noopener noreferrer">播放</a>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @* ── 空状态 ── *@
        @if (string.IsNullOrWhiteSpace(Model.MainPage) && Model.Texts.Count == 0 && Model.Pictures.Count == 0
             && Model.Relevances.Count == 0 && Model.Outlinks.Count == 0 && Model.Audio.Count == 0)
        {
            <div class="examine-pre-data-view__empty">
                <CgMdiIcon Name="mdiInformationOutline" aria-hidden="true" />
                <span>暂无数据</span>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public ExaminePreDataModel? Model { get; set; }

    private static string? GetRelevanceName(SearchAloneModel model)
    {
        if (model.entry is not null) return model.entry.Name;
        if (model.article is not null) return model.article.DisplayName ?? model.article.Name;
        if (model.tag is not null) return model.tag.Name;
        if (model.video is not null) return model.video.DisplayName ?? model.video.Name;
        if (model.periphery is not null) return model.periphery.Name;
        if (model.user is not null) return model.user.UserName ?? "用户";
        return null;
    }
}

