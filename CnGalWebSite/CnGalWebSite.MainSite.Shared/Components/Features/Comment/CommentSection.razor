@* 评论区入口容器（静态 SSR）
   编排只读列表 + AuthorizeView 包裹的交互区域
   未登录：纯静态只读评论列表
   已登录：交互式评论列表（支持回复、删除、实时刷新） *@

@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.SDK.MainSite.Models.Comments
@using CnGalWebSite.MainSite.Shared.Components.Features.Comment

@inject ICommentQueryService CommentQueryService

<CgMiniModeContainer>
    <section class="comment-section" aria-label="评论区">
        <h2>
            <CgMdiIcon Name="mdiCommentTextMultipleOutline" /> 留言板
            @if (_totalCount > 0)
            {
                <span class="comment-section__count">@_totalCount</span>
            }
        </h2>

        @if (!CanComment)
        {
            <CommentClosedTip />
        }
        else
        {
            @* 登录用户使用交互式评论区（独立获取数据，支持回复/删除/刷新） *@
            <AuthorizeView>
                <Authorized>
                    <CommentInteractive Type="Type"
                                        ObjectId="@ObjectId"
                                        CanDelete="CanDelete" />
                </Authorized>
                <NotAuthorized>
                    @* 未登录用户：纯静态只读评论列表 *@
                    @if (_items is not null)
                    {
                        <CommentList Items="_items" ShowActions="false" />
                    }

                    <div class="comment-section__login-prompt">
                        <CgMdiIcon Name="mdiLoginVariant" />
                        <span>登入后可以发表评论</span>
                        <CgButton Variant="primary" Href="/account/login" class="comment-section__login-btn">去登录</CgButton>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        }
    </section>
</CgMiniModeContainer>

@code {
    /// <summary>
    /// 评论类型（词条、文章、视频等）
    /// </summary>
    [Parameter, EditorRequired]
    public CommentType Type { get; set; }

    /// <summary>
    /// 对象 ID
    /// </summary>
    [Parameter, EditorRequired]
    public string ObjectId { get; set; } = "";

    /// <summary>
    /// 是否允许评论
    /// </summary>
    [Parameter]
    public bool CanComment { get; set; } = true;

    /// <summary>
    /// 是否可以删除评论（管理员权限）
    /// </summary>
    [Parameter]
    public bool CanDelete { get; set; }

    /// <summary>
    /// 是否逆序显示（最新评论在前）
    /// </summary>
    [Parameter]
    public bool Desc { get; set; }

    private IReadOnlyList<CommentItemViewModel>? _items;
    private int _totalCount;

    protected override async Task OnParametersSetAsync()
    {
        if (!CanComment)
        {
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        var result = await CommentQueryService.GetCommentsAsync(Type, ObjectId);
        if (result.Success && result.Data is not null)
        {
            var items = result.Data.Items;
            if (Desc)
            {
                items = items.OrderByDescending(s => s.CommentTime).ToList();
            }
            _items = items;
            _totalCount = result.Data.TotalCount;
        }
        else
        {
            _items = [];
            _totalCount = 0;
        }
    }
}
