@using Microsoft.AspNetCore.Components.Web
@using CnGalWebSite.MainSite.Shared.Services
@using CnGalWebSite.MainSite.Shared.Services.KanbanModels
@inject IKanbanLive2DService Live2DService
@inject IKanbanRemoteConfigService RemoteConfigService
@inject IKanbanSettingService SettingService
@inject IKanbanUserDataService UserDataService
@inject IKanbanEventService EventService
@inject ICommodityQueryService CommodityService
@inject IKanbanCommodityOwnershipService OwnershipService
@inject IJSRuntime JS
@implements IDisposable
@rendermode InteractiveServer

<div id="kanban-live2d" class="kanban-live2d @(_settingsLoaded ? "" : "kanban-live2d--hidden")" style="@GetStyleString()">
    <KanbanMainCard Width="@Live2DService.Kanban.Size.Width" Height="@Live2DService.Kanban.Size.Height" />

    <button class="kanban-resize-handle" type="button"
            aria-label="拖动调整看板娘大小"
            title="拖动调整大小">
        <CgMdiIcon Name="mdiDragVariant" aria-hidden="true" />
    </button>

    <KanbanButtonGroup OnBackToTop="HandleBackToTop">
        <ChatContent>
            <KanbanChatCard />
        </ChatContent>
        <ClothesContent>
            <KanbanSettingsPanel Title="服装"
                                 HeaderIcon="mdiHanger"
                                 Clothes="_clothes"
                                 Stockings="_stockings"
                                 Shoes="_shoes"
                                 ShowExpressionsSection="false"
                                 OwnedItems="_ownedItems" />
        </ClothesContent>
        <ExpressionsContent>
            <KanbanSettingsPanel Title="表情"
                                 HeaderIcon="mdiEmoticonOutline"
                                 Expressions="_expressions"
                                 ShowClothesSection="false"
                                 ShowStockingsSection="false"
                                 ShowShoesSection="false"
                                 OwnedItems="_ownedItems" />
        </ExpressionsContent>
        <CommunityContent>
            <KanbanCommunityPanel />
        </CommunityContent>
        <ToolboxContent>
            <KanbanToolboxPanel />
        </ToolboxContent>
    </KanbanButtonGroup>
    <KanbanDialogBox Model="_currentDialog" OnClose="HandleDialogClose" />
</div>

@code {
    private bool _isReady;
    private bool _settingsLoaded;
    private CancellationTokenSource? _cts;
    private Task? _eventLoopTask;

    private List<KanbanClothesModel>? _clothes;
    private List<KanbanStockingsModel>? _stockings;
    private List<KanbanShoesModel>? _shoes;
    private List<KanbanExpressionModel>? _expressions;
    private List<KanbanMotionGroupModel>? _motionGroups;
    private List<string>? _ownedItems;

    /// <summary>
    /// 事件服务触发的当前对话框模型，传入 KanbanDialogBox 显示。
    /// </summary>
    private KanbanDialogBoxModel? _currentDialog;

    protected override void OnInitialized()
    {
        Live2DService.Live2DInitialized += OnLive2DInitialized;
        Live2DService.CustomEventTriggered += OnCustomEventTriggered;
        EventService.OnDialogTriggered += OnDialogTriggered;
        OwnershipService.OwnershipChanged += OnOwnershipChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 先加载设置，确保 canvas 在 Live2D 初始化前已是正确尺寸
            await SettingService.LoadAsync();
            Live2DService.Kanban.Position.Left = SettingService.Kanban.Position.Left;
            Live2DService.Kanban.Position.Top = SettingService.Kanban.Position.Top;
            Live2DService.Kanban.Size.Width = SettingService.Kanban.Size.Width;
            Live2DService.Kanban.Size.Height = SettingService.Kanban.Size.Height;
            Live2DService.DialogBox.Position.Left = SettingService.DialogBox.Position.Left;
            Live2DService.DialogBox.Position.Bottom = SettingService.DialogBox.Position.Bottom;

            _settingsLoaded = true;
            StateHasChanged();

            await Live2DService.InitAsync("cngal形象", 0);

            await UserDataService.LoadAsync();

            _cts = new CancellationTokenSource();
            await LoadSettingsDataAsync();

            // 启动看板娘事件循环（定时问候、空闲事件、鼠标悬停、导航事件等）
            _eventLoopTask = EventService.StartAsync(_cts.Token);

            StateHasChanged();
        }
    }

    private async Task LoadSettingsDataAsync()
    {
        try
        {
            _clothes = await RemoteConfigService.GetClothesAsync();
            _stockings = await RemoteConfigService.GetStockingsAsync();
            _shoes = await RemoteConfigService.GetShoesAsync();
            _expressions = await RemoteConfigService.GetExpressionsAsync();
            _motionGroups = await RemoteConfigService.GetMotionGroupsAsync();
            await RefreshOwnedItemsAsync();
        }
        catch
        {
            _ownedItems = [];
        }
    }

    private async Task RefreshOwnedItemsAsync()
    {
        var commodities = await CommodityService.GetAllCommoditiesAsync(_cts?.Token ?? default);
        _ownedItems = commodities.Success && commodities.Data is not null
            ? commodities.Data
                .Where(item => item.IsOwned && !string.IsNullOrWhiteSpace(item.Value))
                .Select(item => item.Value)
                .ToList()
            : [];
    }

    private string GetStyleString()
    {
        var kanban = Live2DService.Kanban;
        return $"position:fixed; left:{kanban.Position.Left}px; top:{kanban.Position.Top}px; width:{kanban.Size.Width}px; height:{kanban.Size.Height}px; z-index:var(--cg-kanban-z-index);";
    }

    private async Task HandleBackToTop()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "window.scrollTo({top:0,behavior:'smooth'})");
        }
        catch
        {
        }
    }

    private async void OnLive2DInitialized()
    {
        _isReady = true;

        var userData = UserDataService.UserData;
        if (!string.IsNullOrEmpty(userData.ClothesName))
        {
            await Live2DService.SetClothes(userData.ClothesName);
        }

        if (!string.IsNullOrEmpty(userData.StockingsName))
        {
            await Live2DService.SetStockings(userData.StockingsName);
        }

        if (!string.IsNullOrEmpty(userData.ShoesName))
        {
            await Live2DService.SetShoes(userData.ShoesName);
        }

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// 将 Live2D JS 层的自定义事件（摸头、触碰身体等）转发给事件服务处理。
    /// </summary>
    private async void OnCustomEventTriggered(string eventName)
    {
        try
        {
            await EventService.TriggerCustomEventAsync(eventName);
        }
        catch
        {
            // 静默处理，避免阻塞 Live2D 交互
        }
    }

    /// <summary>
    /// 事件服务弹出对话框时触发，将 Model 传给 KanbanDialogBox 显示。
    /// </summary>
    private void OnDialogTriggered(KanbanDialogBoxModel model)
    {
        _currentDialog = model;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnOwnershipChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await RefreshOwnedItemsAsync();
            StateHasChanged();
        });
    }

    /// <summary>
    /// 用户关闭对话框时清除当前对话框。
    /// </summary>
    private async Task HandleDialogClose()
    {
        _currentDialog = null;
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();

        Live2DService.Live2DInitialized -= OnLive2DInitialized;
        Live2DService.CustomEventTriggered -= OnCustomEventTriggered;
        EventService.OnDialogTriggered -= OnDialogTriggered;
        OwnershipService.OwnershipChanged -= OnOwnershipChanged;

        _ = Live2DService.ReleaseLive2D();
        GC.SuppressFinalize(this);
    }
}
