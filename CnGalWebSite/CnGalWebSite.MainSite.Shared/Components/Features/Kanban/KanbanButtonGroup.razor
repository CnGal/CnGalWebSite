@implements IDisposable

<div id="kanban-button-group" class="kanban-button-group">
    <CgPopupMenu>
        <TriggerContent>
            <button class="kanban-action-btn" type="button" title="聊天" aria-label="聊天">
                <CgMdiIcon Name="mdiChat" aria-hidden="true" />
            </button>
        </TriggerContent>
        <ChildContent>
            @ChatContent
        </ChildContent>
    </CgPopupMenu>

    <CgPopupMenu>
        <TriggerContent>
            <button class="kanban-action-btn" type="button" title="设置" aria-label="设置">
                <CgMdiIcon Name="mdiCogOutline" aria-hidden="true" />
            </button>
        </TriggerContent>
        <ChildContent>
            @SettingsContent
        </ChildContent>
    </CgPopupMenu>

    <button class="kanban-action-btn" type="button" title="回到顶部" aria-label="回到顶部" @onclick="() => OnBackToTop.InvokeAsync()">
        <CgMdiIcon Name="mdiArrowUp" aria-hidden="true" />
    </button>

    <button class="kanban-action-btn kanban-action-btn--danger" type="button" title="退出 (双击确认)" aria-label="退出" @onclick="HandleQuitClick">
        <CgMdiIcon Name="mdiClose" aria-hidden="true" />
    </button>
</div>

@code {
    [Parameter]
    public RenderFragment? ChatContent { get; set; }

    [Parameter]
    public RenderFragment? SettingsContent { get; set; }

    [Parameter]
    public EventCallback OnBackToTop { get; set; }

    [Parameter]
    public EventCallback OnQuit { get; set; }

    private int _quitClickCount;
    private System.Timers.Timer? _quitTimer;

    private void HandleQuitClick()
    {
        _quitClickCount++;

        if (_quitClickCount == 1)
        {
            StartQuitTimer();
        }
        else
        {
            ResetQuitState();
            OnQuit.InvokeAsync();
        }
    }

    private void StartQuitTimer()
    {
        _quitTimer?.Dispose();
        _quitTimer = new System.Timers.Timer(5000);
        _quitTimer.Elapsed += OnQuitTimerElapsed;
        _quitTimer.AutoReset = false;
        _quitTimer.Start();
    }

    private void OnQuitTimerElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        _ = InvokeAsync(ResetQuitState);
    }

    private void ResetQuitState()
    {
        _quitClickCount = 0;
        _quitTimer?.Dispose();
        _quitTimer = null;
    }

    public void Dispose()
    {
        _quitTimer?.Dispose();
        GC.SuppressFinalize(this);
    }
}
