@implements IDisposable

<div id="kanban-button-group" class="kanban-button-group">
    <AuthorizeView Roles="Admin">
        <CgButton Variant="ghost" Size="sm" OnClick="OnChatClick" title="聊天">
            聊
        </CgButton>
    </AuthorizeView>
    <CgButton Variant="ghost" Size="sm" OnClick="OnClothesClick" title="换装">
        装
    </CgButton>
    <CgButton Variant="ghost" Size="sm" OnClick="OnExpressionClick" title="表情">
        表
    </CgButton>
    <CgButton Variant="ghost" Size="sm" OnClick="OnMotionClick" title="动作">
        动
    </CgButton>
    <CgButton Variant="ghost" Size="sm" OnClick="OnBackToTop" title="回到顶部">
        ↑
    </CgButton>
    <CgButton Variant="ghost-danger" Size="sm" OnClick="HandleQuitClick" title="退出 (双击确认)">
        ✕
    </CgButton>
</div>

@code {
    [Parameter]
    public EventCallback OnChatClick { get; set; }

    [Parameter]
    public EventCallback OnClothesClick { get; set; }

    [Parameter]
    public EventCallback OnExpressionClick { get; set; }

    [Parameter]
    public EventCallback OnMotionClick { get; set; }

    [Parameter]
    public EventCallback OnBackToTop { get; set; }

    [Parameter]
    public EventCallback OnQuit { get; set; }

    private int _quitClickCount;
    private System.Timers.Timer? _quitTimer;

    private void HandleQuitClick()
    {
        _quitClickCount++;

        if (_quitClickCount == 1)
        {
            StartQuitTimer();
        }
        else
        {
            ResetQuitState();
            OnQuit.InvokeAsync();
        }
    }

    private void StartQuitTimer()
    {
        _quitTimer?.Dispose();
        _quitTimer = new System.Timers.Timer(5000);
        _quitTimer.Elapsed += OnQuitTimerElapsed;
        _quitTimer.AutoReset = false;
        _quitTimer.Start();
    }

    private void OnQuitTimerElapsed(object? sender, System.Timers.ElapsedEventArgs e)
    {
        _ = InvokeAsync(ResetQuitState);
    }

    private void ResetQuitState()
    {
        _quitClickCount = 0;
        _quitTimer?.Dispose();
        _quitTimer = null;
    }

    public void Dispose()
    {
        _quitTimer?.Dispose();
        GC.SuppressFinalize(this);
    }
}
