@using CnGalWebSite.MainSite.Shared.Services
@using CnGalWebSite.MainSite.Shared.Services.KanbanModels
@inject IKanbanChatService ChatService
@inject IJSRuntime JS

<div id="kanban-chatcard" class="kanban-chat-card">
    <div class="kanban-chat-header">
        <div class="kanban-chat-header-start">
            <CgMdiIcon Name="mdiChat" aria-hidden="true" />
            <span class="kanban-chat-title">聊天</span>
        </div>
    </div>

    <div class="kanban-chat-messages" @ref="_messagesContainer">
        @foreach (var msg in _visibleMessages)
        {
            <div class="kanban-chat-message @(msg.IsUser ? "kanban-chat-message--user" : "kanban-chat-message--bot")">
                @if (!msg.IsUser)
                {
                    <img class="kanban-chat-avatar"
                         src="@(string.IsNullOrEmpty(msg.Image) ? "_content/CnGalWebSite.MainSite.Shared/images/default-avatar.svg" : msg.Image)"
                         alt="看板娘头像" />
                }
                <div class="kanban-chat-bubble">
                    @msg.Text
                </div>
                @if (msg.IsUser)
                {
                    <img class="kanban-chat-avatar"
                         src="@(string.IsNullOrEmpty(msg.Image) ? "_content/CnGalWebSite.MainSite.Shared/images/default-avatar.svg" : msg.Image)"
                         alt="用户头像" />
                }
            </div>
        }
    </div>

    <div class="kanban-chat-input-area">
        <CgTextarea @bind-Value="@_inputText"
                    Placeholder="来聊天吧~"
                    Rows="2"
                    Disabled="@_isSending" />
        <CgButton Variant="primary"
                  Size="sm"
                  Async
                  OnClick="SendAsync"
                  Disabled="@(string.IsNullOrWhiteSpace(_inputText) || _isSending)">
            发送
        </CgButton>
    </div>
</div>

@code {
    private ElementReference _messagesContainer;
    private string _inputText = string.Empty;
    private bool _isSending;
    private int _lastMessageCount;

    private IReadOnlyList<KanbanChatModel> _visibleMessages =>
        ChatService.Messages;

    protected override void OnInitialized()
    {
        ChatService.Show();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_visibleMessages.Count != _lastMessageCount)
        {
            _lastMessageCount = _visibleMessages.Count;
            await ScrollToBottomAsync();
        }
    }

    private async Task SendAsync(MouseEventArgs args)
    {
        if (string.IsNullOrWhiteSpace(_inputText) || _isSending)
        {
            return;
        }

        _isSending = true;
        var message = _inputText;
        _inputText = string.Empty;
        StateHasChanged();

        try
        {
            await ChatService.SendMessageAsync(message, isFirst: false);
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "arguments[0].scrollTop = arguments[0].scrollHeight", _messagesContainer);
        }
        catch
        {
        }
    }

    public void Dispose()
    {
        ChatService.Close();
        GC.SuppressFinalize(this);
    }
}
