@rendermode InteractiveServer
@inject IExpoQueryService ExpoQueryService
@inject IExpoCommandService ExpoCommandService
@inject ICgToastService ToastService
@inject ICgDeviceIdentificationService DeviceIdentificationService
@inject ILotteryCommandService LotteryCommandService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IMainSiteAuthRequestService AuthRequestService

<div class="lottery-tasks-card">
    @foreach (var task in GetSortedTasks())
    {
        <div class="task-card">
            <div>
                <div class="name-card">
                    @if (!string.IsNullOrWhiteSpace(task.Link))
                    {
                        <a href="@task.Link" target="_blank" rel="noopener">
                            @task.Name
                        </a>
                    }
                    else
                    {
                        @task.Name
                    }
                </div>
                <div class="content-card">
                    <div class="gift-card">
                        <CgMdiIcon Name="mdiGift" />
                        <div class="count-card">@task.Points 点</div>
                    </div>
                    @if (task.IsCompleted)
                    {
                        <div class="action-card active">
                            已完成
                        </div>
                    }
                    else if (task.IsSignedIn)
                    {
                        <div class="action-card active">
                            已签到
                        </div>
                    }
                    else
                    {
                        <div class="action-card" @onclick="task.OnClick">
                            @if (task.IsLoading)
                            {
                                <span>@task.LoadingText</span>
                            }
                            else
                            {
                                <span>去完成</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<SpaceSteamEditModal @bind-Visible="_showSteamModal" />

@code {
    [Parameter]
    public ExpoUserTaskModel Model { get; set; } = new();

    [Parameter]
    public EventCallback OnChanged { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    private bool _showSteamModal;
    private bool _isDrawing;

    private const long LotteryId = 56;

    public class TaskItem
    {
        public string Name { get; set; } = string.Empty;
        public int Points { get; set; }
        public bool IsCompleted { get; set; }
        public bool IsSignedIn { get; set; }
        public bool IsLoading { get; set; }
        public string LoadingText { get; set; } = string.Empty;
        public string? Link { get; set; }
        public Func<Task> OnClick { get; set; } = () => Task.CompletedTask;
    }

    private List<TaskItem> GetSortedTasks()
    {
        var tasks = new List<TaskItem>
        {
            new()
            {
                Name = "领取抽奖号码",
                Points = 100,
                IsCompleted = Model.IsLotteryNumber,
                IsLoading = _isDrawing,
                LoadingText = "抽奖中",
                OnClick = OnClickLotteryNumberAsync
            },
            new()
            {
                Name = "预约CnGal周年庆直播",
                Points = 50,
                IsCompleted = Model.IsBooking,
                Link = "https://space.bilibili.com/145239325/dynamic",
                OnClick = OnClickBookingAsync
            },
            new()
            {
                Name = "晒出Steam游戏库",
                Points = 50,
                IsCompleted = Model.IsPickUpSharedGames,
                OnClick = Model.IsSharedGames ? OnClickShareGamesAsync : OnClickOpenShareGamesAsync
            },
            new()
            {
                Name = $"每日签到 ({Model.SignInDays}/5)",
                Points = 20,
                IsCompleted = Model.SignInDays >= 5,
                IsSignedIn = Model.IsSignIn && Model.SignInDays < 5,
                OnClick = OnClickSignInAsync
            },
            new()
            {
                Name = "给游戏评分",
                Points = 20,
                IsCompleted = Model.IsRateGame,
                Link = "https://www.cngal.org/sharegames/new",
                OnClick = OnClickRateGameAsync
            },
            new()
            {
                Name = "绑定群聊QQ",
                Points = 20,
                IsCompleted = Model.IsBindQQ,
                Link = "/space/edit",
                OnClick = OnClickBindQQAsync
            },
            new()
            {
                Name = "更换默认头像",
                Points = 20,
                IsCompleted = Model.IsChangeAvatar,
                Link = "/space/edit",
                OnClick = OnClickChangeAvatarAsync
            },
            new()
            {
                Name = "更换默认签名",
                Points = 20,
                IsCompleted = Model.IsChangeSignature,
                Link = "/space/edit",
                OnClick = OnClickChangeSignatureAsync
            },
            new()
            {
                Name = "填写国G世代",
                Points = 20,
                IsCompleted = Model.IsSaveGGeneration,
                Link = "https://www.cngal.org/sedai",
                OnClick = OnClickSaveGGenerationAsync
            }
        };

        return tasks.OrderBy(t => t.IsCompleted ? 1 : 0).ToList();
    }

    private async Task<bool> CheckLoginAsync()
    {
        if (AuthState is null)
        {
            var returnUrl = new Uri(Navigation.Uri).PathAndQuery;
            Navigation.NavigateTo(AuthRequestService.BuildLoginUrl(returnUrl), true);
            return false;
        }

        var authState = await AuthState;
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            return true;
        }

        var returnUrl2 = new Uri(Navigation.Uri).PathAndQuery;
        Navigation.NavigateTo(AuthRequestService.BuildLoginUrl(returnUrl2), true);
        return false;
    }

    private async Task FinishTaskAsync(ExpoTaskType type)
    {
        try
        {
            var result = await ExpoCommandService.FinishTaskAsync(type);
            if (!result.Success)
            {
                ToastService.Show("完成任务失败", result.Error?.Message ?? "请稍后重试", "error");
                return;
            }

            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            ToastService.Show("完成任务失败", ex.Message, "error");
        }
    }

    private async Task OnClickBookingAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsBooking) return;

        await JS.InvokeVoidAsync("window.open", "https://space.bilibili.com/145239325", "_blank");
        await FinishTaskAsync(ExpoTaskType.Booking);
    }

    private async Task OnClickShareGamesAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsPickUpSharedGames) return;
        await FinishTaskAsync(ExpoTaskType.ShareGames);
    }

    private async Task OnClickOpenShareGamesAsync()
    {
        if (!await CheckLoginAsync()) return;

        try
        {
            var result = await ExpoQueryService.CheckUserGameRatingAsync();
            if (result.Success)
            {
                await FinishTaskAsync(ExpoTaskType.ShareGames);
                return;
            }
        }
        catch { /* fall through to steam modal */ }

        // Check if user has Steam ID — open Steam modal if not
        _showSteamModal = true;
        StateHasChanged();
    }

    private async Task OnClickSignInAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsSignIn) return;
        if (Model.SignInDays >= 5) return;
        await FinishTaskAsync(ExpoTaskType.SignIn);
    }

    private async Task OnClickSurveyAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsSurvey) return;

        try
        {
            var result = await ExpoQueryService.CheckUserGameRatingAsync();
            if (result.Success)
            {
                await FinishTaskAsync(ExpoTaskType.Survey);
                return;
            }
        }
        catch { /* fall through to navigate */ }

        // Navigate to questionnaires page
        Navigation.NavigateTo("/questionnaires");
    }

    private async Task OnClickRateGameAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsRateGame) return;

        try
        {
            var result = await ExpoQueryService.CheckUserGameRatingAsync();
            if (result.Success && result.Data)
            {
                await FinishTaskAsync(ExpoTaskType.RateGame);
                return;
            }
        }
        catch { /* fall through */ }

        ToastService.Show("提示", "请先对游戏进行评分后再领取奖励", "info");
        await JS.InvokeVoidAsync("window.open", "https://www.cngal.org/sharegames/new", "_blank");
    }

    private async Task OnClickBindQQAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsBindQQ) return;

        try
        {
            var result = await ExpoQueryService.CheckUserBindQQAsync();
            if (result.Success && result.Data)
            {
                await FinishTaskAsync(ExpoTaskType.BindQQ);
                return;
            }
        }
        catch { /* fall through */ }

        ToastService.Show("提示", "请先绑定群聊QQ后再领取奖励", "info");
        await JS.InvokeVoidAsync("window.open", "/space/edit", "_blank");
    }

    private async Task OnClickChangeAvatarAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsChangeAvatar) return;

        try
        {
            var result = await ExpoQueryService.CheckUserChangeAvatarAsync();
            if (result.Success && result.Data)
            {
                await FinishTaskAsync(ExpoTaskType.ChangeAvatar);
                return;
            }
        }
        catch { /* fall through */ }

        ToastService.Show("提示", "请先更换默认头像后再领取奖励", "info");
        await JS.InvokeVoidAsync("window.open", "/space/edit", "_blank");
    }

    private async Task OnClickChangeSignatureAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsChangeSignature) return;

        try
        {
            var result = await ExpoQueryService.CheckUserChangeSignatureAsync();
            if (result.Success && result.Data)
            {
                await FinishTaskAsync(ExpoTaskType.ChangeSignature);
                return;
            }
        }
        catch { /* fall through */ }

        ToastService.Show("提示", "请先更换默认签名后再领取奖励", "info");
        await JS.InvokeVoidAsync("window.open", "/space/edit", "_blank");
    }

    private async Task OnClickSaveGGenerationAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsSaveGGeneration) return;

        await JS.InvokeVoidAsync("window.open", "https://www.cngal.org/sedai", "_blank");
        await FinishTaskAsync(ExpoTaskType.SaveGGeneration);
    }

    private async Task OnClickLotteryNumberAsync()
    {
        if (!await CheckLoginAsync()) return;
        if (Model.IsLotteryNumber) return;

        if (Model.IsHasJoinedLottery)
        {
            await FinishTaskAsync(ExpoTaskType.LotteryNumber);
        }
        else
        {
            Navigation.NavigateTo("/expo/anniversary");
        }
    }
}
