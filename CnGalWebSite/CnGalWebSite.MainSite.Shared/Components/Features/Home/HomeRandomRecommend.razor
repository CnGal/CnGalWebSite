@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Home
@using CnGalWebSite.DataModel.Model

<HomeSection Title="随机推荐" Icon="mdiTrendingUp" IconColor="var(--cg-color-secondary)">
    <ul class="home-random-recommend-grid">
        @if (HotRecommends != null)
        {
            foreach (var item in HotRecommends.Take(8))
            {
                <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction">
                    @if (item.Reason != RecommendReason.None)
                    {
                        <span class="home-recommend-reason">
                            <CgMdiIcon Name="mdiStarOutline" aria-hidden="true" />
                            @item.Reason.GetDisplayName()
                        </span>
                    }
                </HomeGameCard>
            }
        }
    </ul>
</HomeSection>

@code {
    [Parameter]
    public IEnumerable<HotRecommendItemModel> HotRecommends { get; set; } = [];
}
