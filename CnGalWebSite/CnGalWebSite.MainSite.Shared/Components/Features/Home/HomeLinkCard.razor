<li class="home-card @(CommunityStyle ? "home-card--community" : string.Empty)">
    <a href="@Url" target="@Target" rel="noopener noreferrer">
        @if (CommunityStyle)
        {
            <span class="home-card-community-icon @(GetToneClass())">
                <CgMdiIcon Name="@Icon" aria-hidden="true" />
            </span>
            <span class="home-card-community-content">
                <strong>@Title</strong>
                @if (!string.IsNullOrWhiteSpace(Text))
                {
                    <p>@Text</p>
                }
            </span>
        }
        else
        {
            <strong>@Title</strong>
            @if (!string.IsNullOrWhiteSpace(Text))
            {
                <p>@Text</p>
            }
        }
    </a>
</li>

@code {
    [Parameter] public string Url { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Text { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public bool CommunityStyle { get; set; }
    [Parameter] public string Icon { get; set; } = "mdiForum";
    [Parameter] public string IconTone { get; set; } = "primary";

    private string GetToneClass()
    {
        return IconTone switch
        {
            "secondary" => "is-secondary",
            "purple" => "is-purple",
            _ => "is-primary"
        };
    }
}