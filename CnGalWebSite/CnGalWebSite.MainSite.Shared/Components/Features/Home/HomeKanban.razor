        },
        new()
        {
            Content = "“说起来建立这个网站的初衷并不为别的，只是希望能够对国产galgame的推广，宣传乃至发展能有所帮助。”",
            Source = "写在诞生日",
            SourceLink = "/articles/index/6"
        }
    };

    private QuoteModel _item = _items[new Random().Next(0, _items.Length)];
}
