    {
        new()
        {
            Content = "“每个人都可以参与到编辑中，同时每个人都能享有编辑后的成果。”",
            Source = "CnGal资料站 V3 正式上线后的感谢！",
            SourceLink = "/articles/index/257"
        },
        new()
        {
            Content = "“愿每一个CnGal创作者的作品都能不被忘记”",
            Source = "CnGal资料站 V3 正式上线后的感谢！",
            SourceLink = "/articles/index/257"
        },
        new()
        {
            Content = "“总要做点自己想做的事，为了自己也好，为了别人也好，两全其美更好。”",
            Source = "写在诞生日",
