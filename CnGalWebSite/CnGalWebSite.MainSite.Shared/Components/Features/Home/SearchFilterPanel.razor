<div class="search-filter-panel">
    @* ── Type filters ── *@
    <div class="search-filter-panel__section">
        <h3 class="search-filter-panel__section-title">
            <CgMdiIcon Name="mdiFilterVariant" aria-hidden="true" />
            类型
        </h3>

        <div class="search-filter-panel__group">
            <span class="search-filter-panel__group-label">词条</span>
            <div class="search-filter-panel__tags">
                @foreach (var type in EntryTypes)
                {
                    <a href="@GetTypeToggleUrl(type.Key)"
                       class="search-filter-panel__tag @(SelectedTypes.Contains(type.Key) ? "search-filter-panel__tag--active" : "")">
                        @type.Value
                    </a>
                }
            </div>
        </div>

        <div class="search-filter-panel__group">
            <span class="search-filter-panel__group-label">文章</span>
            <div class="search-filter-panel__tags">
                @foreach (var type in ArticleTypes)
                {
                    <a href="@GetTypeToggleUrl(type.Key)"
                       class="search-filter-panel__tag @(SelectedTypes.Contains(type.Key) ? "search-filter-panel__tag--active" : "")">
                        @type.Value
                    </a>
                }
            </div>
        </div>

        <div class="search-filter-panel__group">
            <span class="search-filter-panel__group-label">其他</span>
            <div class="search-filter-panel__tags">
                @foreach (var type in OtherTypes)
                {
                    <a href="@GetTypeToggleUrl(type.Key)"
                       class="search-filter-panel__tag @(SelectedTypes.Contains(type.Key) ? "search-filter-panel__tag--active" : "")">
                        @type.Value
                    </a>
                }
            </div>
        </div>
    </div>

    @* ── Time filters ── *@
    <div class="search-filter-panel__section">
        <h3 class="search-filter-panel__section-title">
            <CgMdiIcon Name="mdiCalendarRange" aria-hidden="true" />
            时间
        </h3>
        <div class="search-filter-panel__tags">
            @foreach (var time in AvailableTimes)
            {
                <a href="@GetTimeToggleUrl(time.Key)"
                   class="search-filter-panel__tag @(SelectedTimes.Contains(time.Key) ? "search-filter-panel__tag--active" : "")">
                    @time.Value
                </a>
            }
        </div>
    </div>

    @* ── Sort ── *@
    <div class="search-filter-panel__section search-filter-panel__section--inline">
        <h3 class="search-filter-panel__section-title">
            <CgMdiIcon Name="mdiSortVariant" aria-hidden="true" />
            排序
        </h3>
        <div class="search-filter-panel__tags">
            @foreach (var sort in SortOptions)
            {
                <a href="@GetSortUrl(sort.Key)"
                   class="search-filter-panel__tag @(CurrentSortField == sort.Key ? "search-filter-panel__tag--active" : "")">
                    @sort.Value
                </a>
            }
            @if (!string.IsNullOrEmpty(CurrentSortField))
            {
                <a href="@GetSortOrderToggleUrl()"
                   class="search-filter-panel__tag search-filter-panel__tag--active search-filter-panel__tag--order">
                    <CgMdiIcon Name="@(IsAscending ? "mdiSortAscending" : "mdiSortDescending")" aria-hidden="true" />
                    @(IsAscending ? "顺序" : "逆序")
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public List<string> SelectedTypes { get; set; } = [];
    [Parameter] public List<string> SelectedTimes { get; set; } = [];
    [Parameter] public string CurrentSort { get; set; } = "";

    private static readonly KeyValuePair<string, string>[] EntryTypes =
    [
        new("Entry", "词条"), new("Game", "游戏"), new("Role", "角色"),
        new("ProductionGroup", "组织"), new("Staff", "Staff"),
    ];

    private static readonly KeyValuePair<string, string>[] ArticleTypes =
    [
        new("Article", "文章"), new("Tought", "感想"), new("Strategy", "攻略"),
        new("Interview", "访谈"), new("News", "动态"), new("Evaluation", "评测"),
        new("PeripheralArticle", "周边文章"), new("Notice", "公告"),
        new("OtherArticle", "杂谈"), new("Fan", "二创"),
    ];

    private static readonly KeyValuePair<string, string>[] OtherTypes =
    [
        new("Tag", "标签"), new("Video", "视频"),
        new("Periphery", "周边"), new("SetorAlbumEtc", "设定集"), new("Ost", "原声集"),
        new("Set", "套装"), new("OtherPeriphery", "其他周边"),
    ];

    private static readonly KeyValuePair<string, string>[] AvailableTimes = BuildAvailableTimes();

    private static KeyValuePair<string, string>[] BuildAvailableTimes()
    {
        var range = 5;
        var result = new KeyValuePair<string, string>[range + 1];
        var year = DateTime.Now.Year - range;
        for (var i = 0; i <= range; i++, year++)
        {
            var after = new DateTimeOffset(new DateTime(year, 1, 1)).ToUnixTimeMilliseconds();
            var before = new DateTimeOffset(new DateTime(year + 1, 1, 1)).ToUnixTimeMilliseconds();
            result[i] = new($"{after}-{before}", year.ToString());
        }
        return result;
    }

    private static readonly KeyValuePair<string, string>[] SortOptions =
    [
        new("", "默认排序"),
        new("LastEditTime", "最后编辑时间"),
        new("PubulishTime", "发布时间"),
        new("CreateTime", "创建时间"),
        new("ReaderCount", "热度"),
    ];

    private string CurrentSortField => CurrentSort.Replace(" desc", "");
    private bool IsAscending => !string.IsNullOrEmpty(CurrentSortField) && !CurrentSort.Contains(" desc");

    private string GetTypeToggleUrl(string type)
    {
        var types = new List<string>(SelectedTypes);
        if (!types.Remove(type)) types.Add(type);
        return BuildUrl(types: types);
    }

    private string GetTimeToggleUrl(string time)
    {
        var times = new List<string>(SelectedTimes);
        if (!times.Remove(time)) times.Add(time);
        return BuildUrl(times: times);
    }

    private string GetSortUrl(string field)
    {
        var sort = string.IsNullOrEmpty(field) ? "" : field + " desc";
        return BuildUrl(sort: sort);
    }

    private string GetSortOrderToggleUrl()
    {
        var sort = IsAscending ? CurrentSortField + " desc" : CurrentSortField;
        return BuildUrl(sort: sort);
    }

    private string BuildUrl(List<string>? types = null, List<string>? times = null, string? sort = null)
    {
        var tTypes = types ?? SelectedTypes;
        var tTimes = times ?? SelectedTimes;
        var tSort = sort ?? CurrentSort;

        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(SearchText))
            parts.Add("Text=" + Uri.EscapeDataString(SearchText));
        if (!string.IsNullOrWhiteSpace(tSort))
            parts.Add("Sort=" + Uri.EscapeDataString(tSort));
        foreach (var tt in tTypes)
            parts.Add("Types=" + Uri.EscapeDataString(tt));
        foreach (var tt in tTimes)
            parts.Add("Times=" + Uri.EscapeDataString(tt));
        var qs = parts.Count == 0 ? "" : "?" + string.Join("&", parts);
        return "/search" + qs;
    }
}
