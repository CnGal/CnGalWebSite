@using CnGalWebSite.DataModel.ViewModel.Home

<section class="home-hero-section">
    <div class="home-hero-carousel">
        @if (Carousels != null && Carousels.Any())
        {
            var first = Carousels.First();
            <a class="home-hero-carousel-link" href="@first.Link" aria-label="查看轮播详情">
                <img class="home-hero-carousel-image"
                     src="@first.Image"
                     alt="@first.Note"
                     loading="eager"
                     fetchpriority="high"
                     decoding="async"
                     width="2048"
                     height="400" />
            </a>
        }
    </div>
</section>

@code {
    [Parameter]
    public IEnumerable<CarouselViewModel> Carousels { get; set; } = [];
}
