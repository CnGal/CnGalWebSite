@using CnGalWebSite.DataModel.ViewModel.Home
@using static CnGalWebSite.MainSite.Shared.Components.DesignSystem.CgCarousel

<section class="home-hero-section">
    <CgCarousel Items="@MapToCarouselItems()" />
</section>

@code {
    [Parameter]
    public IEnumerable<CarouselViewModel> Carousels { get; set; } = [];

    private IReadOnlyList<CgCarouselItem> MapToCarouselItems()
    {
        return (Carousels ?? [])
            .Select(c => new CgCarouselItem(c.Image, c.Link, c.Note))
            .ToList();
    }
}
