<li class="home-game-card @(Horizontal ? "home-game-card--horizontal" : string.Empty)">
    <a href="@Url" class="home-game-card-link">
        <figure class="home-game-card-image-wrapper">
            <img class="home-game-card-image" src="@Image" alt="@Name" loading="lazy" decoding="async" />
        </figure>

        <div class="home-game-card-body">
            <h3 class="home-game-card-title">@Name</h3>
            @if (!string.IsNullOrWhiteSpace(BriefIntroduction))
            {
                <p class="home-game-card-desc">@BriefIntroduction</p>
            }
            @if (Tags is not null && Tags.Any())
            {
                <div class="home-game-card-tags">
                    @foreach (var tag in Tags.Take(2))
                    {
                        <span class="home-game-card-tag">
                            <CgMdiIcon Name="mdiTag" aria-hidden="true" />
                            @tag
                        </span>
                    }
                </div>
            }
            @if (ChildContent is not null)
            {
                <div class="home-game-card-extra">
                    @ChildContent
                </div>
            }
        </div>
    </a>
</li>

@code {
    [Parameter] public string Url { get; set; } = "";
    [Parameter] public string Image { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string? BriefIntroduction { get; set; }
    [Parameter] public IEnumerable<string>? Tags { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Horizontal { get; set; }
}
