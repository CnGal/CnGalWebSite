@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Commodities
@using CnGalWebSite.DataModel.ViewModel.Others
@using Microsoft.Extensions.Logging
@inject ICgDeviceIdentificationService DeviceIdentification
@inject ILogger<CommodityCodeRedeem> Logger

@* CommodityCodeRedeem — G币兑换码输入组件（含人机验证 + 设备指纹） *@

<div class="commodity-code-redeem">
    <CgAlert Variant="info">
        <span>前往 <strong>B站工房</strong> 购买周边，我们会按消费金额（不包括邮费）<strong>5：1</strong> 赠送G币哦。在下面输入B站工房 <strong>订单号</strong> 即可兑换。</span>
    </CgAlert>

    <div class="commodity-code-redeem__form">
        <div class="commodity-code-redeem__input-group">
            <CgInput @bind-Value="@_orderCode"
                     Placeholder="请输入B站工房订单号"
                     Disabled="@_isProcessing" />
            <CgButton Variant="primary"
                      Async="true"
                      Disabled="@(string.IsNullOrWhiteSpace(_orderCode))"
                      OnClick="HandleRedeemAsync">
                <CgMdiIcon Name="mdiTicketConfirmationOutline" aria-hidden="true" />
                兑换
            </CgButton>
        </div>
    </div>

    <CgHumanMachineVerification @ref="_verification"
                                 OnVerficated="OnVerficatedAsync"
                                 WaitChecked="true" />

    <div class="commodity-code-redeem__promo">
        <div class="commodity-code-redeem__promo-header">
            <CgMdiIcon Name="mdiShoppingOutline" aria-hidden="true" />
            <span>前往B站工房购买周边</span>
        </div>
        <a href="https://gf.bilibili.com/item/detail/1110069065"
           target="_blank"
           rel="noopener"
           class="commodity-code-redeem__promo-link">
            <img src="https://tucang.cngal.top/api/image/show/e144487a1a224a3bb54dfc7eb55483ab?https://image.cngal.org/images/upload/20240818/793eac7917a9fe37ea4934760ea39bb387fce0c2.jpeg"
                 alt="B站工房周边"
                 class="commodity-code-redeem__promo-image"
                 loading="lazy" />
        </a>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<RedeemedCommodityCodeModel> OnRedeem { get; set; }

    private string _orderCode = string.Empty;
    private bool _isProcessing;
    private CgHumanMachineVerification? _verification;

    private async Task HandleRedeemAsync()
    {
        if (!OnRedeem.HasDelegate || string.IsNullOrWhiteSpace(_orderCode))
        {
            return;
        }

        if (_verification is null)
        {
            Logger.LogError("CgHumanMachineVerification 组件引用为空");
            return;
        }

        _isProcessing = true;
        StateHasChanged();

        try
        {
            await _verification.StartVerification();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "极验人机验证异常");
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }

    private async Task OnVerficatedAsync(HumanMachineVerificationResult result)
    {
        if (!result.Success)
        {
            return;
        }

        try
        {
            var device = await DeviceIdentification.GetIdentificationAsync();
            await OnRedeem.InvokeAsync(new RedeemedCommodityCodeModel
            {
                Code = _orderCode,
                Verification = result,
                Identification = device
            });
            _orderCode = string.Empty;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "组装或提交兑换模型异常");
        }
    }
}
