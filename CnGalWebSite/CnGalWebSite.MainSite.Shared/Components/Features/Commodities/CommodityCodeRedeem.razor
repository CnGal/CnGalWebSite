@* CommodityCodeRedeem — G币兑换码输入组件 *@

<div class="commodity-code-redeem">
    @* B站工房说明提示 *@
    <CgAlert Variant="info">
        <span>前往 <strong>B站工房</strong> 购买周边，我们会按消费金额（不包括邮费）<strong>5：1</strong> 赠送G币哦。在下面输入B站工房 <strong>订单号</strong> 即可兑换。</span>
    </CgAlert>

    @* 兑换表单 *@
    <div class="commodity-code-redeem__form">
        <div class="commodity-code-redeem__input-group">
            <input type="text"
                   class="commodity-code-redeem__input"
                   placeholder="请输入B站工房订单号"
                   @bind="_orderCode"
                   @bind:event="oninput"
                   disabled="@IsProcessing" />
            <CgButton Variant="primary"
                      Async="true"
                      Disabled="@(IsProcessing || string.IsNullOrWhiteSpace(_orderCode))"
                      OnClick="HandleRedeemAsync">
                <CgMdiIcon Name="mdiTicketConfirmationOutline" aria-hidden="true" />
                兑换
            </CgButton>
        </div>

        @* 消息提示 *@
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="commodity-code-redeem__message @(IsSuccess ? "commodity-code-redeem__message--success" : "commodity-code-redeem__message--error")">
                <CgMdiIcon Name="@(IsSuccess ? "mdiCheckCircleOutline" : "mdiAlertCircleOutline")" aria-hidden="true" />
                <span>@Message</span>
            </div>
        }
    </div>

    @* B站工房推广 *@
    <div class="commodity-code-redeem__promo">
        <div class="commodity-code-redeem__promo-header">
            <CgMdiIcon Name="mdiShoppingOutline" aria-hidden="true" />
            <span>前往B站工房购买周边</span>
        </div>
        <a href="https://gf.bilibili.com/item/detail/1110069065"
           target="_blank"
           rel="noopener"
           class="commodity-code-redeem__promo-link">
            <img src="https://tucang.cngal.top/api/image/show/e144487a1a224a3bb54dfc7eb55483ab?https://image.cngal.org/images/upload/20240818/793eac7917a9fe37ea4934760ea39bb387fce0c2.jpeg"
                 alt="B站工房周边"
                 class="commodity-code-redeem__promo-image"
                 loading="lazy" />
        </a>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<string> OnRedeem { get; set; }

    [Parameter]
    public bool IsProcessing { get; set; }

    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public bool IsSuccess { get; set; }

    private string _orderCode = string.Empty;

    private async Task HandleRedeemAsync(MouseEventArgs args)
    {
        if (OnRedeem.HasDelegate && !string.IsNullOrWhiteSpace(_orderCode))
        {
            await OnRedeem.InvokeAsync(_orderCode);
        }
    }
}
