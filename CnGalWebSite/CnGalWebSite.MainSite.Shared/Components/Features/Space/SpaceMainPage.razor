@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem

@if (!string.IsNullOrWhiteSpace(Model.MainPageHtml))
{
    <div class="cg-space-card">
        <div class="cg-space-card-header">
            <CgMdiIcon Name="mdiHomeOutline" Class="cg-space-card-icon" />
            <h2 class="cg-space-card-title">个人介绍</h2>
        </div>
        <div class="cg-space-card-body">
            <div class="cg-markdown-body">
                @((MarkupString)Model.MainPageHtml)
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public required SpaceDetailViewModel Model { get; set; }
}