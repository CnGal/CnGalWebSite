@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry

<div class="cg-space-card">
    <div class="cg-space-card-body">
        <div class="cg-space-info-item">
            <CgMdiIcon Name="mdiStarOutline" Class="cg-space-info-icon" />
            <span>贡献值：@Model.ContributionValue</span>
        </div>
        
        @if (Model.Birthday != null)
        {
            <div class="cg-space-info-item">
                <CgMdiIcon Name="mdiCakeVariantOutline" Class="cg-space-info-icon" />
                <span>生日：@Model.Birthday.Value.ToString("M月d日")</span>
            </div>
        }
        
        <div class="cg-space-info-item">
            <CgMdiIcon Name="mdiClockOutline" Class="cg-space-info-icon" />
            <span>在线时间：@Model.OnlineTime.ToString("0.0")小时</span>
        </div>
        
        <div class="cg-space-info-item">
            <CgMdiIcon Name="mdiCalendarAccountOutline" Class="cg-space-info-icon" />
            <span>注册时间：@Model.RegisteTime.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
        
        <div class="cg-space-info-item">
            <CgMdiIcon Name="mdiHistory" Class="cg-space-info-icon" />
            <span>最后访问：@Model.LastOnlineTime.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
        
        <div class="cg-space-info-item">
            <CgMdiIcon Name="mdiIdentifier" Class="cg-space-info-icon" />
            <span>UID：@Model.Id</span>
        </div>
    </div>
    
    @if (Model.UserCertification != null)
    {
        <div class="cg-space-card-divider"></div>
        <div class="cg-space-card-header">
            <CgMdiIcon Name="mdiCertificateOutline" Class="cg-space-card-icon" />
            <h2 class="cg-space-card-title">用户认证</h2>
        </div>
        <div class="cg-space-card-body">
            <EntryCardItem Url="@($"/entries/index/{Model.UserCertification.Id}")" 
                           Image="@Model.UserCertification.MainImage" 
                           Title="@Model.UserCertification.Name" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required SpaceDetailViewModel Model { get; set; }
}
