@* 游玩记录列表 + Steam 信息 *@

<SpaceSteamInfoCard SteamUsers="SteamUsers" GameRecords="Model" />

@if (IsCurrentUser)
{
    <SpaceSteamToolbar SteamId="@SteamId" UserId="@UserId" OnDataChanged="OnDataChanged" />
}

@if (VisibleRecords.Count > 0)
{
    <ul class="space-game-record-list__grid">
        @foreach (var record in VisibleRecords)
        {
            <li>
                <SpaceGameRecordItem Model="record" OnClick="() => OnCardClick(record)" />
            </li>
        }
    </ul>
}
else
{
    <div class="space-game-record-list__empty">
        <CgMdiIcon Name="mdiGamepadVariantOutline" />
        <p>暂无游玩记录</p>
    </div>
}

@* 查看弹窗（点击卡片后打开） *@
<SpaceGameRecordViewModal @ref="_viewModal"
                           IsCurrentUser="IsCurrentUser"
                           UserId="@UserId"
                           OnEditRequest="OnEditFromView"
                           OnDataChanged="OnDataChanged" />

@* 编辑弹窗（从查看弹窗的"编辑"按钮打开） *@
@if (IsCurrentUser)
{
    <SpaceGameRecordEditModal @ref="_editModal" UserId="@UserId" OnSaved="OnRecordSaved" />
}

@code {
    [Parameter]
    public required UserGameRecordsViewModel Model { get; set; }

    [Parameter]
    public bool IsCurrentUser { get; set; }

    [Parameter]
    public IReadOnlyList<SteamUserInfoItem> SteamUsers { get; set; } = [];

    [Parameter]
    public string SteamId { get; set; } = string.Empty;

    [Parameter]
    public string UserId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnDataChanged { get; set; }

    private SpaceGameRecordViewModal? _viewModal;
    private SpaceGameRecordEditModal? _editModal;
    private GameRecordItem? _currentRecord;

    private IReadOnlyList<GameRecordItem> VisibleRecords => Model.Records
        .Where(r => !r.IsHidden || IsCurrentUser)
        .ToList();

    /// <summary>
    /// 第1步：点击卡片 → 打开查看弹窗
    /// </summary>
    private void OnCardClick(GameRecordItem record)
    {
        _currentRecord = record;
        _viewModal?.Open(record);
    }

    /// <summary>
    /// 第2步：查看弹窗中点击"编辑" → 打开编辑弹窗
    /// </summary>
    private async Task OnEditFromView()
    {
        if (_currentRecord is not null && _editModal is not null)
        {
            await _editModal.OpenAsync(_currentRecord.GameId, _currentRecord.IsDubbing);
        }
    }

    private async Task OnRecordSaved()
    {
        await OnDataChanged.InvokeAsync();
    }
}
