@using CnGalWebSite.SDK.MainSite.Models

<div class="cg-space-hero">
    <div class="cg-space-hero-bg">
        <picture>
            @if (!string.IsNullOrWhiteSpace(Model.MBgImage))
            {
                <source media="(max-width: 768px)" srcset="@Model.MBgImage" />
            }
            <img src="@Model.BackgroundImage" alt="Background" />
        </picture>
    </div>
    
    <div class="cg-space-hero-content">
        <div class="cg-space-hero-avatar">
            <img src="@Model.PhotoPath" alt="@Model.Name" />
        </div>
        <div class="cg-space-hero-info">
            <h1 class="cg-space-hero-name">@Model.Name</h1>
            @if (Model.Ranks?.Any() == true)
            {
                <CgRankList Model="Model.Ranks" Center="true" />
            }
            @if (!string.IsNullOrWhiteSpace(Model.PersonalSignature))
            {
                <div class="cg-space-hero-signature">@Model.PersonalSignature</div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required SpaceDetailViewModel Model { get; set; }
}