@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem

<div class="cg-space-card">
    <div class="cg-space-card-body">
        <div class="cg-space-data-stats">
            <div class="cg-space-data-stat-item">
                <div class="cg-space-data-stat-value">@Model.EditCount</div>
                <div class="cg-space-data-stat-label">累计编辑</div>
            </div>
            <div class="cg-space-data-stat-item">
                <div class="cg-space-data-stat-value">@Model.ArticleCount</div>
                <div class="cg-space-data-stat-label">发表文章</div>
            </div>
        </div>
        
        <div class="cg-space-data-level-container">
            <div class="cg-space-data-level-header">
                <span>
                    <CgMdiIcon Name="mdiMagicStaff" Class="cg-space-data-level-icon" />
                    Lv：@(GetUserLevel(Model.Integral))
                </span>
                <span class="cg-space-data-level-text">
                    @(GetUserLevel(Model.Integral) == 10 ? Model.Integral.ToString() : $"{Model.Integral} / {GetLevelIntegral(GetUserLevel(Model.Integral))}")
                </span>
            </div>
            <div class="cg-space-progress-bar">
                <div class="cg-space-progress-bar-fill" style="width: @(GetLevelProgress(Model.Integral))%"></div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required SpaceDetailViewModel Model { get; set; }

    private int GetUserLevel(int integral)
    {
        int[] levelThresholds = { 0, 100, 300, 600, 1000, 1500, 2100, 2800, 3600, 4500 };
        for (int i = levelThresholds.Length - 1; i >= 0; i--)
        {
            if (integral >= levelThresholds[i]) return i + 1;
        }
        return 1;
    }

    private int GetLevelIntegral(int level)
    {
        int[] levelThresholds = { 0, 100, 300, 600, 1000, 1500, 2100, 2800, 3600, 4500 };
        if (level >= 10) return levelThresholds[9];
        return levelThresholds[level];
    }
    
    private double GetLevelProgress(int integral)
    {
        int level = GetUserLevel(integral);
        if (level >= 10) return 100.0;
        int max = GetLevelIntegral(level);
        return max == 0 ? 0 : Math.Clamp(100.0 * integral / max, 0, 100);
    }
}