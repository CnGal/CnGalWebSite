@rendermode InteractiveServer

@inject ISpaceCommandService SpaceCommandService
@inject ICgToastService ToastService
@inject NavigationManager NavigationManager

<div class="space-steam-toolbar">
    @if (string.IsNullOrWhiteSpace(SteamId))
    {
        <div class="space-steam-toolbar__wrapper space-steam-toolbar__wrapper--primary">
            <CgButton Variant="primary" OnClick="OpenEditModal">
                <CgMdiIcon Name="mdiSteam" aria-hidden="true" />
                <span>绑定 Steam 账号</span>
            </CgButton>
        </div>
    }
    else
    {
        <div class="space-steam-toolbar__wrapper space-steam-toolbar__wrapper--pill">
            <CgButton Variant="secondary"
                      Disabled="_isRefreshing"
                      OnClick="HandleRefreshAsync">
                @if (_isRefreshing)
                {
                    <CgProgressRing />
                }
                else
                {
                    <CgMdiIcon Name="mdiRefresh" aria-hidden="true" />
                }
                <span>刷新 Steam 数据</span>
            </CgButton>

            <div class="space-steam-toolbar__divider"></div>

            <CgButton Variant="secondary" OnClick="OpenEditModal">
                <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                <span>管理 Steam 账号</span>
            </CgButton>
        </div>
    }
</div>

<SpaceSteamEditModal @bind-Visible="_showEditModal" OnSaved="HandleSaved" />

@code {
    [Parameter]
    public string SteamId { get; set; } = string.Empty;

    [Parameter]
    public string UserId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnDataChanged { get; set; }

    private bool _isRefreshing;
    private bool _showEditModal;

    private async Task HandleRefreshAsync()
    {
        _isRefreshing = true;
        StateHasChanged();

        try
        {
            var result = await SpaceCommandService.RefreshSteamInfoAsync(UserId);
            if (result.Success)
            {
                ToastService.Show("Steam 数据刷新成功", variant: "success");
                // 通知父组件交互式刷新数据
                await OnDataChanged.InvokeAsync();
            }
            else
            {
                ToastService.Show("刷新失败", result.Error?.Message ?? "刷新 Steam 信息失败", "error");
            }
        }
        catch
        {
            ToastService.Show("刷新 Steam 信息时发生异常", variant: "error");
        }
        finally
        {
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private void OpenEditModal()
    {
        _showEditModal = true;
    }

    private async Task HandleSaved()
    {
        await OnDataChanged.InvokeAsync();
    }
}
