@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem

@if (IsCurrentUser)
{
    <div class="favorite-toolbar">
        <a href="/favoritefolders/create" class="favorite-create-btn">
            <CgMdiIcon Name="mdiPlusCircleOutline" aria-hidden="true" />
            <span>创建收藏夹</span>
        </a>
    </div>
}

@if (Folders.Count == 0)
{
    <div class="favorite-empty">
        <CgMdiIcon Name="mdiHeartOutline" Class="favorite-empty-icon" aria-hidden="true" />
        <span>暂无收藏夹</span>
    </div>
}
else
{
    <ul class="favorite-grid">
        @foreach (var folder in Folders)
        {
            <li>
                <a href="/favoritefolders/index/@folder.Id" class="favorite-card">
                    <div class="favorite-card-cover">
                        @if (!string.IsNullOrWhiteSpace(folder.MainImage))
                        {
                            <img src="@folder.MainImage" alt="@folder.Name" loading="lazy" decoding="async" />
                        }
                        else
                        {
                            <div class="favorite-card-placeholder">
                                <CgMdiIcon Name="mdiHeartMultiple" aria-hidden="true" />
                            </div>
                        }
                        <span class="favorite-card-count">@folder.Count 项</span>
                    </div>
                    <div class="favorite-card-body">
                        <h3 class="favorite-card-name">@folder.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(folder.BriefIntroduction))
                        {
                            <p class="favorite-card-desc">@folder.BriefIntroduction</p>
                        }
                        <div class="favorite-card-meta">
                            @if (folder.IsDefault)
                            {
                                <span class="favorite-badge">默认</span>
                            }
                            @if (!folder.ShowPublicly)
                            {
                                <span class="favorite-badge favorite-badge--private">
                                    <CgMdiIcon Name="mdiLockOutline" aria-hidden="true" /> 私密
                                </span>
                            }
                            @if (folder.IsHidden)
                            {
                                <span class="favorite-badge favorite-badge--hidden">
                                    <CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /> 已隐藏
                                </span>
                            }
                        </div>
                    </div>
                </a>
            </li>
        }
    </ul>
}

@code {
    [Parameter, EditorRequired]
    public required IReadOnlyList<FavoriteFolderSummaryItem> Folders { get; set; }

    [Parameter]
    public bool IsCurrentUser { get; set; }
}
