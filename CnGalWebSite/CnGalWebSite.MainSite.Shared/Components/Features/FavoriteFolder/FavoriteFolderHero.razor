@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem

<div class="cg-ff-hero">
    <div class="cg-ff-hero-image-wrapper">
        @if (!string.IsNullOrWhiteSpace(Model.MainPicture))
        {
            <img src="@Model.MainPicture" alt="@Model.Name" class="cg-ff-hero-image" />
        }
        else
        {
            <div class="cg-ff-hero-placeholder">
                <CgMdiIcon Name="mdiHeartMultiple" aria-hidden="true" />
            </div>
        }
    </div>
    <div class="cg-ff-hero-content">
        <h1 class="cg-ff-hero-name">@Model.Name</h1>
        @if (!string.IsNullOrWhiteSpace(Model.BriefIntroduction))
        {
            <p class="cg-ff-hero-desc">@Model.BriefIntroduction</p>
        }
        <div class="cg-ff-hero-actions">
            @if (Model.Authority)
            {
                <a class="cg-ff-hero-edit-btn" href="/favoritefolders/edit/@Model.Id">
                    <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                    <span>编辑</span>
                </a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required FavoriteFolderDetailViewModel Model { get; set; }
}
