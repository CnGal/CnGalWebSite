@implements IDisposable
@inject IToolboxEntryMergeService EntryMergeService
@inject IEntryCommandService EntryCommandService

<CgModal IsOpen="IsOpen" Title="合并词条" Width="760px" OnClose="CloseAsync">
    <ChildContent>
        <div class="toolbox-dialog">
            @if (_step == 1)
            {
                <CgAlert Variant="warning">合并时会自动迁移关联信息，并提交多条审核记录。当前不支持合并游戏词条。</CgAlert>
                <p class="toolbox-dialog__hint">
                    被合并的词条
                    <span class="toolbox-dialog__hint-arrow" aria-hidden="true">→</span>
                    合并到的词条
                </p>
                <div class="toolbox-dialog__form">
                    <div class="toolbox-dialog__two-col">
                        <CgFormGroup Label="被合并的词条" Required>
                            <CgAutoComplete @bind-Value="_subName"
                                            Items="_entryItems"
                                            Placeholder="将被隐藏并迁移数据的词条"
                                            Disabled="_isLoadingEntryItems" />
                        </CgFormGroup>
                        <CgFormGroup Label="合并到的词条" Required>
                            <CgAutoComplete @bind-Value="_hostName"
                                            Items="_entryItems"
                                            Placeholder="保留的主词条名称"
                                            Disabled="_isLoadingEntryItems" />
                        </CgFormGroup>
                    </div>
                </div>
            }
            else if (_step == 2)
            {
                <CgAlert Variant="info">正在合并词条，请不要关闭弹窗。</CgAlert>
                <ToolboxProgressPanel CurrentTask="_currentTask" CurrentIndex="0" TotalCount="1" CurrentMessage="@_message" />
            }
            else
            {
                <CgAlert Variant="@(_currentTask?.Failed == true ? "warning" : "success")">词条合并流程已结束。</CgAlert>
                @if (_currentTask is not null)
                {
                    <div class="toolbox-dialog__results">
                        <div class="toolbox-dialog__result toolbox-dialog__result--@(_currentTask.Succeeded ? "success" : "error")">
                            <CgMdiIcon Name="@(_currentTask.Succeeded ? "mdiCheckCircleOutline" : "mdiAlertCircleOutline")" class="toolbox-dialog__result-icon" aria-hidden="true" />
                            <div class="toolbox-dialog__result-content">
                                <strong>
                                    <span>@_currentTask.SubName</span>
                                    <CgMdiIcon Name="mdiArrowRight" aria-hidden="true" />
                                    <span>@_currentTask.HostName</span>
                                </strong>
                                @if (_currentTask.Succeeded)
                                {
                                    <span>已成功提交审核。</span>
                                }
                                else
                                {
                                    <span class="toolbox-dialog__error">@_currentTask.Error</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </ChildContent>
    <Footer>
        <div class="toolbox-dialog__footer">
            @if (_step == 1)
            {
                <CgButton Variant="secondary" OnClick="CloseAsync">取消</CgButton>
                <CgButton OnClick="StartAsync" Async>开始合并</CgButton>
            }
            else if (_step == 2)
            {
                <CgButton Variant="secondary" Disabled>处理中</CgButton>
            }
            else
            {
                <CgButton Variant="secondary" OnClick="Retry">重新输入</CgButton>
                <CgButton OnClick="CloseAsync">关闭</CgButton>
            }
        </div>
    </Footer>
</CgModal>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private int _step = 1;
    private string? _hostName;
    private string? _subName;
    private MergeEntryTaskModel? _currentTask;
    private string _message = "准备中";
    private List<string> _entryItems = [];
    private bool _isLoadingEntryItems;

    protected override async Task OnInitializedAsync()
    {
        EntryMergeService.ProgressUpdate += OnProgressUpdate;
        await LoadEntryItemsAsync();
    }

    private async Task LoadEntryItemsAsync()
    {
        _isLoadingEntryItems = true;
        try
        {
            var result = await EntryCommandService.GetEntryEditMetaOptionsAsync();
            if (result.Success && result.Data is not null)
            {
                _entryItems = result.Data.EntryRoleItems
                    .Concat(result.Data.EntryGroupItems)
                    .Concat(result.Data.EntryStaffItems)
                    .Distinct(StringComparer.Ordinal)
                    .OrderBy(s => s, StringComparer.Ordinal)
                    .ToList();
            }
        }
        finally
        {
            _isLoadingEntryItems = false;
        }
    }

    private async Task StartAsync()
    {
        if (string.IsNullOrWhiteSpace(_hostName) || string.IsNullOrWhiteSpace(_subName))
        {
            _message = "请填写「被合并的词条」与「合并到的词条」";
            return;
        }

        _currentTask = new MergeEntryTaskModel
        {
            HostName = _hostName.Trim(),
            SubName = _subName.Trim()
        };

        _step = 2;
        await EntryMergeService.ProcessMergeEntryAsync(_currentTask);
        _step = 3;
    }

    private void Retry()
    {
        _step = 1;
        _message = "准备中";
    }

    private Task CloseAsync()
    {
        return OnClose.InvokeAsync();
    }

    private void OnProgressUpdate(ToolboxProgressUpdate update)
    {
        _ = InvokeAsync(() =>
        {
            _message = update.Message;
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        EntryMergeService.ProgressUpdate -= OnProgressUpdate;
    }
}
