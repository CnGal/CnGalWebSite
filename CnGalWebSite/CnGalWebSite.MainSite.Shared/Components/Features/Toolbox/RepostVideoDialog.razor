@implements IDisposable
@inject IToolboxVideoRepostService VideoService

<CgModal IsOpen="IsOpen" Title="转载其他平台视频" Width="760px" OnClose="CloseAsync">
    <ChildContent>
        <div class="toolbox-dialog">
            @if (_step == 1)
            {
                <CgAlert Variant="info">目前只支持 B 站视频。</CgAlert>
                <p class="toolbox-dialog__hint">
                    每行一条视频链接。示例：<br />
                    <span class="toolbox-dialog__sample">https://www.bilibili.com/video/BV1tF411N7XD</span>
                </p>
                <div class="toolbox-dialog__form">
                    <div class="toolbox-dialog__row-split">
                        <CgFormGroup Label="类型">
                            <CgInput TValue="string" @bind-Value="_type" Placeholder="留空则使用 B 站分区" />
                        </CgFormGroup>
                        <CgFormGroup Label="标题（可不填，将自动获取）">
                            <CgInput TValue="string" @bind-Value="_title" Placeholder="仅单个链接时建议填写；多行时留空" />
                        </CgFormGroup>
                    </div>
                    <CgFormGroup Label="链接" Required>
                        <CgTextarea @bind-Value="_urls" Rows="5" Placeholder="每行一条，支持多行粘贴" />
                    </CgFormGroup>
                    <CgCheckbox @bind-Value="_isCreatedByCurrentUser" Label="本人创作" />
                </div>
            }
            else if (_step == 2)
            {
                <CgAlert Variant="info">正在处理视频，请不要关闭弹窗。</CgAlert>
                <ToolboxProgressPanel CurrentTask="_currentTask" CurrentIndex="_currentIndex" TotalCount="_tasks.Count" CurrentMessage="_message" />
            }
            else
            {
                <CgAlert Variant="@(_tasks.Any(s => s.Failed) ? "warning" : "success")">视频处理完成。</CgAlert>
                <div class="toolbox-dialog__results">
                    @foreach (var task in _tasks)
                    {
                        <div class="toolbox-dialog__result toolbox-dialog__result--@(task.Succeeded ? "success" : "error")">
                            <CgMdiIcon Name="@(task.Succeeded ? "mdiCheckCircleOutline" : "mdiAlertCircleOutline")" class="toolbox-dialog__result-icon" aria-hidden="true" />
                            <div class="toolbox-dialog__result-content">
                                <strong>@task.Url</strong>
                                @if (task.Succeeded)
                                {
                                    <span>已成功抓取，待审核 Id：@task.Id</span>
                                }
                                else
                                {
                                    <span class="toolbox-dialog__error">@task.Error</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </ChildContent>
    <Footer>
        <div class="toolbox-dialog__footer">
            @if (_step == 1)
            {
                <CgButton Variant="secondary" OnClick="CloseAsync">取消</CgButton>
                <CgButton OnClick="StartAsync" Async>开始处理</CgButton>
            }
            else if (_step == 2)
            {
                <CgButton Variant="secondary" Disabled>处理中</CgButton>
            }
            else
            {
                <CgButton Variant="secondary" OnClick="Retry">重新输入</CgButton>
                <CgButton OnClick="CloseAsync">关闭</CgButton>
            }
        </div>
    </Footer>
</CgModal>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private int _step = 1;
    private string? _urls;
    private string? _title;
    private string? _type;
    private bool _isCreatedByCurrentUser;
    private List<RepostVideoTaskModel> _tasks = [];
    private RepostVideoTaskModel? _currentTask;
    private int _currentIndex;
    private string _message = "准备中";

    protected override void OnInitialized()
    {
        VideoService.ProgressUpdate += OnProgressUpdate;
    }

    private async Task StartAsync()
    {
        var urls = ParseLines(_urls);
        if (urls.Count == 0)
        {
            _message = "请至少输入一个视频链接";
            return;
        }

        _tasks = urls.Select((url, index) => new RepostVideoTaskModel
        {
            Url = url,
            Title = urls.Count == 1 ? _title?.Trim() ?? string.Empty : string.Empty,
            Type = _type?.Trim() ?? string.Empty,
            IsCreatedByCurrentUser = _isCreatedByCurrentUser
        }).ToList();

        _step = 2;
        for (_currentIndex = 0; _currentIndex < _tasks.Count; _currentIndex++)
        {
            _currentTask = _tasks[_currentIndex];
            await VideoService.ProcessVideoAsync(_currentTask);
        }

        _step = 3;
    }

    private void Retry()
    {
        _step = 1;
        _message = "准备中";
    }

    private Task CloseAsync()
    {
        return OnClose.InvokeAsync();
    }

    private void OnProgressUpdate(ToolboxProgressUpdate update)
    {
        _ = InvokeAsync(() =>
        {
            _message = update.Message;
            StateHasChanged();
        });
    }

    private static List<string> ParseLines(string? text)
    {
        return (text ?? string.Empty)
            .Split(['\r', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => !string.IsNullOrWhiteSpace(s))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    public void Dispose()
    {
        VideoService.ProgressUpdate -= OnProgressUpdate;
    }
}
