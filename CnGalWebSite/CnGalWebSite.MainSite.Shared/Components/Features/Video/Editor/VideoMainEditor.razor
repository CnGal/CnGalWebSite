@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Videos
@using CnGalWebSite.SDK.MainSite.Models.Files
@inject IFileCommandService FileCommandService

<section class="entry-editor-section" id="section-main">
    <h2><CgMdiIcon Name="mdiVideoOutline" Class="entry-section-icon" aria-hidden="true"/>主要信息</h2>
    <p>编辑视频名称、封面、基本信息与版权设置。</p>

    @if (Model != null)
    {
        <CgGrid MinWidth="150px">
            <CgFormGroup Label="主图">
                <CgImageUpload @bind-Value="Model.MainPicture"
                               Text="上传主图"
                               ShowCropper
                               Type="ImageAspectType._16_9"
                               OnUploadImageAsync="FileCommandService.UploadImageAsync"/>
            </CgFormGroup>
            <CgFormGroup Label="背景图">
                <CgImageUpload @bind-Value="Model.BackgroundPicture"
                               Text="上传大背景图"
                               Type="ImageAspectType.None"
                               OnUploadImageAsync="FileCommandService.UploadImageAsync"/>
            </CgFormGroup>
            <CgFormGroup Label="小背景图">
                <CgImageUpload @bind-Value="Model.SmallBackgroundPicture"
                               Text="上传小背景图"
                               Type="ImageAspectType.None"
                               OnUploadImageAsync="FileCommandService.UploadImageAsync"/>
            </CgFormGroup>
        </CgGrid>

        <CgGrid>
            <CgFormGroup Label="名称同步">
                <CgCheckbox Value="@_syncDisplayName"
                            ValueChanged="OnSyncDisplayNameChanged"
                            Label="显示名称与唯一名称保持一致"/>
            </CgFormGroup>
        </CgGrid>

        <CgGrid>
            <CgFormGroup Label="唯一名称">
                <CgInput Value="@Model.Name"
                         ValueChanged="OnNameChanged" TValue="string"/>
            </CgFormGroup>
            <CgFormGroup Label="显示名称">
                <CgInput @bind-Value="Model.DisplayName"
                         Disabled="_syncDisplayName"/>
            </CgFormGroup>
        </CgGrid>

        <CgFormGroup Label="简介">
            <CgTextarea @bind-Value="Model.BriefIntroduction"
                        Rows="3" Placeholder="简短的视频介绍"/>
        </CgFormGroup>

        <CgGrid>
            <CgFormGroup Label="类别">
                <CgInput @bind-Value="Model.Type" Placeholder="如：实况、PV、攻略等"/>
            </CgFormGroup>
            <CgFormGroup Label="时长">
                <CgInput Value="@_duration" TValue="string"
                         ValueChanged="DurationChanged"
                         Placeholder="格式 hh:mm:ss"/>
            </CgFormGroup>
        </CgGrid>

        <CgGrid>
            <CgFormGroup Label="发布时间">
                <CgDateInput Value="@((DateTime?)Model.PubishTime)"
                             ValueChanged="v => Model.PubishTime = v ?? DateTime.Now"
                             Mode="CgDateInputMode.DateTime" />
            </CgFormGroup>
            <CgFormGroup Label="版权">
                <CgEnumSelect TEnum="CopyrightType"
                              @bind-Value="Model.Copyright"/>
            </CgFormGroup>
        </CgGrid>

        <CgGrid>
            <CgFormGroup Label="原作者">
                <CgInput @bind-Value="Model.OriginalAuthor" Placeholder="可选"/>
            </CgFormGroup>
        </CgGrid>

        <CgGrid>
            <CgFormGroup Label="互动视频">
                <CgCheckbox @bind-Value="Model.IsInteractive" Label="标记为互动视频"/>
            </CgFormGroup>
            <CgFormGroup Label="本人创作">
                <CgCheckbox @bind-Value="Model.IsCreatedByCurrentUser" Label="本人创作"/>
            </CgFormGroup>
        </CgGrid>
    }
</section>

@code {
    [Parameter] public EditVideoMainViewModel Model { get; set; } = default!;

    private bool _syncDisplayName;
    private bool _syncInitialized;
    private string _duration = string.Empty;

    protected override void OnParametersSet()
    {
        if (!_syncInitialized)
        {
            _syncDisplayName = string.Equals(Model.Name, Model.DisplayName, StringComparison.Ordinal);
            _duration = Model.Duration.ToString("hh\\:mm\\:ss");
            _syncInitialized = true;
        }
    }

    private Task OnNameChanged(string? value)
    {
        Model.Name = value ?? string.Empty;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }
        return Task.CompletedTask;
    }

    private Task OnSyncDisplayNameChanged(bool value)
    {
        _syncDisplayName = value;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }
        return Task.CompletedTask;
    }

    private void DurationChanged(string? ts)
    {
        _duration = ts ?? string.Empty;
        if (TimeSpan.TryParse(ts, out TimeSpan result))
        {
            Model.Duration = result;
        }
    }
}
