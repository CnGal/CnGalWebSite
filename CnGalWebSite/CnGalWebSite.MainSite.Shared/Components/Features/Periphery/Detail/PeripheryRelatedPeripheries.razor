@using CnGalWebSite.DataModel.ViewModel.Search
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail

@if (Peripheries.Count > 0)
{
    <EntryCard Title="关联周边" Icon="mdiGiftOutline">
        <ul class="periphery-related-list">
            @foreach (var item in Peripheries)
            {
                <li>
                    <a href="@($"/peripheries/index/{item.Id}")" class="periphery-related-item">
                        <div class="periphery-related-image">
                            @if (!string.IsNullOrWhiteSpace(item.MainImage))
                            {
                                <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                            }
                            else
                            {
                                <div class="periphery-related-placeholder">
                                    <CgMdiIcon Name="mdiGiftOutline" />
                                </div>
                            }
                        </div>
                        <div class="periphery-related-info">
                            <span class="periphery-related-name">@item.Name</span>
                            @if (!string.IsNullOrWhiteSpace(item.BriefIntroduction))
                            {
                                <span class="periphery-related-intro">@item.BriefIntroduction</span>
                            }
                        </div>
                    </a>
                </li>
            }
        </ul>
    </EntryCard>
}

@code {
    [Parameter] public IReadOnlyList<PeripheryInforTipViewModel> Peripheries { get; set; } = [];
}
