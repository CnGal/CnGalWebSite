@using CnGalWebSite.DataModel.ViewModel.Peripheries
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail

@if (OverviewModels.Count > 0)
{
    <EntrySection Title="周边概览" Icon="mdiViewGridOutline">
        @foreach (var group in OverviewModels)
        {
            <div class="periphery-overview-group">
                <a class="periphery-overview-group-header" href="@GetGroupUrl(group)">
                    @if (!string.IsNullOrWhiteSpace(group.Image))
                    {
                        <img class="periphery-overview-group-image @(group.IsThumbnail ? "periphery-overview-group-image--round" : "")" src="@group.Image" alt="@group.Name" loading="lazy" />
                    }
                    <div class="periphery-overview-group-info">
                        <h3>@group.Name</h3>
                        @if (!string.IsNullOrWhiteSpace(group.BriefIntroduction))
                        {
                            <p>@group.BriefIntroduction</p>
                        }
                    </div>
                </a>

                @if (group.Peripheries.Count > 0)
                {
                    <ul class="periphery-overview-items">
                        @foreach (var item in group.Peripheries)
                        {
                            <li>
                                <a href="@($"/peripheries/index/{item.Id}")" class="periphery-overview-item">
                                    <div class="periphery-overview-item-image">
                                        @if (!string.IsNullOrWhiteSpace(item.Image))
                                        {
                                            <img src="@item.Image" alt="@item.Name" loading="lazy" decoding="async" />
                                        }
                                        else
                                        {
                                            <div class="periphery-overview-item-placeholder">
                                                <CgMdiIcon Name="mdiGiftOutline" />
                                            </div>
                                        }
                                    </div>
                                    <span class="periphery-overview-item-name">@item.Name</span>
                                    <span class="periphery-overview-item-stat">
                                        <CgMdiIcon Name="mdiHeartOutline" />
                                        @item.CollectedCount
                                    </span>
                                </a>
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </EntrySection>
}

@code {
    [Parameter] public IReadOnlyList<GameOverviewPeripheryListModel> OverviewModels { get; set; } = [];

    private static string GetGroupUrl(GameOverviewPeripheryListModel group) => group.Type switch
    {
        PeripheryOverviewType.Entry => $"/entries/index/{group.ObjectId}",
        PeripheryOverviewType.Periphery => $"/peripheries/index/{group.ObjectId}",
        PeripheryOverviewType.User => $"/space/index/{group.ObjectId}",
        _ => "#"
    };
}
