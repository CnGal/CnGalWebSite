@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail

@if (Pictures.Count > 0)
{
    <EntrySection Title="图片" Icon="mdiImageMultipleOutline">
        @foreach (var group in Pictures)
        {
            @if (!string.IsNullOrWhiteSpace(group.Modifier))
            {
                <h3 class="periphery-gallery-group-title">@group.Modifier</h3>
            }
            <ul class="periphery-gallery-grid">
                @foreach (var pic in group.Pictures.Take(MaxPerGroup))
                {
                    <li>
                        <a href="@pic.Url" target="_blank" rel="noopener noreferrer">
                            <img src="@pic.Url" alt="@(!string.IsNullOrWhiteSpace(pic.Note) ? pic.Note : "周边图片")" loading="lazy" decoding="async" />
                        </a>
                    </li>
                }
            </ul>
        }
    </EntrySection>
}

@code {
    [Parameter] public IReadOnlyList<PicturesViewModel> Pictures { get; set; } = [];
    [Parameter] public int MaxPerGroup { get; set; } = 12;
}
