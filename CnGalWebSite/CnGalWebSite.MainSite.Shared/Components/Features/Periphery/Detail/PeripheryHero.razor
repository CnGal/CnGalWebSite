@inject IMainSiteAuthRequestService AuthRequestService

@if (!string.IsNullOrWhiteSpace(Name))
{
    <header class="periphery-hero">
        <div class="periphery-hero-side">
            @if (!string.IsNullOrWhiteSpace(MainPicture))
            {
                <img src="@MainPicture" alt="@Name" class="periphery-cover" loading="eager" decoding="async" />
            }
            else
            {
                <div class="periphery-cover periphery-cover--empty" aria-label="暂无封面">NO IMAGE</div>
            }
        </div>
        <div class="periphery-hero-main">
            <div class="periphery-hero-top">
                <span class="periphery-type">
                    <CgMdiIcon Name="mdiGiftOutline" />
                    周边
                </span>
            </div>
            <h1>@DisplayTitle</h1>
            @if (!string.IsNullOrWhiteSpace(BriefIntroduction))
            {
                <p class="periphery-brief">@BriefIntroduction</p>
            }
            <div class="periphery-hero-stats">
                <span class="periphery-hero-stat">
                    <CgMdiIcon Name="mdiEyeOutline" />
                    @ReaderCount 次浏览
                </span>
                <span class="periphery-hero-stat">
                    <CgMdiIcon Name="mdiHeartOutline" />
                    @CollectedCount 人收藏
                </span>
            </div>

            @if (PeripheryId > 0)
            {
                <div class="periphery-hero-actions">
                    <AuthorizeView>
                        <Authorized>
                            <CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail.EntryFavoriteButton ObjectId="PeripheryId" ObjectType="CnGalWebSite.DataModel.Model.FavoriteObjectType.Periphery" />
                            <a class="periphery-edit-btn" href="/peripheries/edit/@PeripheryId">
                                <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                                <span>编辑周边</span>
                            </a>
                        </Authorized>
                        <NotAuthorized>
                            <a class="periphery-edit-btn periphery-edit-btn--login" href="@AuthRequestService.BuildLoginUrl($"/peripheries/edit/{PeripheryId}")">
                                <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                                <span>登录后编辑</span>
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            }
        </div>
    </header>
}

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string? DisplayName { get; set; }
    [Parameter] public string? BriefIntroduction { get; set; }
    [Parameter] public string? MainPicture { get; set; }
    [Parameter] public string? BackgroundPicture { get; set; }
    [Parameter] public int ReaderCount { get; set; }
    [Parameter] public int CollectedCount { get; set; }
    [Parameter] public long PeripheryId { get; set; }

    private string DisplayTitle => string.IsNullOrWhiteSpace(DisplayName) ? Name : DisplayName;
}
