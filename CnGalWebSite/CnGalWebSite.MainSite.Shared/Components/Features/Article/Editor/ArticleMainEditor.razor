@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Articles
@using CnGalWebSite.Extensions
@using CnGalWebSite.SDK.MainSite.Models.Files
@using System.Linq

<section class="article-editor-section" id="section-article-main">
    <h2><CgMdiIcon Name="mdiFileDocumentOutline" Class="article-section-icon" aria-hidden="true"/>核心内容</h2>
    <p>设置文章主图、标题、类型与正文内容。</p>

    @if (Model != null)
    {     
        <CgFormGroup Label="类型">
            <div class="article-type-selector">
                @foreach (var type in VisibleArticleTypes)
                {
                    var isActive = Model.Type == type;
                    <button type="button"
                            class="article-type-btn @(isActive ? "active" : "")"
                            @onclick="() => OnTypeChanged(type)">
                        <CgMdiIcon Name="@GetArticleTypeIcon(type)" Class="article-type-icon" aria-hidden="true"/>
                        <span>@type.GetDisplayName()</span>
                    </button>
                }
            </div>
        </CgFormGroup>
        <CgFormGroup Label="主图">
            <CgImageUpload @bind-Value="Model.MainPicture"
                           Text="上传主图"
                           Type="ImageAspectType.None"/>
        </CgFormGroup>

        <CgFormGroup Label="标题">
            <CgInput @bind-Value="Model.Name" TValue="string"/>
        </CgFormGroup>



        <CgAlert Variant="info">
            你可以在这里自由发挥撰写文章内容，支持 Markdown 语法。
        </CgAlert>
        <CgMarkdownEditor @bind-Value="MainPageModel.Context"
                           Placeholder="支持 Markdown 语法..." />
    }
</section>

@code {
    [Parameter] public EditArticleMainViewModel Model { get; set; } = default!;
    [Parameter] public EditArticleMainPageViewModel MainPageModel { get; set; } = default!;
    [Parameter] public bool IsAdmin { get; set; }
    [Parameter] public EventCallback OnTypeChangedCallback { get; set; }

    private static readonly ArticleType[] _articleTypes =
    [
        ArticleType.Tought,
        ArticleType.Strategy,
        ArticleType.Interview,
        ArticleType.News,
        ArticleType.Evaluation,
        ArticleType.Peripheral,
        ArticleType.Notice,
        ArticleType.None,
        ArticleType.Fan
    ];

    private ArticleType[] VisibleArticleTypes => IsAdmin
        ? _articleTypes
        : _articleTypes.Where(t => t != ArticleType.Notice).ToArray();

    private static string GetArticleTypeIcon(ArticleType type) => type switch
    {
        ArticleType.Tought => "mdiHeadLightbulbOutline",
        ArticleType.Strategy => "mdiMapOutline",
        ArticleType.Interview => "mdiAccountVoice",
        ArticleType.News => "mdiNewspaperVariantOutline",
        ArticleType.Evaluation => "mdiStarCheckOutline",
        ArticleType.Peripheral => "mdiGiftOutline",
        ArticleType.Notice => "mdiBullhornOutline",
        ArticleType.None => "mdiTextBoxOutline",
        ArticleType.Fan => "mdiPaletteOutline",
        _ => "mdiHelpCircleOutline"
    };

    private async Task OnTypeChanged(ArticleType newType)
    {
        Model.Type = newType;
        await OnTypeChangedCallback.InvokeAsync();
    }
}
