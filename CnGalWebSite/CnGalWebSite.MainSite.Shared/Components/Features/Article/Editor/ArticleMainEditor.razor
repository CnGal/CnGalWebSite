@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Articles
@using CnGalWebSite.Extensions
@using CnGalWebSite.SDK.MainSite.Models.Files

<section class="article-editor-section" id="section-article-main">
    <h2><CgMdiIcon Name="mdiFileDocumentOutline" Class="article-section-icon" aria-hidden="true"/>主要信息</h2>
    <p>编辑文章类型、名称与主视觉资源。</p>

    @if (Model != null)
    {
        <CgFormGroup Label="类型">
            <CgEnumSelect TEnum="ArticleType"
                          Value="@Model.Type"
                          ValueChanged="OnTypeChanged"/>
        </CgFormGroup>

        <CgGrid>
            <CgFormGroup Label="唯一名称">
                <CgInput Value="@Model.Name"
                         ValueChanged="OnNameChanged" TValue="string"/>
            </CgFormGroup>
            <CgFormGroup Label="显示名称">
                <CgInput @bind-Value="Model.DisplayName"
                         Disabled="_syncDisplayName"/>
            </CgFormGroup>
        </CgGrid>

        <CgFormGroup Label="名称同步">
            <CgCheckbox Value="@_syncDisplayName"
                        ValueChanged="OnSyncDisplayNameChanged"
                        Label="显示名称与唯一名称保持一致"/>
        </CgFormGroup>

        <CgFormGroup Label="简介">
            <CgTextarea @bind-Value="Model.BriefIntroduction"
                        Rows="3" Placeholder="简短的介绍"/>
        </CgFormGroup>

        <CgGrid MinWidth="150px">
            <CgFormGroup Label="主图">
                <CgImageUpload @bind-Value="Model.MainPicture"
                               Text="上传主图"
                               Type="ImageAspectType.None"/>
            </CgFormGroup>
            <CgFormGroup Label="背景图">
                <CgImageUpload @bind-Value="Model.BackgroundPicture"
                               Text="上传背景图"
                               Type="ImageAspectType.None"/>
            </CgFormGroup>
            <CgFormGroup Label="小背景图">
                <CgImageUpload @bind-Value="Model.SmallBackgroundPicture"
                               Text="上传小背景图"
                               Type="ImageAspectType.None"/>
            </CgFormGroup>
        </CgGrid>

        <CgFormGroup Label="发布时间">
            <CgDateInput Value="@((DateTime?)Model.PubishTime)"
                         ValueChanged="OnPublishTimeChanged"
                         Mode="CgDateInputMode.DateTime"/>
        </CgFormGroup>

        <CgFormGroup Label="原创标记">
            <CgCheckbox @bind-Value="Model.IsCreatedByCurrentUser"
                        Label="本文为本人创作"/>
        </CgFormGroup>

        @if (!Model.IsCreatedByCurrentUser)
        {
            <CgGrid>
                <CgFormGroup Label="原作者">
                    <CgInput @bind-Value="Model.OriginalAuthor" Placeholder="原作者名称"/>
                </CgFormGroup>
                <CgFormGroup Label="原文链接">
                    <CgInput @bind-Value="Model.OriginalLink" Placeholder="https://..."/>
                </CgFormGroup>
            </CgGrid>
        }

        @if (Model.Type == ArticleType.News)
        {
            <CgGrid>
                <CgFormGroup Label="动态类别">
                    <CgInput @bind-Value="Model.NewsType" Placeholder="动态类别"/>
                </CgFormGroup>
                <CgFormGroup Label="动态发生时间">
                    <CgDateInput Value="@((DateTime?)_realNewsTime)"
                                 ValueChanged="OnRealNewsTimeChanged"
                                 Mode="CgDateInputMode.DateTime"/>
                </CgFormGroup>
            </CgGrid>
        }
    }
</section>

@code {
    [Parameter] public EditArticleMainViewModel Model { get; set; } = default!;

    private bool _syncDisplayName;
    private bool _syncInitialized;
    private DateTime _realNewsTime;

    protected override void OnParametersSet()
    {
        if (_syncInitialized) return;

        _syncDisplayName = string.Equals(Model.Name, Model.DisplayName, StringComparison.Ordinal);
        _realNewsTime = Model.RealNewsTime ?? DateTime.Now;
        _syncInitialized = true;
    }

    private void OnTypeChanged(ArticleType newType)
    {
        Model.Type = newType;
    }

    private Task OnNameChanged(string? value)
    {
        Model.Name = value ?? string.Empty;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }
        return Task.CompletedTask;
    }

    private Task OnSyncDisplayNameChanged(bool value)
    {
        _syncDisplayName = value;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }
        return Task.CompletedTask;
    }

    private void OnPublishTimeChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            Model.PubishTime = value.Value;
        }
    }

    private void OnRealNewsTimeChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _realNewsTime = value.Value;
            Model.RealNewsTime = value.Value;
        }
    }
}
