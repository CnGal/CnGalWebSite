<section class="article-meta">
    <div class="article-meta-item">
        <CgMdiIcon Name="mdiEyeOutline" />
        <span>@ReaderCount 阅读</span>
    </div>
    <div class="article-meta-item">
        <CgMdiIcon Name="mdiThumbUpOutline" />
        <span>@ThumbsUpCount 点赞</span>
    </div>
    <div class="article-meta-item">
        <CgMdiIcon Name="mdiCommentTextOutline" />
        <span>@CommentCount 评论</span>
    </div>
    <div class="article-meta-item article-meta-item--time">
        <CgMdiIcon Name="mdiCalendarOutline" />
        <time datetime="@TimeValue">@TimeDisplay</time>
    </div>
</section>

@code {
    [Parameter] public int ReaderCount { get; set; }
    [Parameter] public int ThumbsUpCount { get; set; }
    [Parameter] public long CommentCount { get; set; }
    [Parameter] public DateTime? PublishTime { get; set; }
    [Parameter] public DateTime CreateTime { get; set; }
    [Parameter] public DateTime LastEditTime { get; set; }

    private DateTime EffectiveTime
    {
        get
        {
            if (PublishTime.HasValue && PublishTime.Value.Year >= 1900)
            {
                return PublishTime.Value;
            }
            return CreateTime.Year < 1900 ? LastEditTime : CreateTime;
        }
    }

    private string TimeValue => EffectiveTime.ToString("yyyy-MM-dd");
    private string TimeDisplay => EffectiveTime.ToString("yyyy-MM-dd");
}
