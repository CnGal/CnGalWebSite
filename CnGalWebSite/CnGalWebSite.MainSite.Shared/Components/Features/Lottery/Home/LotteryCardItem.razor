@using CnGalWebSite.Extensions

<li>
    <div class="lottery-card">
        @if (!string.IsNullOrWhiteSpace(Model.Thumbnail))
        {
            <a class="lottery-card-image-wrapper" href="@($"/lotteries/index/{Model.Id}")">
                <img src="@Model.Thumbnail" alt="@Model.Name" class="lottery-card-image" loading="lazy" />
            </a>
        }
        <div class="lottery-card-body">
            <a class="lottery-card-title-link" href="@($"/lotteries/index/{Model.Id}")">
                <h3 class="lottery-card-title">@Model.Name</h3>
            </a>
            
            <div class="lottery-card-meta">
                <span class="lottery-card-meta-item">参与人数：@Model.Count</span>
                <span class="lottery-card-meta-item">截止时间：@Model.EndTime.ToString("yyyy年M月d日 H点")</span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.BriefIntroduction))
            {
                <p class="lottery-card-intro">@Model.BriefIntroduction</p>
            }

            <div class="lottery-card-footer">
                <div class="lottery-card-condition">
                    <span class="lottery-card-condition-label">参与条件：</span>
                    <span class="lottery-card-condition-value">@Model.ConditionType.GetDisplayName()</span>
                </div>
                
                <CgButton Href="@($"/lotteries/index/{Model.Id}")" Variant="primary" class="lottery-card-btn">
                    <CgMdiIcon Name="mdiGiftOutline" />
                    <span class="lottery-card-btn-text">查看抽奖</span>
                </CgButton>
            </div>
        </div>
    </div>
</li>

@code {
    [Parameter, EditorRequired]
    public LotteryCardItemModel Model { get; set; } = default!;

    private bool IsEnded => Model.IsEnd || DateTime.Now > Model.EndTime;
    private bool IsUpcoming => DateTime.Now < Model.BeginTime;

    private string StatusText => IsEnded ? "已结束" : (IsUpcoming ? "未开始" : "进行中");
    private string StatusCss => IsEnded ? "ended" : (IsUpcoming ? "upcoming" : "active");
    private string StatusIcon => IsEnded ? "mdiCheckCircleOutline" : (IsUpcoming ? "mdiClockOutline" : "mdiPlayCircleOutline");
}
