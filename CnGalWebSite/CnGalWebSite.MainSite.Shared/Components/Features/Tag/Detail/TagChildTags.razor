@using CnGalWebSite.DataModel.ViewModel.Search
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail

<EntrySection Title="子标签" Icon="mdiTagMultipleOutline" Show="Tags is not null && Tags.Count > 0">
    <EntryCardList>
        @if (Tags is not null)
        {
            @foreach (var tag in Tags)
            {
                <li>
                    <EntryCardItem Url="@($"/tags/index/{tag.Id}")" Image="@tag.MainImage" Title="@tag.Name" />
                </li>
            }
        }
    </EntryCardList>
</EntrySection>

@code {
    [Parameter] public List<TagInforTipViewModel>? Tags { get; set; }
}
