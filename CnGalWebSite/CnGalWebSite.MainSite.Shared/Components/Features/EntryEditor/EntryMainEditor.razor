@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.Extensions
@using CnGalWebSite.SDK.MainSite.Models.Files

<section class="entry-editor-section">
    <h2>主要信息</h2>
    <p>编辑词条类型、名称、样式模板与主视觉资源。</p>

    @if (Model != null)
    {
        <div class="cg-grid-2">
            <div class="cg-form-group">
                <label class="cg-form-label">类型</label>
                <CgEnumSelect TEnum="EntryType"
                              Value="@Model.Type"
                              ValueChanged="OnTypeChanged" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">样式模板</label>
                <CgEnumSelect TEnum="EntryStyleTemplate"
                              Value="@Model.Template"
                              ValueChanged="OnTemplateChanged" />
            </div>
        </div>

        <div class="cg-form-group">
            <CgCheckbox Value="@_syncDisplayName"
                        ValueChanged="OnSyncDisplayNameChanged"
                        Label="显示名称与唯一名称保持一致" />
        </div>

        <div class="cg-grid-2">
            <div class="cg-form-group">
                <label class="cg-form-label">唯一名称</label>
                <CgInput Value="@Model.Name"
                         ValueChanged="OnNameChanged"
                         Placeholder="如：game_name" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">显示名称</label>
                <CgInput @bind-Value="Model.DisplayName"
                         Disabled="_syncDisplayName"
                         Placeholder="展示在页面上的名称" />
            </div>
        </div>

        <div class="cg-grid-2">
            <div class="cg-form-group">
                <label class="cg-form-label">别称</label>
                <CgInput @bind-Value="Model.AnotherName"
                         Placeholder="可选，多个别称可用分隔符组织" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">缩略图</label>
                <CgImageUpload @bind-Value="Model.Thumbnail"
                               Text="上传缩略图"
                               ShowCropper
                               Type="ImageAspectType._1_1" />
            </div>
        </div>

        <div class="cg-form-group">
            <label class="cg-form-label">简介</label>
            <textarea class="cg-textarea"
                      @bind="Model.BriefIntroduction"
                      placeholder="简短的一句话介绍"
                      rows="3"></textarea>
        </div>

        <div class="cg-grid-2">
            <div class="cg-form-group">
                <label class="cg-form-label">主图</label>
                <CgImageUpload @bind-Value="Model.MainPicture"
                               Text="上传主图"
                               ShowCropper
                               Type="ImageAspectType._16_9" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">背景图</label>
                <CgImageUpload @bind-Value="Model.BackgroundPicture"
                               Text="上传大背景图"
                               Type="ImageAspectType.None" />
            </div>
        </div>

        <div class="cg-form-group">
            <label class="cg-form-label">小背景图</label>
            <CgImageUpload @bind-Value="Model.SmallBackgroundPicture"
                           Text="上传小背景图"
                           Type="ImageAspectType.None" />
        </div>
    }
</section>

@code {
    [Parameter]
    public EditMainViewModel Model { get; set; } = default!;

    [Parameter]
    public EventCallback<EntryType> TypeChanged { get; set; }

    private bool _syncDisplayName;
    private bool _syncInitialized;


    protected override void OnParametersSet()
    {
        if (_syncInitialized)
        {
            return;
        }

        _syncDisplayName = string.Equals(Model.Name, Model.DisplayName, StringComparison.Ordinal);
        _syncInitialized = true;
    }

    private async Task OnTypeChanged(EntryType newType)
    {
        Model.Type = newType;
        await TypeChanged.InvokeAsync(newType);
    }

    private void OnTemplateChanged(EntryStyleTemplate template)
    {
        Model.Template = template;
    }

    private Task OnNameChanged(string? value)
    {
        Model.Name = value ?? string.Empty;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }

        return Task.CompletedTask;
    }

    private Task OnSyncDisplayNameChanged(bool value)
    {
        _syncDisplayName = value;
        if (_syncDisplayName)
        {
            Model.DisplayName = Model.Name;
        }

        return Task.CompletedTask;
    }
}
