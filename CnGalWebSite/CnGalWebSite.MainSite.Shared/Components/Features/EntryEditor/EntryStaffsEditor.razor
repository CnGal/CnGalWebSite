@using CnGalWebSite.DataModel.Helper
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel

<CgFormSection Title="Staff 列表">
    <HeaderActions>
        <CgButton Variant="outline" OnClick="OpenBatchDialog">批量导入</CgButton>
        <CgButton Variant="primary" OnClick="AddStaff">添加 Staff</CgButton>
    </HeaderActions>
    <ChildContent>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <CgAlert Variant="error">@_errorMessage</CgAlert>
        }

        <CgTable HasData="@Staffs.Any()">
            <Empty>
                <p class="cg-staff-empty">暂无 Staff 数据，请点击"添加 Staff"或"批量导入"。</p>
            </Empty>
            <ChildContent>
                <thead>
                <tr>
                    <th>分组</th>
                    <th>★官方职位</th>
                    <th>★唯一名称</th>
                    <th>通用职位</th>
                    <th>隶属组织</th>
                    <th>自定义名称</th>
                    <th>操作</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var item in Staffs)
                {
                    <tr>
                        <td>@item.Modifier</td>
                        <td>@item.PositionOfficial</td>
                        <td>@item.Name</td>
                        <td>@item.PositionGeneral.GetDisplayName()</td>
                        <td>@item.SubordinateOrganization</td>
                        <td>@item.CustomName</td>
                        <td class="cg-actions">
                            <CgButton Variant="outline" OnClick="() => EditStaff(item)">编辑</CgButton>
                            <CgButton Variant="danger" OnClick="() => RemoveStaff(item)">删除</CgButton>
                        </td>
                    </tr>
                }
                </tbody>
            </ChildContent>
        </CgTable>
    </ChildContent>
</CgFormSection>

@* ── 编辑 / 新增弹窗 ── *@
<CgModal IsOpen="@_editDialogOpen"
         Title="@(_editTarget == null ? "添加 Staff" : "编辑 Staff")"
         OnClose="CloseEditDialogAsync">
    <ChildContent>
        @if (_editingItem != null)
        {
            <CgGrid>
                <CgFormGroup Label="分组">
                    <CgInput @bind-Value="_editingItem.Modifier" Placeholder="如：主题曲"/>
                </CgFormGroup>
                <CgFormGroup Label="★官方职位">
                    <CgInput @bind-Value="_editingItem.PositionOfficial" Placeholder="如：主催、作曲"/>
                </CgFormGroup>
                <CgFormGroup Label="★唯一名称">
                    <CgInput @bind-Value="_editingItem.Name" Placeholder="Staff 唯一名称"/>
                </CgFormGroup>
                <CgFormGroup Label="通用职位">
                    <CgEnumSelect TEnum="PositionGeneralType"
                                  Value="@_editingItem.PositionGeneral"
                                  ValueChanged="OnPositionGeneralChanged"/>
                </CgFormGroup>
                <CgFormGroup Label="隶属组织">
                    <CgInput @bind-Value="_editingItem.SubordinateOrganization" Placeholder="如：工作室A"/>
                </CgFormGroup>
                <CgFormGroup Label="自定义名称">
                    <CgInput @bind-Value="_editingItem.CustomName" Placeholder="自定义显示名称"/>
                </CgFormGroup>
            </CgGrid>
        }
    </ChildContent>
    <Footer>
        <CgButton Variant="outline" OnClick="CloseEditDialog">取消</CgButton>
        <CgButton Variant="primary" OnClick="SaveStaff">保存</CgButton>
    </Footer>
</CgModal>

@* ── 批量导入弹窗 ── *@
<CgModal IsOpen="@_batchDialogOpen"
         Title="批量导入 Staff"
         OnClose="CloseBatchDialogAsync">
    <ChildContent>
        <div class="cg-batch-tip">
            <p>按照下方例子整理 Staff 文本后输入可以批量导入 Staff 信息</p>
            <p>括号中的内容分别是通用职位、配音角色、隶属组织</p>
            <p>同类项将会自动合并</p>
            <p>其中"、""，""，"和"："":"和"（）""()"都可作分隔符，如果 Staff 名称中包含分隔符，请单独录入</p>
            <p>请把有分类的 Staff 放到最后</p>
            <br/>
            <p class="cg-batch-example">
                主催：小明<br/>
                CV（配音）：小红、小亮（工作室A）、小李<br/>
                主题曲：<br/>
                作词：小红（工作室B）<br/>
                作曲：小刚
            </p>
        </div>
        <CgTextarea @bind-Value="_batchText" Rows="7" Placeholder="请输入 Staff 文本" />
    </ChildContent>
    <Footer>
        <CgButton Variant="outline" OnClick="CloseBatchDialog">取消</CgButton>
        <CgButton Variant="primary" OnClick="SaveBatch">保存</CgButton>
    </Footer>
</CgModal>

@code {
    [Parameter] public List<StaffModel> Staffs { get; set; } = default!;

    // ── 错误提示 ──
    private string? _errorMessage;
    private Timer? _errorTimer;

    // ── 编辑弹窗状态 ──
    private bool _editDialogOpen;
    private StaffModel? _editingItem;
    private StaffModel? _editTarget; // null = 新增, 非null = 编辑

    // ── 批量导入弹窗状态 ──
    private bool _batchDialogOpen;
    private string? _batchText;

    // ── 错误提示辅助 ──
    private void ShowError(string message)
    {
        _errorMessage = message;
        _errorTimer?.Dispose();
        _errorTimer = new Timer(_ =>
        {
            _errorMessage = null;
            InvokeAsync(StateHasChanged);
        }, null, 4000, Timeout.Infinite);
    }

    // ── 添加 ──
    private void AddStaff()
    {
        _editTarget = null;
        _editingItem = new StaffModel();
        _editDialogOpen = true;
    }

    // ── 编辑 ──
    private void EditStaff(StaffModel model)
    {
        _editTarget = model;
        _editingItem = new StaffModel
        {
            Id = model.Id,
            Modifier = model.Modifier,
            PositionOfficial = model.PositionOfficial,
            Name = model.Name,
            PositionGeneral = model.PositionGeneral,
            SubordinateOrganization = model.SubordinateOrganization,
            CustomName = model.CustomName
        };
        _editDialogOpen = true;
    }

    // ── 删除 ──
    private void RemoveStaff(StaffModel model)
    {
        Staffs.Remove(model);
    }

    // ── 保存编辑 ──
    private void SaveStaff()
    {
        if (_editingItem == null)
        {
            return;
        }

        // 验证
        var result = _editingItem.Validate(Staffs);
        if (!result.Successful)
        {
            ShowError(result.Error);
            return;
        }

        if (_editTarget == null)
        {
            // 新增：分配 Id
            _editingItem.Id = Staffs.Count == 0 ? 1 : Staffs.Max(s => s.Id) + 1;
            Staffs.Add(_editingItem);
        }
        else
        {
            // 编辑：回写到原对象
            _editTarget.Modifier = _editingItem.Modifier;
            _editTarget.PositionOfficial = _editingItem.PositionOfficial;
            _editTarget.Name = _editingItem.Name;
            _editTarget.PositionGeneral = _editingItem.PositionGeneral;
            _editTarget.SubordinateOrganization = _editingItem.SubordinateOrganization;
            _editTarget.CustomName = _editingItem.CustomName;
        }

        CloseEditDialog();
    }

    private void OnPositionGeneralChanged(PositionGeneralType value)
    {
        if (_editingItem != null)
        {
            _editingItem.PositionGeneral = value;
        }
    }

    private void CloseEditDialog()
    {
        _editingItem = null;
        _editTarget = null;
        _editDialogOpen = false;
    }

    private Task CloseEditDialogAsync()
    {
        CloseEditDialog();
        return Task.CompletedTask;
    }

    // ── 批量导入 ──
    private void OpenBatchDialog()
    {
        _batchText = null;
        _batchDialogOpen = true;
    }

    private void SaveBatch()
    {
        if (string.IsNullOrWhiteSpace(_batchText))
        {
            ShowError("请输入 Staff 文本");
            return;
        }

        var items = ToolHelper.GetStaffsFromString(_batchText);

        foreach (var item in items)
        {
            var result = item.Validate(Staffs);
            if (!result.Successful)
            {
                ShowError(result.Error);
                // 跳过重复项，继续导入其他项
                continue;
            }

            item.Id = Staffs.Any() ? Staffs.Max(s => s.Id) + 1 : 0;
            Staffs.Add(item);
        }

        CloseBatchDialog();
    }

    private void CloseBatchDialog()
    {
        _batchText = null;
        _batchDialogOpen = false;
    }

    private Task CloseBatchDialogAsync()
    {
        CloseBatchDialog();
        return Task.CompletedTask;
    }
}
