@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Entries

<section class="entry-editor-section">
    <h2>正文主页</h2>
    <p>使用 Markdown 编辑词条详情内容。</p>

    @if (Model != null)
    {
        <CgTextarea @bind-Value="Model.Context"
                    Placeholder="支持 Markdown 语法..."
                    Rows="20"
                    Monospace />
    }
</section>

@code {
    [Parameter]
    public EditMainPageViewModel Model { get; set; } = default!;
}
