@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Entries

<section class="entry-editor-section" id="section-mainpage">
    <h2><CgMdiIcon Name="mdiBookOpenVariant" Class="entry-section-icon" aria-hidden="true" />正文主页</h2>
    <p>使用 Markdown 编辑词条详情内容。</p>

    @if (Model != null)
    {
        <CgMarkdownEditor @bind-Value="Model.Context"
                           Placeholder="支持 Markdown 语法..." />
    }
</section>

@code {
    [Parameter]
    public EditMainPageViewModel Model { get; set; } = default!;
}
