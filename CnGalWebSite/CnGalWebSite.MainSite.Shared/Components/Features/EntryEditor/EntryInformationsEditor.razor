@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.Extensions
@using System.Globalization

<CgFormSection Title="基础信息项" Icon="mdiFormatListBulleted" Flat>
    @foreach (var info in Informations)
    {
        @if (info.Name == "生日")
        {
            <CgFormGroup Label="@FormatLabel(info)">
                <CgDateInput Value="@ParseBirthday(info.Value)"
                             ValueChanged="(date) => OnBirthdayChanged(date, info)" />
            </CgFormGroup>
        }
        else if (info.Name == "性别")
        {
            <CgFormGroup Label="@FormatLabel(info)">
                <CgEnumSelect TEnum="GenderType"
                              Value="@GetGenderValue(info.Value)"
                              ValueChanged="(v) => OnGenderChanged(v, info)" />
            </CgFormGroup>
        }
        else
        {
            <CgFormGroup Label="@FormatLabel(info)">
                <CgInput @bind-Value="info.Value" Placeholder="@($"请输入{info.Name}")" />
            </CgFormGroup>
        }
    }
</CgFormSection>

@code {
    [Parameter]
    public List<EditInformationModel> Informations { get; set; } = default!;

    private static string FormatLabel(EditInformationModel info)
    {
        return !string.IsNullOrWhiteSpace(info.Description)
            ? $"{info.Name} ({info.Description})"
            : info.Name;
    }

    private static DateTime? ParseBirthday(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        return DateTime.TryParseExact(value, "M月d日", null, DateTimeStyles.None, out var date)
            ? date
            : null;
    }

    private static void OnBirthdayChanged(DateTime? date, EditInformationModel info)
    {
        info.Value = date?.ToString("M月d日");
    }

    private static GenderType GetGenderValue(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return GenderType.None;
        }

        return value.ToEnumValue<GenderType>();
    }

    private static void OnGenderChanged(GenderType gender, EditInformationModel info)
    {
        info.Value = gender.GetDisplayName();
    }
}
