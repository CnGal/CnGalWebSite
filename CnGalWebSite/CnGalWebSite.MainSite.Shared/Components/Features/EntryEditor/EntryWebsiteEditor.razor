@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Entries
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.Extensions

<section class="entry-editor-section">
    <h2>专题页设置</h2>
    <p>专属样式、图片规格、HTML 覆盖页等内容。</p>
    
    @if (Model != null)
    {
        <div class="cg-grid-2">
            <div class="cg-form-group">
                <label class="cg-form-label">Logo</label>
                <CgInput @bind-Value="Model.Logo" Placeholder="Logo 图片链接" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">副标题</label>
                <CgInput @bind-Value="Model.SubTitle" Placeholder="专题副标题" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">主题语句</label>
                <CgInput @bind-Value="Model.Impressions" Placeholder="如：献给每一位创作者" />
            </div>
            <div class="cg-form-group">
                <label class="cg-form-label">主题颜色</label>
                <CgInput @bind-Value="Model.Color" Placeholder="如：#3B82F6" />
            </div>
        </div>

        <div class="cg-form-group">
            <label class="cg-form-label">自定义首页（HTML）</label>
            <textarea class="cg-textarea" @bind="Model.FirstPage" placeholder="可选，覆盖专题首页内容" rows="5"></textarea>
        </div>

        <div class="cg-form-group">
            <label class="cg-form-label">自定义介绍（HTML）</label>
            <textarea class="cg-textarea" @bind="Model.Introduction" placeholder="可选，覆盖专题介绍内容" rows="5"></textarea>
        </div>

        <div class="cg-form-group">
            <label class="cg-form-label">自定义 HTML 代码</label>
            <textarea class="cg-textarea" @bind="Model.Html" placeholder="在此输入自定义的网页 HTML 代码" rows="6"></textarea>
        </div>

        <div class="cg-form-section mt-4">
            <button class="cg-btn cg-btn--primary" @onclick="AddImage">添加专题图片</button>
            <div class="image-list mt-4">
                @foreach (var img in Model.Images)
                {
                    <div class="image-item">
                        <div class="cg-form-group flex-1">
                            <label class="cg-form-label">图片位置（Type）</label>
                            <CgSelect Value="@img.Type.ToString()"
                                      ValueChanged="(text) => OnImageTypeChanged(img, text)"
                                      Options="@_imageTypeOptions" />
                        </div>
                        <div class="cg-form-group flex-1">
                            <label class="cg-form-label">图片尺寸（Size）</label>
                            <CgSelect Value="@img.Size.ToString()"
                                      ValueChanged="(text) => OnImageSizeChanged(img, text)"
                                      Options="@_imageSizeOptions" />
                        </div>
                        <div class="cg-form-group flex-1">
                            <label class="cg-form-label">图片链接</label>
                            <CgInput @bind-Value="img.Image" Placeholder="如：https://..." />
                        </div>
                        <div class="cg-form-group flex-1">
                            <label class="cg-form-label">备注说明</label>
                            <CgInput @bind-Value="img.Note" Placeholder="图片描述" />
                        </div>
                        <button class="cg-btn cg-btn--danger" @onclick="@(() => RemoveImage(img))">删除</button>
                    </div>
                }
            </div>
        </div>
    }
</section>

@code {
    [Parameter]
    public EditEntryWebsiteViewModel Model { get; set; } = default!;

    private readonly List<KeyValuePair<string, string>> _imageTypeOptions = Enum.GetValues<EntryWebsiteImageType>()
        .Select(type => KeyValuePair.Create(type.ToString(), type.GetDisplayName()))
        .ToList();

    private readonly List<KeyValuePair<string, string>> _imageSizeOptions = Enum.GetValues<EntryWebsiteImageSize>()
        .Select(type => KeyValuePair.Create(type.ToString(), type.GetDisplayName()))
        .ToList();

    private void AddImage()
    {
        Model.Images ??= new();
        Model.Images.Add(new EditWebsiteImageModel());
    }

    private void RemoveImage(EditWebsiteImageModel img)
    {
        Model.Images?.Remove(img);
    }

    private Task OnImageTypeChanged(EditWebsiteImageModel model, string? value)
    {
        if (Enum.TryParse<EntryWebsiteImageType>(value, out var type))
        {
            model.Type = type;
        }

        return Task.CompletedTask;
    }

    private Task OnImageSizeChanged(EditWebsiteImageModel model, string? value)
    {
        if (Enum.TryParse<EntryWebsiteImageSize>(value, out var size))
        {
            model.Size = size;
        }

        return Task.CompletedTask;
    }
}
