@page "/admin/listnews"
@attribute [Authorize(Roles = "Editor")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@inject IArticleCommandService ArticleCommandService
@inject IFileCommandService FileCommandService
@implements IDisposable
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.News
@using CnGalWebSite.DataModel.ViewModel.Articles
@using CnGalWebSite.DataModel.ViewModel

<CgPageMeta Title="动态管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiNewspaperVariantOutline" aria-hidden="true" />
        动态管理
    </h1>

    @* ── 顶部操作按钮 ── *@
    <div class="admin-news-toolbar">
        <CgButton Variant="primary" Size="sm" OnClick="OpenAddNewsModal">
            <CgMdiIcon Name="mdiPlus" aria-hidden="true" /> 添加动态
        </CgButton>
        <CgButton Variant="secondary" Size="sm" OnClick="() => _showWeiboModal = true">
            <CgMdiIcon Name="mdiSinaWeibo" aria-hidden="true" /> 导入微博
        </CgButton>
    </div>

    <CgTabs Items="@_tabs"
            DefaultActiveKey="gamenews"
            Variant="underline"
            AriaLabel="动态管理"
            Id="admin-news-tabs">
        <PanelTemplate>
            @if (context == "gamenews")
            {
                <CgDataTable TItem="GameNewsOverviewModel"
                             Title="游戏动态列表"
                             OnServerQuery="OnQueryGameNews"
                             DefaultSortField="Id"
                             DefaultSortDesc="true"
                             @ref="_gameNewsTable">
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="Id" Field="Id" Width="80px" />
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="标题" Field="Title">
                        <ChildContent Context="item">
                            @if (item.ArticleId > 0)
                            {
                                <a class="admin-cell-name" href="@($"/articles/index/{item.ArticleId}")">@item.Title</a>
                            }
                            else
                            {
                                <span>@item.Title</span>
                            }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="作者" Field="Author" Width="120px" />
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="状态" Field="State">
                        <ChildContent Context="item">
                            <span class="admin-badge @GetStateBadgeClass(item.State)">@item.State.GetDisplayName()</span>
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="来源类型" Field="RssType" Width="120px" Sortable="false">
                        <ChildContent Context="item">
                            @if (item.RssType.HasValue)
                            {
                                <span class="admin-badge @GetRssTypeBadgeClass(item.RssType.Value)">@item.RssType.Value.GetDisplayName()</span>
                            }
                            else
                            {
                                <span class="admin-badge admin-badge--neutral">-</span>
                            }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="发布时间" Field="PublishTime" Width="160px">
                        <ChildContent Context="item">
                            @item.PublishTime.ToString("yyyy-MM-dd HH:mm")
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameNewsOverviewModel" Title="操作" Sortable="false" Width="220px">
                        <ChildContent Context="item">
                            <div class="admin-actions">
                                <button class="admin-action-btn admin-action-btn--edit" title="编辑" @onclick="() => OpenEditGameNewsModal(item.Id)"><CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" /></button>
                                @if (item.State == GameNewsState.Edit)
                                {
                                    <button class="admin-action-btn admin-action-btn--publish" title="发布" @onclick="() => PublishGameNews(item.Id)"><CgMdiIcon Name="mdiPublish" aria-hidden="true" /></button>
                                    <button class="admin-action-btn admin-action-btn--hide" title="忽略" @onclick="() => IgnoreGameNews(item.Id, true)"><CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /></button>
                                }
                                else if (item.State == GameNewsState.Ignore)
                                {
                                    <button class="admin-action-btn admin-action-btn--show" title="恢复" @onclick="() => IgnoreGameNews(item.Id, false)"><CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" /></button>
                                }
                                <button class="admin-action-btn admin-action-btn--preview" title="预览" @onclick="() => PreviewGameNews(item.Id)"><CgMdiIcon Name="mdiEye" aria-hidden="true" /></button>
                            </div>
                        </ChildContent>
                    </CgDataTableColumn>
                </CgDataTable>
            }
            else if (context == "weeklynews")
            {
                <CgDataTable TItem="WeeklyNewsOverviewModel"
                             Title="周报列表"
                             OnServerQuery="OnQueryWeeklyNews"
                             DefaultSortField="Id"
                             DefaultSortDesc="true"
                             @ref="_weeklyNewsTable">
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="Id" Field="Id" Width="80px" />
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="标题" Field="Title">
                        <ChildContent Context="item">
                            @if (item.ArticleId > 0)
                            {
                                <a class="admin-cell-name" href="@($"/articles/index/{item.ArticleId}")">@item.Title</a>
                            }
                            else
                            {
                                <span>@item.Title</span>
                            }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="状态" Field="State">
                        <ChildContent Context="item">
                            <span class="admin-badge @GetStateBadgeClass(item.State)">@item.State.GetDisplayName()</span>
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="发布时间" Field="PublishTime" Width="160px">
                        <ChildContent Context="item">
                            @item.PublishTime.ToString("yyyy-MM-dd HH:mm")
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="创建时间" Field="CreateTime" Width="160px">
                        <ChildContent Context="item">
                            @item.CreateTime.ToString("yyyy-MM-dd HH:mm")
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="WeeklyNewsOverviewModel" Title="操作" Sortable="false" Width="220px">
                        <ChildContent Context="item">
                            <div class="admin-actions">
                                <button class="admin-action-btn admin-action-btn--edit" title="编辑" @onclick="() => OpenEditWeeklyNewsModal(item.Id)"><CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" /></button>
                                @if (item.State == GameNewsState.Edit)
                                {
                                    <button class="admin-action-btn admin-action-btn--publish" title="发布" @onclick="() => PublishWeeklyNews(item.Id)"><CgMdiIcon Name="mdiPublish" aria-hidden="true" /></button>
                                }
                                <button class="admin-action-btn admin-action-btn--reset" title="重置" @onclick="() => ResetWeeklyNews(item.Id)"><CgMdiIcon Name="mdiRefresh" aria-hidden="true" /></button>
                                <button class="admin-action-btn admin-action-btn--preview" title="预览" @onclick="() => PreviewWeeklyNews(item.Id)"><CgMdiIcon Name="mdiEye" aria-hidden="true" /></button>
                            </div>
                        </ChildContent>
                    </CgDataTableColumn>
                </CgDataTable>
            }
        </PanelTemplate>
    </CgTabs>
</div>

@* ═══════════════════  动态编辑弹窗  ═══════════════════ *@
<CgModal IsOpen="_showEditGameNewsModal" Title="@(_isAddingNews ? "添加动态" : "编辑动态")" OnClose="CloseEditGameNewsModal" Width="800px">
    <ChildContent>
    @if (_editingGameNews != null)
    {
        <CgFormSection Title="基本信息" Icon="mdiInformationOutline" Flat>
            
            <CgFormGroup Label="主图">
                    <CgImageUpload @bind-Value="_editingGameNews.MainPicture" Type=" SDK.MainSite.Models.Files.ImageAspectType._16_9" ShowCropper />
            </CgFormGroup>
            <CgGrid>
                <CgFormGroup Label="标题">
                    <CgInput @bind-Value="_editingGameNews.Title" Placeholder="请输入标题"/>
                </CgFormGroup>
                <CgFormGroup Label="作者">
                    <CgInput @bind-Value="_editingGameNews.Author" Placeholder="请输入作者"/>
                </CgFormGroup>
            </CgGrid>
            <CgFormGroup Label="简介">
                <CgTextarea @bind-Value="_editingGameNews.BriefIntroduction" Placeholder="请输入简介"/>
            </CgFormGroup>

        </CgFormSection>

        <CgFormSection Title="分类与来源" Icon="mdiTagOutline" Flat>
            <CgGrid>
                <CgFormGroup Label="文章类型">
                    <CgEnumSelect TEnum="ArticleType" @bind-Value="_editingGameNews.Type" />
                </CgFormGroup>
                <CgFormGroup Label="动态类型">
                    <CgInput @bind-Value="_editingGameNews.NewsType" Placeholder="例如：新闻、公告等" />
                </CgFormGroup>
                <CgFormGroup Label="来源类型">
                    <CgEnumSelect TEnum="OriginalRSSType" @bind-Value="_editingGameNews.RssType" Disabled="true" />
                </CgFormGroup>
                <CgFormGroup Label="原文发布时间">
                    <CgDateInput @bind-Value="_gameNewsPublishTime" Mode="CgDateInputMode.DateTime" />
                </CgFormGroup>
            </CgGrid>
            <CgFormGroup Label="原文链接">
                <CgInput @bind-Value="_editingGameNews.Link" Placeholder="请输入原文链接" />
            </CgFormGroup>
        </CgFormSection>

        <CgFormSection Title="作者关联" Icon="mdiAccountOutline" Flat>
            <CgGrid>
                <CgFormGroup Label="微博Id">
                    <CgInput @bind-Value="_editingGameNews.WeiboId" Placeholder="请输入微博Id" />
                </CgFormGroup>
                <CgFormGroup Label="关联词条名称">
                    <CgAutoComplete @bind-Value="_editingGameNews.AuthorEntryName" Items="_allEntryNames" Placeholder="请输入关联词条名称" />
                </CgFormGroup>
            </CgGrid>
        </CgFormSection>

        <CgFormSection Title="关联词条" Icon="mdiLinkVariant" Flat>
            <CnGalWebSite.MainSite.Shared.Components.Features.Entry.Editor.EntryRelevanceListEditor Title="词条" Items="_editingGameNews.Entries" AutoCompleteItems="_allEntryNames" />
        </CgFormSection>

        <CgFormSection Title="正文" Icon="mdiTextBoxOutline" Flat>
            <CgFormGroup Label="正文内容 (Markdown)">
                <CgMarkdownEditor @bind-Value="_editingGameNews.MainPage" Placeholder="请输入正文内容（支持Markdown）" />
            </CgFormGroup>
        </CgFormSection>
    }
    </ChildContent>
    <Footer>
        <CgButton Variant="secondary" OnClick="CloseEditGameNewsModal">取消</CgButton>
        <CgButton Variant="primary" Async OnClick="SaveGameNews">保存</CgButton>
    </Footer>
</CgModal>

@* ═══════════════════  周报编辑弹窗  ═══════════════════ *@
<CgModal IsOpen="_showEditWeeklyNewsModal" Title="编辑周报" OnClose="CloseEditWeeklyNewsModal" Width="800px">
    <ChildContent>
    @if (_editingWeeklyNews != null)
    {
        <CgFormSection Title="基本信息" Icon="mdiInformationOutline" Flat>
            
            <CgFormGroup Label="主图链接">
                <CgImageUpload @bind-Value="_editingWeeklyNews.MainPicture" Type=" SDK.MainSite.Models.Files.ImageAspectType._16_9" ShowCropper/>
            </CgFormGroup>
            <CgFormGroup Label="标题">
                <CgInput @bind-Value="_editingWeeklyNews.Title" Placeholder="请输入标题"/>
            </CgFormGroup>
            <CgFormGroup Label="简介">
                <CgTextarea @bind-Value="_editingWeeklyNews.BriefIntroduction" Placeholder="请输入简介"/>
            </CgFormGroup>

        </CgFormSection>

        <CgFormSection Title="时间与类型" Icon="mdiClockOutline" Flat>
            <CgGrid>
                <CgFormGroup Label="文章类型">
                    <CgEnumSelect TEnum="ArticleType" @bind-Value="_editingWeeklyNews.Type" />
                </CgFormGroup>
                <CgFormGroup Label="发布时间">
                    <CgDateInput @bind-Value="_weeklyNewsPublishTime" Mode="CgDateInputMode.DateTime" />
                </CgFormGroup>
                <CgFormGroup Label="创建时间">
                    <CgDateInput @bind-Value="_weeklyNewsCreateTime" Mode="CgDateInputMode.DateTime" />
                </CgFormGroup>
            </CgGrid>
        </CgFormSection>

        <CgFormSection Title="关联动态" Icon="mdiNewspaperVariantOutline" Flat>
            @if (_editingWeeklyNews.News.Any())
            {
                <div class="admin-weekly-news-list">
                    @foreach (var newsItem in _editingWeeklyNews.News)
                    {
                        <div class="admin-weekly-news-item">
                            <CgCheckbox @bind-Value="newsItem.IsSelected"
                                        Label="@($"[{newsItem.NewsId}] {newsItem.NewsTitle}")" />
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="admin-empty-text">该周没有可关联的动态</p>
            }
        </CgFormSection>

        <CgFormSection Title="正文" Icon="mdiTextBoxOutline" Flat>
            <CgFormGroup Label="正文内容 (Markdown)">
                <CgMarkdownEditor @bind-Value="_editingWeeklyNews.MainPage" Placeholder="请输入正文内容（支持Markdown）" />
            </CgFormGroup>
        </CgFormSection>
    }
    </ChildContent>
    <Footer>
        <CgButton Variant="secondary" OnClick="CloseEditWeeklyNewsModal">取消</CgButton>
        <CgButton Variant="danger" Async OnClick="ResetWeeklyNewsInModal">重置</CgButton>
        <CgButton Variant="primary" Async OnClick="SaveWeeklyNews">保存</CgButton>
    </Footer>
</CgModal>

@* ═══════════════════  微博导入弹窗  ═══════════════════ *@
<CgModal IsOpen="_showWeiboModal" Title="导入微博动态" OnClose="() => _showWeiboModal = false">
    <ChildContent>
    <CgFormGroup Label="微博链接">
        <CgInput @bind-Value="_weiboLink" Placeholder="请粘贴微博链接" />
    </CgFormGroup>
    </ChildContent>

    <Footer>
        <CgButton Variant="secondary" OnClick="() => _showWeiboModal = false">取消</CgButton>
        <CgButton Variant="primary" Async OnClick="ImportWeiboNews">导入</CgButton>
    </Footer>
</CgModal>

@* ═══════════════════  预览弹窗  ═══════════════════ *@
<CgModal IsOpen="_showPreviewModal" Title="@(_previewTitle ?? "预览")" OnClose="() => _showPreviewModal = false">
    <ChildContent>
    @if (_previewLoading)
    {
        <div class="admin-preview-loading">
            <CgProgressRing />
        </div>
    }
    else if (_previewContent != null)
    {
        <div class="admin-preview-meta">
            @if (!string.IsNullOrWhiteSpace(_previewContent.OriginalAuthor))
            {
                <span class="admin-preview-author">
                    <CgMdiIcon Name="mdiAccountOutline" aria-hidden="true" /> @_previewContent.OriginalAuthor
                </span>
            }
            @if (_previewContent.PubishTime.HasValue)
            {
                <span class="admin-preview-time">
                    <CgMdiIcon Name="mdiClockOutline" aria-hidden="true" /> @_previewContent.PubishTime.Value.ToString("yyyy-MM-dd HH:mm")
                </span>
            }
        </div>
        <CgHtmlContent Content="@_previewContent.MainPage" />
    }
    else
    {
        <CgAlert Variant="error">预览加载失败</CgAlert>
    }
    </ChildContent>
    <Footer>
        <CgButton Variant="secondary" OnClick="() => _showPreviewModal = false">关闭</CgButton>
    </Footer>
</CgModal>

@code {
    private CancellationTokenSource? _cts;
    private CgDataTable<GameNewsOverviewModel>? _gameNewsTable;
    private CgDataTable<WeeklyNewsOverviewModel>? _weeklyNewsTable;

    private readonly IReadOnlyList<CgTabItem> _tabs =
    [
        new CgTabItem("gamenews", "动态", "mdiNewspaperVariantOutline"),
        new CgTabItem("weeklynews", "周报", "mdiCalendarRange"),
    ];

    // ─── 动态编辑状态 ───
    private bool _showEditGameNewsModal;
    private bool _isAddingNews;
    private EditGameNewsModel? _editingGameNews;
    private DateTime? _gameNewsPublishTime;

    // ─── 周报编辑状态 ───
    private bool _showEditWeeklyNewsModal;
    private EditWeeklyNewsModel? _editingWeeklyNews;
    private DateTime? _weeklyNewsPublishTime;
    private DateTime? _weeklyNewsCreateTime;

    // ─── 微博导入 ───
    private bool _showWeiboModal;
    private string _weiboLink = string.Empty;

    // ─── 预览 ───
    private bool _showPreviewModal;
    private bool _previewLoading;
    private string? _previewTitle;
    private ArticleViewModel? _previewContent;

    private List<string> _allEntryNames = [];

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        try
        {
            var metaResult = await ArticleCommandService.GetArticleEditMetaOptionsAsync(_cts.Token);
            if (metaResult.Success && metaResult.Data != null)
            {
                _allEntryNames = metaResult.Data.EntryGameItems
                    .Concat(metaResult.Data.EntryRoleItems)
                    .Concat(metaResult.Data.EntryGroupItems)
                    .Concat(metaResult.Data.EntryStaffItems)
                    .Distinct()
                    .ToList();
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed, ignore
        }
    }

    // ═══════════════════  列表查询  ═══════════════════

    private async Task<CgDataTableResult<GameNewsOverviewModel>> OnQueryGameNews(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? string.Empty,
            SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };

        var result = await AdminQueryService.GetGameNewsAsync(parameter, _cts?.Token ?? CancellationToken.None);
        if (result.Success && result.Data is not null)
        {
            return new CgDataTableResult<GameNewsOverviewModel>(result.Data.Items.ToList(), result.Data.Total);
        }
        return new CgDataTableResult<GameNewsOverviewModel>([], 0);
    }

    private async Task<CgDataTableResult<WeeklyNewsOverviewModel>> OnQueryWeeklyNews(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? string.Empty,
            SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };

        var result = await AdminQueryService.GetWeeklyNewsAsync(parameter, _cts?.Token ?? CancellationToken.None);
        if (result.Success && result.Data is not null)
        {
            return new CgDataTableResult<WeeklyNewsOverviewModel>(result.Data.Items.ToList(), result.Data.Total);
        }
        return new CgDataTableResult<WeeklyNewsOverviewModel>([], 0);
    }

    // ═══════════════════  动态编辑  ═══════════════════

    private void OpenAddNewsModal(MouseEventArgs _)
    {
        _isAddingNews = true;
        _editingGameNews = new EditGameNewsModel
        {
            PublishTime = DateTime.Now,
            Type = ArticleType.News,
            Entries = new List<RelevancesModel>()
        };
        _gameNewsPublishTime = _editingGameNews.PublishTime;
        _showEditGameNewsModal = true;
    }

    private async Task OpenEditGameNewsModal(long id)
    {
        _isAddingNews = false;
        var result = await AdminQueryService.GetGameNewsEditAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success && result.Data is not null)
        {
            _editingGameNews = result.Data;
            _gameNewsPublishTime = _editingGameNews.PublishTime;
            _showEditGameNewsModal = true;
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "获取动态编辑数据失败", variant: "error");
        }
    }

    private void CloseEditGameNewsModal()
    {
        _showEditGameNewsModal = false;
        _editingGameNews = null;
    }

    private async Task SaveGameNews(MouseEventArgs _)
    {
        if (_editingGameNews == null) return;

        if (_gameNewsPublishTime.HasValue)
        {
            _editingGameNews.PublishTime = _gameNewsPublishTime.Value;
        }

        SdkResult<bool> result;
        if (_isAddingNews)
        {
            result = await AdminCommandService.AddCustomNewsAsync(_editingGameNews, _cts?.Token ?? CancellationToken.None);
        }
        else
        {
            result = await AdminCommandService.EditGameNewsAsync(_editingGameNews, _cts?.Token ?? CancellationToken.None);
        }

        if (result.Success)
        {
            ToastService.Show(_isAddingNews ? "动态添加成功" : "动态保存成功", variant: "success");
            CloseEditGameNewsModal();
            if (_gameNewsTable is not null) await _gameNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error");
        }
    }

    private async Task PublishGameNews(long id)
    {
        var result = await AdminCommandService.PublishGameNewsAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("动态发布成功", variant: "success");
            if (_gameNewsTable is not null) await _gameNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "发布失败", variant: "error");
        }
    }

    private async Task IgnoreGameNews(long id, bool isIgnore)
    {
        var result = await AdminCommandService.IgnoreGameNewsAsync(new[] { id }, isIgnore, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show(isIgnore ? "已忽略该动态" : "已恢复该动态", variant: "success");
            if (_gameNewsTable is not null) await _gameNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error");
        }
    }

    // ═══════════════════  周报编辑  ═══════════════════

    private async Task OpenEditWeeklyNewsModal(long id)
    {
        var result = await AdminQueryService.GetWeeklyNewsEditAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success && result.Data is not null)
        {
            _editingWeeklyNews = result.Data;
            _weeklyNewsPublishTime = _editingWeeklyNews.PublishTime;
            _weeklyNewsCreateTime = _editingWeeklyNews.CreateTime;
            _showEditWeeklyNewsModal = true;
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "获取周报编辑数据失败", variant: "error");
        }
    }

    private void CloseEditWeeklyNewsModal()
    {
        _showEditWeeklyNewsModal = false;
        _editingWeeklyNews = null;
    }

    private async Task SaveWeeklyNews(MouseEventArgs _)
    {
        if (_editingWeeklyNews == null) return;

        if (_weeklyNewsPublishTime.HasValue)
        {
            _editingWeeklyNews.PublishTime = _weeklyNewsPublishTime.Value;
        }
        if (_weeklyNewsCreateTime.HasValue)
        {
            _editingWeeklyNews.CreateTime = _weeklyNewsCreateTime.Value;
        }

        var result = await AdminCommandService.EditWeeklyNewsAsync(_editingWeeklyNews, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("周报保存成功", variant: "success");
            CloseEditWeeklyNewsModal();
            if (_weeklyNewsTable is not null) await _weeklyNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "保存失败", variant: "error");
        }
    }

    private async Task PublishWeeklyNews(long id)
    {
        var result = await AdminCommandService.PublishWeeklyNewsAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("周报发布成功", variant: "success");
            if (_weeklyNewsTable is not null) await _weeklyNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "发布失败", variant: "error");
        }
    }

    private async Task ResetWeeklyNewsInModal()
    {
        if (_editingWeeklyNews == null) return;
        
        var id = _editingWeeklyNews.Id;
        var result = await AdminCommandService.ResetWeeklyNewsAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("周报已重置", variant: "success");
            if (_weeklyNewsTable is not null) await _weeklyNewsTable.RefreshAsync();
            await OpenEditWeeklyNewsModal(id);
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "重置失败", variant: "error");
        }
    }

    private async Task ResetWeeklyNews(long id)
    {
        var result = await AdminCommandService.ResetWeeklyNewsAsync(id, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("周报已重置", variant: "success");
            if (_weeklyNewsTable is not null) await _weeklyNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "重置失败", variant: "error");
        }
    }

    // ═══════════════════  微博导入  ═══════════════════

    private async Task ImportWeiboNews(MouseEventArgs _)
    {
        if (string.IsNullOrWhiteSpace(_weiboLink))
        {
            ToastService.Show("请输入微博链接", variant: "warning");
            return;
        }

        var result = await AdminCommandService.AddWeiboNewsAsync(_weiboLink, _cts?.Token ?? CancellationToken.None);
        if (result.Success)
        {
            ToastService.Show("微博动态导入成功", variant: "success");
            _weiboLink = string.Empty;
            _showWeiboModal = false;
            if (_gameNewsTable is not null) await _gameNewsTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "导入失败", variant: "error");
        }
    }

    // ═══════════════════  预览  ═══════════════════

    private async Task PreviewGameNews(long id)
    {
        _previewTitle = "动态预览";
        _previewContent = null;
        _previewLoading = true;
        _showPreviewModal = true;

        var result = await AdminQueryService.GetGameNewsPreviewAsync(id, _cts?.Token ?? CancellationToken.None);
        _previewLoading = false;
        if (result.Success && result.Data is not null)
        {
            _previewContent = result.Data;
            _previewTitle = result.Data.Name ?? "动态预览";
        }
    }

    private async Task PreviewWeeklyNews(long id)
    {
        _previewTitle = "周报预览";
        _previewContent = null;
        _previewLoading = true;
        _showPreviewModal = true;

        var result = await AdminQueryService.GetWeeklyNewsPreviewAsync(id, _cts?.Token ?? CancellationToken.None);
        _previewLoading = false;
        if (result.Success && result.Data is not null)
        {
            _previewContent = result.Data;
            _previewTitle = result.Data.Name ?? "周报预览";
        }
    }

    // ═══════════════════  辅助  ═══════════════════

    private static string GetStateBadgeClass(GameNewsState state) => state switch
    {
        GameNewsState.Edit => "admin-badge--warning",
        GameNewsState.Publish => "admin-badge--visible",
        GameNewsState.Ignore => "admin-badge--hidden",
        _ => ""
    };

    private static string GetRssTypeBadgeClass(OriginalRSSType type) => type switch
    {
        OriginalRSSType.Weibo => "admin-badge--rss-weibo",
        OriginalRSSType.Bilibili => "admin-badge--rss-bilibili",
        OriginalRSSType.HeyBox => "admin-badge--rss-heybox",
        OriginalRSSType.Custom => "admin-badge--rss-custom",
        _ => "admin-badge--neutral"
    };

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
