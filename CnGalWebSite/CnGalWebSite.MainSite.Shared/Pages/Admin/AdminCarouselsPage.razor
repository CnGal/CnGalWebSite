@page "/admin/listcarousels"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAdminQueryService QueryService
@inject IAdminCommandService CommandService
@inject ICgToastService ToastService
@inject IFileCommandService FileCommandService
@implements IDisposable
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Home
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.Extensions

<CgPageMeta Title="轮播图管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiViewCarouselOutline" aria-hidden="true" />
        轮播图管理
    </h1>

    <CgDataTable TItem="CarouselOverviewModel"
                 Title="轮播图列表"
                 OnServerQuery="OnQueryAsync"
                 DefaultSortField="Id"
                 DefaultSortDesc="true"
                 @ref="_table">
        <ToolbarContent>
            <CgButton Variant="outline" OnClick="OnCreateAsync">
                <CgMdiIcon Name="mdiPlus" />
                添加轮播图
            </CgButton>
        </ToolbarContent>
        <ChildContent>
            <CgDataTableColumn TItem="CarouselOverviewModel" Title="ID" Field="Id" Width="100px" />
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="展示图" Width="160px">
            <ChildContent Context="context">
                <img src="@context.Image" alt="轮播图" style="max-height: 40px; border-radius: 4px;" />
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="类型" Width="120px">
            <ChildContent Context="context">
                <span class="admin-badge @GetTypeColor(context.Type)">@context.Type.GetDisplayName()</span>
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="外部链接" Field="Link" />
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="备注" Field="Note" />
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="权重" Field="Priority" Sortable="true" Width="100px" />
        <CgDataTableColumn TItem="CarouselOverviewModel" Title="操作" Width="140px">
            <ChildContent Context="context">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="增加权重" @onclick="() => OnEditPriorityAsync(context, 1)"><CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" /></button>
                    <button class="admin-action-btn admin-action-btn--down" title="降低权重" @onclick="() => OnEditPriorityAsync(context, -1)"><CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" /></button>
                    <button class="admin-action-btn admin-action-btn--edit" title="编辑" @onclick="() => OnEditAsync(context)"><CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" /></button>
                </div>
            </ChildContent>
        </CgDataTableColumn>
        </ChildContent>
    </CgDataTable>
</div>

<CgModal IsOpen="_showEditModal" OnClose="() => _showEditModal = false" Title="@(_isNew ? "添加轮播图" : "编辑轮播图")">
    <ChildContent>
        <CgFormSection Flat>
            @if (_editModel != null)
            {
                <CgFormGroup Label="图片" Required="true">
                    <CgImageUpload @bind-Value="_editModel.Image"
                                   OnUploadImageAsync="FileCommandService.UploadImageAsync" />
                </CgFormGroup>
                
                <CgFormGroup Label="类型">
                    <CgEnumSelect TEnum="CarouselType" @bind-Value="_editModel.Type" />
                </CgFormGroup>

                <CgFormGroup Label="外部链接">
                    <CgInput @bind-Value="_editModel.Link" Placeholder="跳转链接" />
                </CgFormGroup>

                <CgFormGroup Label="备注">
                    <CgInput @bind-Value="_editModel.Note" Placeholder="图片说明信息" />
                </CgFormGroup>

                <CgFormGroup Label="权重">
                    <CgInput @bind-Value="_editModel.Priority" />
                </CgFormGroup>
            }
            else
            {
                <div class="admin-loading-state">
                    <CgProgressRing />
                    <span class="admin-loading-state__text">正在加载...</span>
                </div>
            }
        </CgFormSection>
    </ChildContent>
    <Footer>
        <div class="admin-modal-footer">
            <CgButton Variant="secondary" OnClick="() => _showEditModal = false">取消</CgButton>
            <CgButton Variant="primary" Async OnClick="SaveAsync">保存</CgButton>
        </div>
    </Footer>
</CgModal>

@code {
    private CgDataTable<CarouselOverviewModel>? _table;
    private bool _showEditModal;
    private bool _isNew;
    private CarouselEditModel? _editModel;
    private CancellationTokenSource? _cts = new();

    private async Task<CgDataTableResult<CarouselOverviewModel>> OnQueryAsync(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? string.Empty,
            SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };

        try
        {
            var result = await QueryService.GetCarouselsAsync(parameter, _cts!.Token);
            if (result.Success && result.Data != null)
            {
                return new CgDataTableResult<CarouselOverviewModel>(result.Data.Items.ToList(), result.Data.Total);
            }

            ToastService.Show(result.Error?.Message ?? "获取轮播图列表失败", variant: "error");
            return new CgDataTableResult<CarouselOverviewModel>([], 0);
        }
        catch (OperationCanceledException)
        {
            return new CgDataTableResult<CarouselOverviewModel>([], 0);
        }
    }

    private async Task OnEditPriorityAsync(CarouselOverviewModel model, int plusPriority)
    {
        try
        {
            var result = await CommandService.EditCarouselPriorityAsync([model.Id], plusPriority, _cts!.Token);
            if (result.Success)
            {
                ToastService.Show("已更新轮播图权重", variant: "success");
                if (_table != null)
                {
                    await _table.RefreshAsync();
                }
            }
            else
            {
                ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error");
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnCreateAsync()
    {
        _isNew = true;
        _editModel = new CarouselEditModel();
        _showEditModal = true;
        await Task.CompletedTask;
    }

    private async Task OnEditAsync(CarouselOverviewModel model)
    {
        _isNew = false;
        _editModel = null;
        _showEditModal = true;
        StateHasChanged();

        try
        {
            var result = await QueryService.GetCarouselEditAsync(model.Id, _cts!.Token);
            if (result.Success && result.Data != null)
            {
                _editModel = result.Data;
                StateHasChanged();
            }
            else
            {
                ToastService.Show(result.Error?.Message ?? "获取详情失败", variant: "error");
                _showEditModal = false;
            }
        }
        catch (OperationCanceledException)
        {
            _showEditModal = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_editModel == null) return;
        
        try
        {
            var result = await CommandService.EditCarouselAsync(_editModel, _cts!.Token);
            if (result.Success)
            {
                ToastService.Show("轮播图基本信息已保存", variant: "success");
                _showEditModal = false;
                if (_table != null)
                {
                    await _table.RefreshAsync();
                }
            }
            else
            {
                ToastService.Show(result.Error?.Message ?? "保存失败", variant: "error");
            }
        }
        catch (OperationCanceledException) { }
    }

    private string GetTypeColor(CarouselType type)
    {
        return type switch
        {
            CarouselType.Activity => "admin-badge--visible",
            CarouselType.AdvertisingPC => "admin-badge--warning",
            CarouselType.AdvertisingApp => "admin-badge--hidden",
            _ => "admin-badge--neutral"
        };
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
