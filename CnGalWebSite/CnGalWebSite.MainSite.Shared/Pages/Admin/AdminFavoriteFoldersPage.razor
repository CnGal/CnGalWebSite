@page "/admin/listfavoritefolders"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@inject NavigationManager NavigationManager
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Favorites

<PageTitle>收藏夹管理 - CnGal</PageTitle>

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiBookmarkMultipleOutline" aria-hidden="true" />
        收藏夹管理
    </h1>

    <CgDataTable TItem="FavoriteFolderOverviewModel"
                 Title="收藏夹列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true">
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="名称" Field="Name" />
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="图片" Sortable="false" Width="80px">
            <ChildContent Context="item">
                @if (!string.IsNullOrWhiteSpace(item.MainImage))
                {
                    <img src="@item.MainImage" alt="收藏夹图片" style="max-width: 60px; max-height: 40px; border-radius: 4px; object-fit: cover;" />
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="用户" Field="UserName">
            <ChildContent Context="item"><span class="admin-cell-name">@item.UserName</span></ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="创建时间" Field="CreateTime">
            <ChildContent Context="item">@item.CreateTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="数量" Field="Count" Width="80px" />
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                else { <span class="admin-badge admin-badge--visible">可见</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="公开" Field="ShowPublicly">
            <ChildContent Context="item">
                @if (item.ShowPublicly) { <span class="admin-badge admin-badge--yes">公开</span> }
                else { <span class="admin-badge admin-badge--no">私密</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="默认" Field="IsDefault">
            <ChildContent Context="item">
                @if (item.IsDefault) { <span class="admin-badge admin-badge--info">默认</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="FavoriteFolderOverviewModel" Title="操作" Sortable="false" Width="100px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--show" title="查看"
                            @onclick="@(() => NavigationManager.NavigateTo($"/favoritefolders/index/{item.Id}"))">
                        <CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" />
                    </button>
                    <button class="admin-action-btn admin-action-btn--up" title="编辑"
                            @onclick="@(() => NavigationManager.NavigateTo($"/space/EditSpaceFavoriteObjects?UserId={item.UserId}&amp;FolderId={item.Id}"))">
                        <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                    </button>
                </div>
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private async Task<CgDataTableResult<FavoriteFolderOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetFavoriteFoldersAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<FavoriteFolderOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<FavoriteFolderOverviewModel>([], 0);
    }
}
