@page "/admin/listmessages"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Admin

<PageTitle>消息管理 - CnGal</PageTitle>

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiEmailOutline" aria-hidden="true" />
        消息管理
    </h1>

    <CgDataTable TItem="MessageOverviewModel"
                 Title="消息列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true">
        <CgDataTableColumn TItem="MessageOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="MessageOverviewModel" Title="标题" Field="Title" />
        <CgDataTableColumn TItem="MessageOverviewModel" Title="内容" Field="Text">
            <ChildContent Context="item"><div class="admin-cell-text">@item.Text</div></ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="MessageOverviewModel" Title="用户" Field="UserName">
            <ChildContent Context="item"><span class="admin-cell-name">@item.UserName</span></ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="MessageOverviewModel" Title="发送时间" Field="PostTime">
            <ChildContent Context="item">@item.PostTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="MessageOverviewModel" Title="已读" Field="IsReaded">
            <ChildContent Context="item">
                @if (item.IsReaded) { <span class="admin-badge admin-badge--yes">已读</span> }
                else { <span class="admin-badge admin-badge--no">未读</span> }
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private async Task<CgDataTableResult<MessageOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetMessagesAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<MessageOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<MessageOverviewModel>([], 0);
    }
}
