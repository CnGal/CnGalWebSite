@page "/admin/listentries"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.PlayedGames
@using CnGalWebSite.DataModel.ViewModel.Entries
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.Extensions

<CgPageMeta Title="词条管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiBookOpenPageVariantOutline" aria-hidden="true" />
        词条管理
    </h1>

    <CgTabs Items="@_tabs"
            DefaultActiveKey="entries"
            Variant="underline"
            AriaLabel="词条管理"
            Id="admin-entries-tabs">
        <PanelTemplate>
            @if (context == "entries")
            {
                <CgDataTable TItem="EntryOverviewModel"
                             Title="词条列表"
                             OnServerQuery="OnServerQuery"
                             DefaultSortField="Id"
                             DefaultSortDesc="true"
                             @ref="_dataTable">
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="Id" Field="Id" Width="80px" />
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="名称" Field="Name">
                        <ChildContent Context="item">
                            <a class="admin-cell-name" href="@($"/entries/index/{item.Id}")">@item.Name</a>
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="优先级" Field="Priority" Width="80px" />
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="状态" Field="IsHidden">
                        <ChildContent Context="item">
                            @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                            else { <span class="admin-badge admin-badge--visible">可见</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="外链" Field="IsHideOutlink">
                        <ChildContent Context="item">
                            @if (item.IsHideOutlink) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                            else { <span class="admin-badge admin-badge--visible">可见</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="留言板" Field="CanComment">
                        <ChildContent Context="item">
                            @if (item.CanComment) { <span class="admin-badge admin-badge--yes">开启</span> }
                            else { <span class="admin-badge admin-badge--no">关闭</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryOverviewModel" Title="操作" Sortable="false" Width="180px">
                        <ChildContent Context="item">
                            <div class="admin-actions">
                                <button class="admin-action-btn admin-action-btn--up" title="增加权重" @onclick="() => EditPriority(item, true)"><CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" /></button>
                                <button class="admin-action-btn admin-action-btn--down" title="降低权重" @onclick="() => EditPriority(item, false)"><CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" /></button>
                                @if (item.IsHideOutlink)
                                { <button class="admin-action-btn admin-action-btn--link" title="显示外链" @onclick="() => ToggleOutlink(item, false)"><CgMdiIcon Name="mdiLinkVariant" aria-hidden="true" /></button> }
                                else
                                { <button class="admin-action-btn admin-action-btn--hide" title="隐藏外链" @onclick="() => ToggleOutlink(item, true)"><CgMdiIcon Name="mdiLinkVariantOff" aria-hidden="true" /></button> }
                                @if (item.CanComment)
                                { <button class="admin-action-btn admin-action-btn--nocomment" title="关闭留言板" @onclick="() => ToggleCanComment(item, false)"><CgMdiIcon Name="mdiCommentRemoveOutline" aria-hidden="true" /></button> }
                                else
                                { <button class="admin-action-btn admin-action-btn--comment" title="开启留言板" @onclick="() => ToggleCanComment(item, true)"><CgMdiIcon Name="mdiCommentCheckOutline" aria-hidden="true" /></button> }
                                @if (item.IsHidden)
                                { <button class="admin-action-btn admin-action-btn--show" title="显示词条" @onclick="() => ToggleHidden(item, false)"><CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" /></button> }
                                else
                                { <button class="admin-action-btn admin-action-btn--hide" title="隐藏词条" @onclick="() => ToggleHidden(item, true)"><CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /></button> }
                            </div>
                        </ChildContent>
                    </CgDataTableColumn>
                </CgDataTable>
            }
            else if (context == "playedgames")
            {
                <CgDataTable TItem="GameRecordOverviewModel"
                             Title="游玩记录列表"
                             OnServerQuery="OnQueryPlayedGames"
                             DefaultSortField="Id"
                             DefaultSortDesc="true"
                             @ref="_playedGameTable">
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="Id" Field="Id" Width="80px" />
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="游戏" Field="GameName">
                        <ChildContent Context="item">
                            @if (item.GameId > 0)
                            { <a class="admin-cell-name" href="@($"/entries/index/{item.GameId}")">@item.GameName</a> }
                            else { <span>@item.GameName</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="用户" Field="UserName">
                        <ChildContent Context="item">
                            <a class="admin-cell-name" href="@($"/space/index/{item.UserId}")">@item.UserName</a>
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="类型" Field="Type">
                        <ChildContent Context="item"><span class="admin-badge">@item.Type</span></ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="总分" Field="TotalSocre" Width="80px" />
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="评语" Field="PlayImpressions" Sortable="false">
                        <ChildContent Context="item">
                            <div class="admin-cell-text">@item.PlayImpressions</div>
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="公开" Field="ShowPublicly">
                        <ChildContent Context="item">
                            @if (item.ShowPublicly) { <span class="admin-badge admin-badge--yes">公开</span> }
                            else { <span class="admin-badge admin-badge--no">私密</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="状态" Field="IsHidden">
                        <ChildContent Context="item">
                            @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                            else { <span class="admin-badge admin-badge--visible">可见</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="最后编辑" Field="LastEditTime">
                        <ChildContent Context="item">@item.LastEditTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="GameRecordOverviewModel" Title="操作" Sortable="false" Width="120px">
                        <ChildContent Context="item">
                            <div class="admin-actions">
                                @if (item.ShowPublicly)
                                { <button class="admin-action-btn admin-action-btn--hide" title="设为私密" @onclick="() => ToggleShowPublicly(item, false)"><CgMdiIcon Name="mdiLinkVariantOff" aria-hidden="true" /></button> }
                                else
                                { <button class="admin-action-btn admin-action-btn--link" title="设为公开" @onclick="() => ToggleShowPublicly(item, true)"><CgMdiIcon Name="mdiLinkVariant" aria-hidden="true" /></button> }
                                @if (item.IsHidden)
                                { <button class="admin-action-btn admin-action-btn--show" title="显示记录" @onclick="() => TogglePlayedGameHidden(item, false)"><CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" /></button> }
                                else
                                { <button class="admin-action-btn admin-action-btn--hide" title="隐藏记录" @onclick="() => TogglePlayedGameHidden(item, true)"><CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /></button> }
                            </div>
                        </ChildContent>
                    </CgDataTableColumn>
                </CgDataTable>
            }
            else if (context == "infotypes")
            {
                <CgDataTable TItem="EntryInformationTypeOverviewModel"
                             Title="基础信息类型列表"
                             OnServerQuery="OnQueryInfoTypes"
                             DefaultSortField="Id"
                             DefaultSortDesc="true"
                             @ref="_infoTypeTable">
                    <ToolbarContent>
                        <CgButton Variant="outline" OnClick="OnCreateInfoTypeAsync">
                            <CgMdiIcon Name="mdiPlus" />
                            添加基础信息类型
                        </CgButton>
                    </ToolbarContent>
                    <ChildContent>
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="Id" Field="Id" Width="80px" />
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="名称" Field="Name" />
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="介绍" Field="Description">
                        <ChildContent Context="item"><div class="admin-cell-text">@item.Description</div></ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="图标" Field="Icon" Width="80px">
                        <ChildContent Context="item">
                            @if (!string.IsNullOrWhiteSpace(item.Icon))
                            { <CgMdiIcon Name="@item.Icon" aria-hidden="true" /> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="支持类型" Sortable="false">
                        <ChildContent Context="item">
                            @foreach (var t in item.Types)
                            {
                                <span class="admin-badge" style="margin-right: 4px;">@t.GetDisplayName()</span>
                            }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="状态" Field="IsHidden">
                        <ChildContent Context="item">
                            @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                            else { <span class="admin-badge admin-badge--visible">可见</span> }
                        </ChildContent>
                    </CgDataTableColumn>
                    <CgDataTableColumn TItem="EntryInformationTypeOverviewModel" Title="操作" Sortable="false" Width="60px">
                        <ChildContent Context="item">
                            <div class="admin-actions">
                                <button class="admin-action-btn admin-action-btn--edit" title="编辑" @onclick="() => OnEditInfoTypeAsync(item)"><CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" /></button>
                            </div>
                        </ChildContent>
                    </CgDataTableColumn>
                    </ChildContent>
                </CgDataTable>
            }
        </PanelTemplate>
    </CgTabs>
</div>

<CgModal IsOpen="_showInfoTypeModal" OnClose="() => _showInfoTypeModal = false" Title="@(_isNewInfoType ? "添加基础信息类型" : "编辑基础信息类型")">
    <ChildContent>
        <CgFormSection Flat>
            @if (_infoTypeEditModel != null)
            {
                <CgFormGroup Label="名称" Required="true">
                    <CgInput @bind-Value="_infoTypeEditModel.Name" Placeholder="类型名称" />
                </CgFormGroup>

                <CgFormGroup Label="介绍">
                    <CgInput @bind-Value="_infoTypeEditModel.Description" Placeholder="类型说明" />
                </CgFormGroup>

                <CgFormGroup Label="图标">
                    <CgInput @bind-Value="_infoTypeEditModel.Icon" Placeholder="MDI 图标名称" />
                </CgFormGroup>

                <CgFormGroup Label="是否隐藏">
                    <CgCheckbox @bind-Value="_infoTypeEditModel.IsHidden" Label="隐藏此类型" />
                </CgFormGroup>

                <CgFormGroup Label="支持的词条类型">
                    @foreach (var entryType in Enum.GetValues<EntryType>())
                    {
                        <CgCheckbox Value="_infoTypeEditModel.Types.Contains(entryType)"
                                    ValueChanged="v => ToggleEntryType(entryType, v)"
                                    Label="@entryType.GetDisplayName()" />
                    }
                </CgFormGroup>
            }
            else
            {
                <div class="admin-loading-state">
                    <CgProgressRing />
                    <span class="admin-loading-state__text">正在加载...</span>
                </div>
            }
        </CgFormSection>
    </ChildContent>
    <Footer>
        <div class="admin-modal-footer">
            <CgButton Variant="secondary" OnClick="() => _showInfoTypeModal = false">取消</CgButton>
            <CgButton Variant="primary" Async OnClick="SaveInfoTypeAsync">保存</CgButton>
        </div>
    </Footer>
</CgModal>

@code {
    private CgDataTable<EntryOverviewModel>? _dataTable;
    private CgDataTable<GameRecordOverviewModel>? _playedGameTable;
    private CgDataTable<EntryInformationTypeOverviewModel>? _infoTypeTable;
    private bool _showInfoTypeModal;
    private bool _isNewInfoType;
    private EntryInformationTypeEditModel? _infoTypeEditModel;

    private readonly IReadOnlyList<CgTabItem> _tabs =
    [
        new CgTabItem("entries", "词条", "mdiBookOpenPageVariantOutline"),
        new CgTabItem("playedgames", "游玩记录", "mdiGamepadVariantOutline"),
        new CgTabItem("infotypes", "基础信息类型", "mdiTagOutline"),
    ];

    // ─── 词条查询 ───

    private async Task<CgDataTableResult<EntryOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetEntriesAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<EntryOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<EntryOverviewModel>([], 0);
    }

    // ─── 游玩记录查询 ───

    private async Task<CgDataTableResult<GameRecordOverviewModel>> OnQueryPlayedGames(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetPlayedGamesAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<GameRecordOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<GameRecordOverviewModel>([], 0);
    }

    // ─── 基础信息类型查询 ───

    private async Task<CgDataTableResult<EntryInformationTypeOverviewModel>> OnQueryInfoTypes(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetEntryInformationTypesAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<EntryInformationTypeOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<EntryInformationTypeOverviewModel>([], 0);
    }

    // ─── 词条操作 ───

    private async Task EditPriority(EntryOverviewModel item, bool up) { var r = await AdminCommandService.EditEntryPriorityAsync(new[] { item.Id }, up ? 1 : -1); await HandleResult(r, up ? "已增加权重" : "已降低权重"); }
    private async Task ToggleHidden(EntryOverviewModel item, bool hide) { var r = await AdminCommandService.HideEntryAsync(new[] { item.Id }, hide); await HandleResult(r, hide ? "已隐藏词条" : "已显示词条"); }
    private async Task ToggleOutlink(EntryOverviewModel item, bool hide) { var r = await AdminCommandService.HideEntryOutlinkAsync(new[] { item.Id }, hide); await HandleResult(r, hide ? "已隐藏外链" : "已显示外链"); }
    private async Task ToggleCanComment(EntryOverviewModel item, bool canComment) { var r = await AdminCommandService.EditEntryCanCommentAsync(new[] { item.Id }, canComment); await HandleResult(r, canComment ? "已开启留言板" : "已关闭留言板"); }

    // ─── 游玩记录操作 ───

    private async Task TogglePlayedGameHidden(GameRecordOverviewModel item, bool hide)
    {
        var r = await AdminCommandService.HidePlayedGameAsync(new[] { item.Id }, hide);
        await HandlePlayedGameResult(r, hide ? "已隐藏记录" : "已显示记录");
    }

    private async Task ToggleShowPublicly(GameRecordOverviewModel item, bool showPublicly)
    {
        var r = await AdminCommandService.ShowPubliclyPlayedGameAsync(new[] { item.Id }, showPublicly);
        await HandlePlayedGameResult(r, showPublicly ? "已设为公开" : "已设为私密");
    }

    private async Task HandlePlayedGameResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success) { ToastService.Show(successMessage, variant: "success"); if (_playedGameTable is not null) await _playedGameTable.RefreshAsync(); }
        else { ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error"); }
    }

    private async Task HandleResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success) { ToastService.Show(successMessage, variant: "success"); if (_dataTable is not null) await _dataTable.RefreshAsync(); }
        else { ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error"); }
    }

    // ─── 基础信息类型 CRUD ───

    private async Task OnCreateInfoTypeAsync()
    {
        _isNewInfoType = true;
        _infoTypeEditModel = new EntryInformationTypeEditModel();
        _showInfoTypeModal = true;
        await Task.CompletedTask;
    }

    private async Task OnEditInfoTypeAsync(EntryInformationTypeOverviewModel model)
    {
        _isNewInfoType = false;
        _infoTypeEditModel = null;
        _showInfoTypeModal = true;
        StateHasChanged();

        var result = await AdminQueryService.GetEntryInformationTypeEditAsync(model.Id);
        if (result.Success && result.Data != null)
        {
            _infoTypeEditModel = result.Data;
            StateHasChanged();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "获取详情失败", variant: "error");
            _showInfoTypeModal = false;
        }
    }

    private async Task SaveInfoTypeAsync()
    {
        if (_infoTypeEditModel == null) return;

        var result = await AdminCommandService.EditEntryInformationTypeAsync(_infoTypeEditModel);
        if (result.Success)
        {
            ToastService.Show("基础信息类型已保存", variant: "success");
            _showInfoTypeModal = false;
            if (_infoTypeTable != null)
            {
                await _infoTypeTable.RefreshAsync();
            }
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "保存失败", variant: "error");
        }
    }

    private void ToggleEntryType(EntryType type, bool isChecked)
    {
        if (_infoTypeEditModel == null) return;
        if (isChecked && !_infoTypeEditModel.Types.Contains(type))
        {
            _infoTypeEditModel.Types.Add(type);
        }
        else if (!isChecked)
        {
            _infoTypeEditModel.Types.Remove(type);
        }
    }
}
