@page "/admin/listentries"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Admin

<PageTitle>词条管理 - CnGal</PageTitle>

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiBookOpenPageVariantOutline" aria-hidden="true" />
        词条管理
    </h1>

    <CgDataTable TItem="EntryOverviewModel"
                 Title="词条列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true"
                 @ref="_dataTable">
        <CgDataTableColumn TItem="EntryOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="EntryOverviewModel" Title="名称" Field="Name">
            <ChildContent Context="item">
                <a class="admin-cell-name" href="@($"/entries/index/{item.Id}")">@item.Name</a>
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="EntryOverviewModel" Title="优先级" Field="Priority" Width="80px" />
        <CgDataTableColumn TItem="EntryOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden)
                {
                    <span class="admin-badge admin-badge--hidden">已隐藏</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--visible">可见</span>
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="EntryOverviewModel" Title="外链" Field="IsHideOutlink">
            <ChildContent Context="item">
                @if (item.IsHideOutlink)
                {
                    <span class="admin-badge admin-badge--hidden">已隐藏</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--visible">可见</span>
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="EntryOverviewModel" Title="留言板" Field="CanComment">
            <ChildContent Context="item">
                @if (item.CanComment)
                {
                    <span class="admin-badge admin-badge--yes">开启</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--no">关闭</span>
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="EntryOverviewModel" Title="操作" Sortable="false" Width="180px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="增加权重"
                            @onclick="() => EditPriority(item, true)">
                        <CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" />
                    </button>
                    <button class="admin-action-btn admin-action-btn--down" title="降低权重"
                            @onclick="() => EditPriority(item, false)">
                        <CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" />
                    </button>
                    @if (item.IsHideOutlink)
                    {
                        <button class="admin-action-btn admin-action-btn--link" title="显示外链"
                                @onclick="() => ToggleOutlink(item, false)">
                            <CgMdiIcon Name="mdiLinkVariant" aria-hidden="true" />
                        </button>
                    }
                    else
                    {
                        <button class="admin-action-btn admin-action-btn--hide" title="隐藏外链"
                                @onclick="() => ToggleOutlink(item, true)">
                            <CgMdiIcon Name="mdiLinkVariantOff" aria-hidden="true" />
                        </button>
                    }
                    @if (item.CanComment)
                    {
                        <button class="admin-action-btn admin-action-btn--nocomment" title="关闭留言板"
                                @onclick="() => ToggleCanComment(item, false)">
                            <CgMdiIcon Name="mdiCommentRemoveOutline" aria-hidden="true" />
                        </button>
                    }
                    else
                    {
                        <button class="admin-action-btn admin-action-btn--comment" title="开启留言板"
                                @onclick="() => ToggleCanComment(item, true)">
                            <CgMdiIcon Name="mdiCommentCheckOutline" aria-hidden="true" />
                        </button>
                    }
                    @if (item.IsHidden)
                    {
                        <button class="admin-action-btn admin-action-btn--show" title="显示词条"
                                @onclick="() => ToggleHidden(item, false)">
                            <CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" />
                        </button>
                    }
                    else
                    {
                        <button class="admin-action-btn admin-action-btn--hide" title="隐藏词条"
                                @onclick="() => ToggleHidden(item, true)">
                            <CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" />
                        </button>
                    }
                </div>
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private CgDataTable<EntryOverviewModel>? _dataTable;

    private async Task<CgDataTableResult<EntryOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? string.Empty,
            SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };

        var result = await AdminQueryService.GetEntriesAsync(parameter);
        if (result.Success && result.Data is not null)
        {
            return new CgDataTableResult<EntryOverviewModel>(result.Data.Items.ToList(), result.Data.Total);
        }
        return new CgDataTableResult<EntryOverviewModel>([], 0);
    }

    private async Task EditPriority(EntryOverviewModel item, bool up)
    {
        var result = await AdminCommandService.EditEntryPriorityAsync(new[] { item.Id }, up ? 1 : -1);
        await HandleResult(result, up ? "已增加权重" : "已降低权重");
    }

    private async Task ToggleHidden(EntryOverviewModel item, bool hide)
    {
        var result = await AdminCommandService.HideEntryAsync(new[] { item.Id }, hide);
        await HandleResult(result, hide ? "已隐藏词条" : "已显示词条");
    }

    private async Task ToggleOutlink(EntryOverviewModel item, bool hide)
    {
        var result = await AdminCommandService.HideEntryOutlinkAsync(new[] { item.Id }, hide);
        await HandleResult(result, hide ? "已隐藏外链" : "已显示外链");
    }

    private async Task ToggleCanComment(EntryOverviewModel item, bool canComment)
    {
        var result = await AdminCommandService.EditEntryCanCommentAsync(new[] { item.Id }, canComment);
        await HandleResult(result, canComment ? "已开启留言板" : "已关闭留言板");
    }

    private async Task HandleResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success)
        {
            ToastService.Show(successMessage, variant: "success");
            if (_dataTable is not null) await _dataTable.RefreshAsync();
        }
        else
        {
            ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error");
        }
    }
}
