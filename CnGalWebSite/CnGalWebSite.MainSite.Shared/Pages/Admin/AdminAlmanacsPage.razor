@page "/admin/listalmanacs"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAdminQueryService AdminQueryService
@inject NavigationManager NavigationManager
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Almanacs

<CgPageMeta Title="年鉴管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiCalendarTextOutline" aria-hidden="true" />
        年鉴管理
    </h1>

    <CgDataTable TItem="AlmanacOverviewModel"
                 Title="年鉴列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true">
        <ToolbarContent>
            <CgButton Variant="outline" OnClick="@(() => NavigationManager.NavigateTo("/almanac/edit"))">
                <CgMdiIcon Name="mdiPlus" />
                添加年鉴
            </CgButton>
        </ToolbarContent>
        <ChildContent>
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="年份" Field="Year" Width="80px" />
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="名称" Field="Name" />
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="简介" Field="BriefIntroduction">
            <ChildContent Context="item">
                <div class="admin-cell-text">@item.BriefIntroduction</div>
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="词条数" Field="EntryCount" Sortable="false" Width="80px" />
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="文章数" Field="ArticleCount" Sortable="false" Width="80px" />
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="更新时间" Field="UpdateTime">
            <ChildContent Context="item">
                @item.UpdateTime.ToString("yyyy-MM-dd HH:mm")
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="AlmanacOverviewModel" Title="操作" Sortable="false" Width="100px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="编辑"
                            @onclick="@(() => NavigationManager.NavigateTo($"/almanac/edit/{item.Id}"))">
                        <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                    </button>
                    <button class="admin-action-btn admin-action-btn--show" title="查看"
                            @onclick="@(() => NavigationManager.NavigateTo($"/almanac/{item.Id}"))">
                        <CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" />
                    </button>
                </div>
            </ChildContent>
        </CgDataTableColumn>
        </ChildContent>
    </CgDataTable>
</div>

@code {
    private async Task<CgDataTableResult<AlmanacOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetAlmanacsAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<AlmanacOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<AlmanacOverviewModel>([], 0);
    }
}
