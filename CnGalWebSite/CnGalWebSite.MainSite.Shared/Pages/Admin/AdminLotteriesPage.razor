@page "/admin/listlotteries"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Lotteries

<CgPageMeta Title="抽奖管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiGiftOutline" aria-hidden="true" />
        抽奖管理
    </h1>

    <CgDataTable TItem="LotteryOverviewModel" Title="抽奖列表" OnServerQuery="OnServerQuery" DefaultSortField="Id" DefaultSortDesc="true" @ref="_dataTable">
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="名称" Field="Name">
            <ChildContent Context="item"><a class="admin-cell-name" href="@($"/lotteries/index/{item.Id}")">@item.Name</a></ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="抽奖时间" Field="LotteryTime">
            <ChildContent Context="item">@(item.LotteryTime.Year == 1 ? "无" : item.LotteryTime.ToString("yyyy-MM-dd HH:mm"))</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="开始时间" Field="BeginTime">
            <ChildContent Context="item">@item.BeginTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="结束时间" Field="EndTime">
            <ChildContent Context="item">@item.EndTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="优先级" Field="Priority" Width="80px" />
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="已结束" Field="IsEnd">
            <ChildContent Context="item">
                @if (item.IsEnd) { <span class="admin-badge admin-badge--hidden">已结束</span> }
                else { <span class="admin-badge admin-badge--visible">进行中</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                else { <span class="admin-badge admin-badge--visible">可见</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="LotteryOverviewModel" Title="操作" Sortable="false" Width="150px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="增加权重" @onclick="() => EditPriority(item, true)"><CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" /></button>
                    <button class="admin-action-btn admin-action-btn--down" title="降低权重" @onclick="() => EditPriority(item, false)"><CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" /></button>
                    @if (item.CanComment) { <button class="admin-action-btn admin-action-btn--nocomment" title="关闭留言板" @onclick="() => ToggleCanComment(item, false)"><CgMdiIcon Name="mdiCommentRemoveOutline" aria-hidden="true" /></button> }
                    else { <button class="admin-action-btn admin-action-btn--comment" title="开启留言板" @onclick="() => ToggleCanComment(item, true)"><CgMdiIcon Name="mdiCommentCheckOutline" aria-hidden="true" /></button> }
                    @if (item.IsHidden) { <button class="admin-action-btn admin-action-btn--show" title="显示" @onclick="() => ToggleHidden(item, false)"><CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" /></button> }
                    else { <button class="admin-action-btn admin-action-btn--hide" title="隐藏" @onclick="() => ToggleHidden(item, true)"><CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /></button> }
                </div>
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private CgDataTable<LotteryOverviewModel>? _dataTable;

    private async Task<CgDataTableResult<LotteryOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetLotteriesAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<LotteryOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<LotteryOverviewModel>([], 0);
    }

    private async Task EditPriority(LotteryOverviewModel item, bool up) { var r = await AdminCommandService.EditLotteryPriorityAsync(new[] { item.Id }, up ? 1 : -1); await HandleResult(r, up ? "已增加权重" : "已降低权重"); }
    private async Task ToggleHidden(LotteryOverviewModel item, bool hide) { var r = await AdminCommandService.HideLotteryAsync(new[] { item.Id }, hide); await HandleResult(r, hide ? "已隐藏" : "已显示"); }
    private async Task ToggleCanComment(LotteryOverviewModel item, bool canComment) { var r = await AdminCommandService.EditLotteryCanCommentAsync(new[] { item.Id }, canComment); await HandleResult(r, canComment ? "已开启留言板" : "已关闭留言板"); }

    private async Task HandleResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success) { ToastService.Show(successMessage, variant: "success"); if (_dataTable is not null) await _dataTable.RefreshAsync(); }
        else { ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error"); }
    }
}
