@page "/admin/listarticles"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Admin

<CgPageMeta Title="文章管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiNoteTextOutline" aria-hidden="true" />
        文章管理
    </h1>

    <CgDataTable TItem="ArticleOverviewModel"
                 Title="文章列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true"
                 @ref="_dataTable">
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="名称" Field="Name">
            <ChildContent Context="item">
                <a class="admin-cell-name" href="@($"/articles/index/{item.Id}")">@item.Name</a>
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="创建时间" Field="CreateTime">
            <ChildContent Context="item">
                @item.CreateTime.ToString("yyyy-MM-dd HH:mm")
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="最后编辑" Field="LastEditTime">
            <ChildContent Context="item">
                @item.LastEditTime.ToString("yyyy-MM-dd HH:mm")
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="优先级" Field="Priority" Width="80px" />
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden)
                {
                    <span class="admin-badge admin-badge--hidden">已隐藏</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--visible">可见</span>
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="留言板" Field="CanComment">
            <ChildContent Context="item">
                @if (item.CanComment)
                {
                    <span class="admin-badge admin-badge--yes">开启</span>
                }
                else
                {
                    <span class="admin-badge admin-badge--no">关闭</span>
                }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="ArticleOverviewModel" Title="操作" Sortable="false" Width="150px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="增加权重"
                            @onclick="() => EditPriority(item, true)">
                        <CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" />
                    </button>
                    <button class="admin-action-btn admin-action-btn--down" title="降低权重"
                            @onclick="() => EditPriority(item, false)">
                        <CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" />
                    </button>
                    @if (item.CanComment)
                    {
                        <button class="admin-action-btn admin-action-btn--nocomment" title="关闭留言板"
                                @onclick="() => ToggleCanComment(item, false)">
                            <CgMdiIcon Name="mdiCommentRemoveOutline" aria-hidden="true" />
                        </button>
                    }
                    else
                    {
                        <button class="admin-action-btn admin-action-btn--comment" title="开启留言板"
                                @onclick="() => ToggleCanComment(item, true)">
                            <CgMdiIcon Name="mdiCommentCheckOutline" aria-hidden="true" />
                        </button>
                    }
                    @if (item.IsHidden)
                    {
                        <button class="admin-action-btn admin-action-btn--show" title="显示"
                                @onclick="() => ToggleHidden(item, false)">
                            <CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" />
                        </button>
                    }
                    else
                    {
                        <button class="admin-action-btn admin-action-btn--hide" title="隐藏"
                                @onclick="() => ToggleHidden(item, true)">
                            <CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" />
                        </button>
                    }
                </div>
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private CgDataTable<ArticleOverviewModel>? _dataTable;

    private async Task<CgDataTableResult<ArticleOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel
        {
            Page = request.Page,
            ItemsPerPage = request.PageSize,
            SearchText = request.SearchText ?? string.Empty,
            SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField },
            SortDesc = new[] { request.SortDesc }
        };
        var result = await AdminQueryService.GetArticlesAsync(parameter);
        return result.Success && result.Data is not null
            ? new CgDataTableResult<ArticleOverviewModel>(result.Data.Items.ToList(), result.Data.Total)
            : new CgDataTableResult<ArticleOverviewModel>([], 0);
    }

    private async Task EditPriority(ArticleOverviewModel item, bool up)
    {
        var r = await AdminCommandService.EditArticlePriorityAsync(new[] { item.Id }, up ? 1 : -1);
        await HandleResult(r, up ? "已增加权重" : "已降低权重");
    }

    private async Task ToggleHidden(ArticleOverviewModel item, bool hide)
    {
        var r = await AdminCommandService.HideArticleAsync(new[] { item.Id }, hide);
        await HandleResult(r, hide ? "已隐藏文章" : "已显示文章");
    }

    private async Task ToggleCanComment(ArticleOverviewModel item, bool canComment)
    {
        var r = await AdminCommandService.EditArticleCanCommentAsync(new[] { item.Id }, canComment);
        await HandleResult(r, canComment ? "已开启留言板" : "已关闭留言板");
    }

    private async Task HandleResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success) { ToastService.Show(successMessage, variant: "success"); if (_dataTable is not null) await _dataTable.RefreshAsync(); }
        else { ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error"); }
    }
}
