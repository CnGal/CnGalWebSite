@page "/admin/listrecommends"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode InteractiveServer
@inject IAdminQueryService AdminQueryService
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Recommends

<PageTitle>推荐管理 - CnGal</PageTitle>

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiStarOutline" aria-hidden="true" />
        推荐管理
    </h1>

    <CgDataTable TItem="RecommendOverviewModel"
                 Title="推荐列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true">
        <CgDataTableColumn TItem="RecommendOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="RecommendOverviewModel" Title="关联词条" Field="EntryName" />
        <CgDataTableColumn TItem="RecommendOverviewModel" Title="原因" Field="Reason">
            <ChildContent Context="item"><div class="admin-cell-text">@item.Reason</div></ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="RecommendOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                else { <span class="admin-badge admin-badge--visible">可见</span> }
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private async Task<CgDataTableResult<RecommendOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetRecommendsAsync(parameter);
        return result.Success && result.Data is not null ? new CgDataTableResult<RecommendOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<RecommendOverviewModel>([], 0);
    }
}
