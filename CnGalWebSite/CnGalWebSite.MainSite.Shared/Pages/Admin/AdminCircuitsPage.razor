@page "/admin/listcircuits"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject ICircuitHandlerService CircuitHandlerService


<CgPageMeta Title="线路版块" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiNetwork" aria-hidden="true" />
        线路版块
    </h1>

    <CgDataTable TItem="CircuitHandlerModel"
                 Title="线路列表"
                 Items="_items"
                 DefaultSortField="OpenTime"
                 DefaultSortDesc="true"
                 @ref="_table">
        <ToolbarContent>
            <CgButton Variant="outline" OnClick="Refresh">
                <CgMdiIcon Name="mdiRefresh" />
                刷新
            </CgButton>
        </ToolbarContent>
        <ChildContent>
            <CgDataTableColumn TItem="CircuitHandlerModel" Title="Id" Field="Id" />
            <CgDataTableColumn TItem="CircuitHandlerModel" Title="创建时间" Field="OpenTime">
                <ChildContent Context="item">
                    @item.OpenTime.ToString("yyyy-MM-dd HH:mm")
                </ChildContent>
            </CgDataTableColumn>
            <CgDataTableColumn TItem="CircuitHandlerModel" Title="上次活跃时间" Field="LastActiveTime">
                <ChildContent Context="item">
                    @item.LastActiveTime.ToString("yyyy-MM-dd HH:mm")
                </ChildContent>
            </CgDataTableColumn>
            <CgDataTableColumn TItem="CircuitHandlerModel" Title="状态" Field="IsConnected" Width="100px">
                <ChildContent Context="item">
                    @if (item.IsConnected)
                    {
                        <span class="admin-badge admin-badge--visible">已连接</span>
                    }
                    else
                    {
                        <span class="admin-badge admin-badge--hidden">已断开</span>
                    }
                </ChildContent>
            </CgDataTableColumn>
            <CgDataTableColumn TItem="CircuitHandlerModel" Title="重连次数" Field="ReConnectCount" Width="100px" />
        </ChildContent>
    </CgDataTable>
</div>

@code {
    private List<CircuitHandlerModel> _items = [];
    private CgDataTable<CircuitHandlerModel>? _table;

    protected override void OnInitialized()
    {
        _items = CircuitHandlerService.GetItems();
    }

    private async Task Refresh()
    {
        _items = CircuitHandlerService.GetItems();
        if (_table is not null)
        {
            await _table.RefreshAsync();
        }
    }
}
