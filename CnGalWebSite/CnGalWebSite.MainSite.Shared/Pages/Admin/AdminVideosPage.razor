@page "/admin/listvideos"
@attribute [Authorize(Roles = "Admin")]
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IAdminQueryService AdminQueryService
@inject IAdminCommandService AdminCommandService
@inject ICgToastService ToastService
@implements IDisposable
@using CnGalWebSite.Core.Models
@using CnGalWebSite.DataModel.ViewModel.Videos

<CgPageMeta Title="视频管理" />

<div class="admin-list-page">
    <h1 class="admin-page-title">
        <CgMdiIcon Name="mdiVideoOutline" aria-hidden="true" />
        视频管理
    </h1>

    <CgDataTable TItem="VideoOverviewModel"
                 Title="视频列表"
                 OnServerQuery="OnServerQuery"
                 DefaultSortField="Id"
                 DefaultSortDesc="true"
                 @ref="_dataTable">
        <CgDataTableColumn TItem="VideoOverviewModel" Title="Id" Field="Id" Width="80px" />
        <CgDataTableColumn TItem="VideoOverviewModel" Title="名称" Field="Name">
            <ChildContent Context="item">
                <a class="admin-cell-name" href="@($"/videos/index/{item.Id}")">@item.Name</a>
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="VideoOverviewModel" Title="创建时间" Field="CreateTime">
            <ChildContent Context="item">@item.CreateTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="VideoOverviewModel" Title="最后编辑" Field="LastEditTime">
            <ChildContent Context="item">@item.LastEditTime.ToString("yyyy-MM-dd HH:mm")</ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="VideoOverviewModel" Title="优先级" Field="Priority" Width="80px" />
        <CgDataTableColumn TItem="VideoOverviewModel" Title="状态" Field="IsHidden">
            <ChildContent Context="item">
                @if (item.IsHidden) { <span class="admin-badge admin-badge--hidden">已隐藏</span> }
                else { <span class="admin-badge admin-badge--visible">可见</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="VideoOverviewModel" Title="留言板" Field="CanComment">
            <ChildContent Context="item">
                @if (item.CanComment) { <span class="admin-badge admin-badge--yes">开启</span> }
                else { <span class="admin-badge admin-badge--no">关闭</span> }
            </ChildContent>
        </CgDataTableColumn>
        <CgDataTableColumn TItem="VideoOverviewModel" Title="操作" Sortable="false" Width="150px">
            <ChildContent Context="item">
                <div class="admin-actions">
                    <button class="admin-action-btn admin-action-btn--up" title="增加权重" @onclick="() => EditPriority(item, true)"><CgMdiIcon Name="mdiArrowUpBold" aria-hidden="true" /></button>
                    <button class="admin-action-btn admin-action-btn--down" title="降低权重" @onclick="() => EditPriority(item, false)"><CgMdiIcon Name="mdiArrowDownBold" aria-hidden="true" /></button>
                    @if (item.CanComment) { <button class="admin-action-btn admin-action-btn--nocomment" title="关闭留言板" @onclick="() => ToggleCanComment(item, false)"><CgMdiIcon Name="mdiCommentRemoveOutline" aria-hidden="true" /></button> }
                    else { <button class="admin-action-btn admin-action-btn--comment" title="开启留言板" @onclick="() => ToggleCanComment(item, true)"><CgMdiIcon Name="mdiCommentCheckOutline" aria-hidden="true" /></button> }
                    @if (item.IsHidden) { <button class="admin-action-btn admin-action-btn--show" title="显示" @onclick="() => ToggleHidden(item, false)"><CgMdiIcon Name="mdiEyeOutline" aria-hidden="true" /></button> }
                    else { <button class="admin-action-btn admin-action-btn--hide" title="隐藏" @onclick="() => ToggleHidden(item, true)"><CgMdiIcon Name="mdiEyeOffOutline" aria-hidden="true" /></button> }
                </div>
            </ChildContent>
        </CgDataTableColumn>
    </CgDataTable>
</div>

@code {
    private CancellationTokenSource? _cts;
    private CgDataTable<VideoOverviewModel>? _dataTable;

    private async Task<CgDataTableResult<VideoOverviewModel>> OnServerQuery(CgDataTableRequest request)
    {
        var parameter = new QueryParameterModel { Page = request.Page, ItemsPerPage = request.PageSize, SearchText = request.SearchText ?? string.Empty, SortBy = string.IsNullOrEmpty(request.SortField) ? new[] { "Id" } : new[] { request.SortField }, SortDesc = new[] { request.SortDesc } };
        var result = await AdminQueryService.GetVideosAsync(parameter, _cts.Token);
        return result.Success && result.Data is not null ? new CgDataTableResult<VideoOverviewModel>(result.Data.Items.ToList(), result.Data.Total) : new CgDataTableResult<VideoOverviewModel>([], 0);
    }

    private async Task EditPriority(VideoOverviewModel item, bool up) { var r = await AdminCommandService.EditVideoPriorityAsync(new[] { item.Id }, up ? 1 : -1, _cts.Token); await HandleResult(r, up ? "已增加权重" : "已降低权重"); }
    private async Task ToggleHidden(VideoOverviewModel item, bool hide) { var r = await AdminCommandService.HideVideoAsync(new[] { item.Id }, hide, _cts.Token); await HandleResult(r, hide ? "已隐藏视频" : "已显示视频"); }
    private async Task ToggleCanComment(VideoOverviewModel item, bool canComment) { var r = await AdminCommandService.EditVideoCanCommentAsync(new[] { item.Id }, canComment, _cts.Token); await HandleResult(r, canComment ? "已开启留言板" : "已关闭留言板"); }

    private async Task HandleResult(SdkResult<bool> result, string successMessage)
    {
        if (result.Success) { ToastService.Show(successMessage, variant: "success"); if (_dataTable is not null) await _dataTable.RefreshAsync(); }
        else { ToastService.Show(result.Error?.Message ?? "操作失败", variant: "error"); }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
