@page "/space/index/{Id}"
@page "/space/index"

@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.SDK.MainSite.Abstractions
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.Features.Space
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem
@using Microsoft.AspNetCore.Components.Web

@inject ISpaceQueryService SpaceQueryService
@inject IPlayedGameQueryService PlayedGameQueryService
@inject IFavoriteFolderQueryService FavoriteFolderQueryService
@inject NavigationManager NavigationManager

@if (_isNotFound)
{
    <div class="cg-space-not-found">
        <h1 class="cg-space-not-found-title">找不到这个用户哦......</h1>
        <div class="cg-space-not-found-text">有点可怕呢，可以试试联系管理员</div>
        <CgButton Variant="primary" OnClick="@(() => NavigationManager.NavigateTo("/"))">返回首页</CgButton>
    </div>
}
else if (_model != null)
{
    <PageTitle>@($"{_model.Name} - 个人空间 - CnGal资料站")</PageTitle>

    <div class="cg-space-container">
        <div class="cg-space-layout-row">
            <div class="cg-space-layout-sidebar">
                <SpaceHero Model="_model" />
                <SpaceBasicInfoCard Model="_model" />
                <SpaceDataOverviewCard Model="_model" />
                @if (_model.IsCurrentUser)
                {
                    <a class="cg-space-edit-btn" href="/space/edit">
                        <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                        <span>编辑个人空间</span>
                    </a>
                }
                @if (_model.UserCertification != null)
                {
                    <div class="cg-space-cert-section">
                        <div class="cg-space-cert-header">
                            <CgMdiIcon Name="mdiCertificateOutline" Class="cg-space-cert-icon" />
                            <h2 class="cg-space-cert-title">用户认证</h2>
                        </div>
                        <EntryCardItem Url="@($"/entries/index/{_model.UserCertification.Id}")"
                                       Image="@_model.UserCertification.MainImage"
                                       Title="@_model.UserCertification.Name"
                                       IsSquareCover="@(_model.UserCertification.Type is EntryType.Role or EntryType.Staff)" />
                    </div>
                }
            </div>
            
            <div class="cg-space-layout-main">
                <CgTabs Variant="underline" Items="GetSpaceTabs()" DefaultActiveKey="home" Id="space-tabs" AriaLabel="个人空间">
                    <PanelTemplate Context="tabKey">
                        @switch (tabKey)
                        {
                            case "home":
                                <div class="cg-space-tab-card">
                                    <SpaceMainPage Model="_model" />
                                </div>

                                <div style="margin-top: var(--cg-spacing-8);">
                                    <CnGalWebSite.MainSite.Shared.Components.Features.Comment.CommentSection
                                        Type="CommentType.CommentUser"
                                        ObjectId="@_model.Id"
                                        CanComment="_model.CanComment" />
                                </div>
                                break;

                            case "records":
                                @if (_model.IsCurrentUser)
                                {
                                    <SpaceGameRecordSection UserId="@_model.Id" SteamId="@_model.SteamId" />
                                }
                                else if (_gameRecords is not null)
                                {
                                    <SpaceGameRecordList Model="_gameRecords"
                                                        IsCurrentUser="false"
                                                        SteamUsers="_steamUsers"
                                                        SteamId="@_model.SteamId" />
                                }
                                break;

                            case "favorites":
                                @if (_favoriteFolders is not null)
                                {
                                    <SpaceFavoriteFolderList Folders="_favoriteFolders" IsCurrentUser="_model.IsCurrentUser" />
                                }
                                break;
                        }
                    </PanelTemplate>
                </CgTabs>
            </div>
        </div>
    </div>
}
else if (_isError)
{
    <div class="cg-space-error">
        <h1 class="cg-space-error-title">加载失败</h1>
        <div class="cg-space-error-text">@_errorMessage</div>
    </div>
}
else
{
    <div class="cg-space-loading">
        <span>加载中...</span>
    </div>
}

@code {
    [Parameter]
    public string? Id { get; set; }

    private SpaceDetailViewModel? _model;
    private UserGameRecordsViewModel? _gameRecords;
    private IReadOnlyList<SteamUserInfoItem> _steamUsers = [];
    private IReadOnlyList<FavoriteFolderSummaryItem>? _favoriteFolders;
    private bool _isNotFound;
    private bool _isError;
    private string _errorMessage = string.Empty;

    private bool _showFavoritesTab => _model is not null && (_model.IsCurrentUser || _model.IsShowFavorites);

    private IReadOnlyList<CgTabItem> GetSpaceTabs()
    {
        var recordCount = _gameRecords?.Records.Count(r => !r.IsHidden && (r.ShowPublicly || _model!.IsCurrentUser));
        var tabs = new List<CgTabItem>
        {
            new CgTabItem("home", "主页", "mdiHomeOutline"),
            new CgTabItem("records", "游玩记录", "mdiControllerClassicOutline", recordCount?.ToString()),
        };

        if (_showFavoritesTab)
        {
            var favCount = _favoriteFolders?.Count;
            tabs.Add(new CgTabItem("favorites", "收藏夹", "mdiHeartMultiple", favCount > 0 ? favCount.ToString() : null));
        }

        return tabs;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_model != null && !string.IsNullOrWhiteSpace(Id) && _model.Id != Id)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        _isNotFound = false;
        _isError = false;
        _model = null;
        _gameRecords = null;
        _favoriteFolders = null;

        var targetId = Id ?? string.Empty;
        var result = await SpaceQueryService.GetSpaceDetailAsync(targetId);

        if (result.Success && result.Data != null)
        {
            _model = result.Data;

            var tasks = new List<Task>();

            // 非当前用户：静态加载游玩记录（当前用户由 SpaceGameRecordSection 交互式加载）
            if (!_model.IsCurrentUser)
            {
                tasks.Add(LoadGameRecordsAsync());
            }

            // 加载收藏夹列表（条件：当前用户或允许展示）
            if (_model.IsCurrentUser || _model.IsShowFavorites)
            {
                tasks.Add(LoadFavoriteFoldersAsync());
            }

            await Task.WhenAll(tasks);
        }
        else if (result.Error?.StatusCode == 404)
        {
            _isNotFound = true;
        }
        else
        {
            _isError = true;
            _errorMessage = result.Error?.Message ?? "未知错误";
        }
    }

    private async Task LoadGameRecordsAsync()
    {
        var recordsTask = PlayedGameQueryService.GetUserGameRecordsAsync(_model!.Id);
        var steamInfoTask = PlayedGameQueryService.GetUserSteamInfoAsync(_model.Id);

        await Task.WhenAll(recordsTask, steamInfoTask);

        var recordsResult = recordsTask.Result;
        _gameRecords = recordsResult.Success ? recordsResult.Data : null;

        var steamInfoResult = steamInfoTask.Result;
        _steamUsers = steamInfoResult.Success && steamInfoResult.Data is not null
            ? steamInfoResult.Data
            : [];
    }

    private async Task LoadFavoriteFoldersAsync()
    {
        var foldersResult = await FavoriteFolderQueryService.GetUserFavoriteFoldersAsync(_model!.Id);
        _favoriteFolders = foldersResult.Success && foldersResult.Data is not null
            ? foldersResult.Data
            : [];
    }
}
