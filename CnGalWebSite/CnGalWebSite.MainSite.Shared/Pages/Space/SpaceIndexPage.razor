@page "/space/index/{Id}"
@page "/space/index"

@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Peripheries
@using CnGalWebSite.DataModel.ViewModel.Space
@using CnGalWebSite.SDK.MainSite.Abstractions
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.Features.Space
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem
@using Microsoft.AspNetCore.Components.Web

@inject ISpaceQueryService SpaceQueryService
@inject IPlayedGameQueryService PlayedGameQueryService
@inject IFavoriteFolderQueryService FavoriteFolderQueryService
@inject IPeripheryQueryService PeripheryQueryService
@inject NavigationManager NavigationManager

@if (_isNotFound)
{
    <div class="cg-space-not-found">
        <h1 class="cg-space-not-found-title">找不到这个用户哦......</h1>
        <div class="cg-space-not-found-text">有点可怕呢，可以试试联系管理员</div>
        <CgButton Variant="primary" OnClick="@(() => NavigationManager.NavigateTo("/"))">返回首页</CgButton>
    </div>
}
else if (_model != null)
{
    <CgPageMeta Title="@($"{_model.Name} - 个人空间")" Description="@(_model.PersonalSignature)" Image="@(_model.PhotoPath)" />

    <div class="cg-space-container">
        <div class="cg-space-layout-row">
            <div class="cg-space-layout-sidebar">
                <SpaceHero Model="_model" />
                <SpaceBasicInfoCard Model="_model" />
                <SpaceDataOverviewCard Model="_model" />
                @if (_model.IsCurrentUser)
                {
                    <a class="cg-space-edit-btn" href="/space/edit">
                        <CgMdiIcon Name="mdiPencilOutline" aria-hidden="true" />
                        <span>编辑个人空间</span>
                    </a>
                }
                @if (_model.UserCertification != null)
                {
                    <div class="cg-space-cert-section">
                        <div class="cg-space-cert-header">
                            <CgMdiIcon Name="mdiCertificateOutline" Class="cg-space-cert-icon" />
                            <h2 class="cg-space-cert-title">用户认证</h2>
                        </div>
                        <EntryCardItem Url="@($"/entries/index/{_model.UserCertification.Id}")"
                                       Image="@_model.UserCertification.MainImage"
                                       Title="@_model.UserCertification.Name"
                                       IsSquareCover="@(_model.UserCertification.Type is EntryType.Role or EntryType.Staff)" />
                    </div>
                }
            </div>
            
            <div class="cg-space-layout-main">
                <CgTabs Variant="underline" Items="GetSpaceTabs()" DefaultActiveKey="@_activeTab" Id="space-tabs" AriaLabel="个人空间"
                        HrefTemplate="@GetTabHref()">
                    <PanelTemplate Context="tabKey">
                        @switch (tabKey)
                        {
                            case "home":
                                <div class="cg-space-tab-card">
                                    <SpaceMainPage Model="_model" />
                                </div>

                                @if (_signInHeatMap is not null)
                                {
                                    <div class="cg-space-heatmap-section">
                                        <CgHeatMap Title="签到记录" Data="_signInHeatMap.Data" MaxCount="_signInHeatMap.MaxCount" Height="180" />
                                    </div>
                                }

                                @if (_editHeatMap is not null)
                                {
                                    <div class="cg-space-heatmap-section">
                                        <CgHeatMap Title="编辑概览" Data="_editHeatMap.Data" MaxCount="_editHeatMap.MaxCount" Height="180" />
                                    </div>
                                }

                                <div class="cg-space-comment-wrapper">
                                    <CnGalWebSite.MainSite.Shared.Components.Features.Comment.CommentSection
                                        Type="CommentType.CommentUser"
                                        ObjectId="@_model.Id"
                                        CanComment="_model.CanComment" />
                                </div>
                                break;

                            case "editrecords":
                                <SpaceEditRecordList Model="_editRecords" PaginationHrefTemplate="@GetPaginationHref("editRecordsPage")" />
                                break;

                            case "articles":
                                <SpaceArticleList Model="_articles" PaginationHrefTemplate="@GetPaginationHref("articlesPage")" />
                                break;

                            case "videos":
                                <SpaceVideoList Model="_videos" />
                                break;

                            case "records":
                                @if (_model.IsCurrentUser)
                                {
                                    <AuthorizeView>
                                        <Authorized>
                                            <SpaceGameRecordSection UserId="@_model.Id" SteamId="@_model.SteamId" />
                                        </Authorized>
                                    </AuthorizeView>
                                }
                                else if (_gameRecords is not null)
                                {
                                    <SpaceGameRecordList Model="_gameRecords"
                                                        IsCurrentUser="false"
                                                        SteamUsers="_steamUsers"
                                                        SteamId="@_model.SteamId" />
                                }
                                break;

                            case "favorites":
                                @if (_favoriteFolders is not null)
                                {
                                    <SpaceFavoriteFolderList Folders="_favoriteFolders" IsCurrentUser="_model.IsCurrentUser" />
                                }
                                break;

                            case "peripheries":
                                <SpacePeripheryList Model="_peripheries" />
                                break;
                        }
                    </PanelTemplate>
                </CgTabs>
            </div>
        </div>
    </div>
}
else if (_isError)
{
    <div class="cg-space-error">
        <h1 class="cg-space-error-title">加载失败</h1>
        <div class="cg-space-error-text">@_errorMessage</div>
    </div>
}
else
{
    <div class="cg-space-loading">
        <span>加载中...</span>
    </div>
}

@* 移动端底部导航栏 — 仅 < 768px 显示 *@
<CnGalWebSite.MainSite.Shared.Components.Layout.CgBottomNav ActiveTab="space" />

@code {
    [Parameter]
    public string? Id { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "articlesPage")]
    public int ArticlesPage { get; set; } = 1;

    [SupplyParameterFromQuery(Name = "editRecordsPage")]
    public int EditRecordsPage { get; set; } = 1;

    private string _activeTab => string.IsNullOrWhiteSpace(Tab) ? "home" : Tab;

    private SpaceDetailViewModel? _model;
    private UserGameRecordsViewModel? _gameRecords;
    private IReadOnlyList<SteamUserInfoItem> _steamUsers = [];
    private IReadOnlyList<FavoriteFolderSummaryItem>? _favoriteFolders;
    private UserArticlesViewModel? _articles;
    private UserVideosViewModel? _videos;
    private UserEditRecordsViewModel? _editRecords;
    private IReadOnlyList<GameOverviewPeripheryListModel>? _peripheries;
    private UserHeatMapViewModel? _signInHeatMap;
    private UserHeatMapViewModel? _editHeatMap;
    private bool _isNotFound;
    private bool _isError;
    private string _errorMessage = string.Empty;

    private bool _showGameRecordTab => _model is not null && (_model.IsCurrentUser || _model.IsShowGameRecord);
    private bool _showFavoritesTab => _model is not null && (_model.IsCurrentUser || _model.IsShowFavorites);

    private IReadOnlyList<CgTabItem> GetSpaceTabs()
    {
        var tabs = new List<CgTabItem>
        {
            new CgTabItem("home", "主页", "mdiHomeOutline"),
            new CgTabItem("editrecords", "编辑记录", "mdiScriptTextOutline"),
        };

        if (_model is not null && _model.ArticleCount > 0)
        {
            tabs.Add(new CgTabItem("articles", "文章", "mdiNewspaperVariantMultipleOutline", _model.ArticleCount.ToString()));
        }

        if (_model is not null && _model.VideoCount > 0)
        {
            tabs.Add(new CgTabItem("videos", "视频", "mdiAnimationPlay", _model.VideoCount.ToString()));
        }

        if (_showGameRecordTab)
        {
            tabs.Add(new CgTabItem("records", "游玩记录", "mdiControllerClassicOutline"));
        }

        if (_showFavoritesTab)
        {
            tabs.Add(new CgTabItem("favorites", "收藏夹", "mdiHeartMultiple"));
        }

        tabs.Add(new CgTabItem("peripheries", "周边", "mdiBasketOutline"));

        return tabs;
    }

    private int _prevArticlesPage;
    private int _prevEditRecordsPage;

    protected override async Task OnInitializedAsync()
    {
        _prevArticlesPage = ArticlesPage;
        _prevEditRecordsPage = EditRecordsPage;
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_model != null && !string.IsNullOrWhiteSpace(Id) && _model.Id != Id)
        {
            _prevArticlesPage = ArticlesPage;
            _prevEditRecordsPage = EditRecordsPage;
            await LoadDataAsync();
            return;
        }

        // 仅分页参数变化时，只重载对应数据
        if (_model != null)
        {
            var tasks = new List<Task>();

            if (ArticlesPage != _prevArticlesPage)
            {
                _prevArticlesPage = ArticlesPage;
                tasks.Add(LoadArticlesAsync());
            }

            if (EditRecordsPage != _prevEditRecordsPage)
            {
                _prevEditRecordsPage = EditRecordsPage;
                tasks.Add(LoadEditRecordsAsync());
            }

            if (tasks.Count > 0)
            {
                await Task.WhenAll(tasks);
            }
        }
    }

    private async Task LoadDataAsync()
    {
        _isNotFound = false;
        _isError = false;
        _model = null;
        _gameRecords = null;
        _favoriteFolders = null;
        _articles = null;
        _videos = null;
        _editRecords = null;
        _peripheries = null;
        _signInHeatMap = null;
        _editHeatMap = null;

        var targetId = Id ?? string.Empty;
        var result = await SpaceQueryService.GetSpaceDetailAsync(targetId);

        if (result.Success && result.Data != null)
        {
            _model = result.Data;

            var tasks = new List<Task>();

            // 按当前 Tab 加载对应数据
            switch (_activeTab)
            {
                case "home":
                    tasks.Add(LoadHeatMapsAsync());
                    break;
                case "editrecords":
                    tasks.Add(LoadEditRecordsAsync());
                    break;
                case "articles":
                    if (_model.ArticleCount > 0)
                        tasks.Add(LoadArticlesAsync());
                    break;
                case "videos":
                    if (_model.VideoCount > 0)
                        tasks.Add(LoadVideosAsync());
                    break;
                case "records":
                    if (!_model.IsCurrentUser && _model.IsShowGameRecord)
                        tasks.Add(LoadGameRecordsAsync());
                    break;
                case "favorites":
                    if (_model.IsCurrentUser || _model.IsShowFavorites)
                        tasks.Add(LoadFavoriteFoldersAsync());
                    break;
                case "peripheries":
                    tasks.Add(LoadPeripheriesAsync());
                    break;
            }

            await Task.WhenAll(tasks);
        }
        else if (result.Error?.StatusCode == 404)
        {
            _isNotFound = true;
        }
        else
        {
            _isError = true;
            _errorMessage = result.Error?.Message ?? "未知错误";
        }
    }

    private async Task LoadGameRecordsAsync()
    {
        var recordsTask = PlayedGameQueryService.GetUserGameRecordsAsync(_model!.Id);
        var steamInfoTask = PlayedGameQueryService.GetUserSteamInfoAsync(_model.Id);

        await Task.WhenAll(recordsTask, steamInfoTask);

        var recordsResult = recordsTask.Result;
        _gameRecords = recordsResult.Success ? recordsResult.Data : null;

        var steamInfoResult = steamInfoTask.Result;
        _steamUsers = steamInfoResult.Success && steamInfoResult.Data is not null
            ? steamInfoResult.Data
            : [];
    }

    private async Task LoadFavoriteFoldersAsync()
    {
        var foldersResult = _model!.IsCurrentUser
            ? await FavoriteFolderQueryService.GetAllUserFavoriteFoldersAsync(_model.Id)
            : await FavoriteFolderQueryService.GetUserFavoriteFoldersAsync(_model.Id);
        _favoriteFolders = foldersResult.Success && foldersResult.Data is not null
            ? foldersResult.Data
            : [];
    }

    private async Task LoadArticlesAsync()
    {
        var page = Math.Max(1, ArticlesPage);
        var result = await SpaceQueryService.GetUserArticlesAsync(_model!.Id, currentPage: page);
        _articles = result.Success ? result.Data : null;
    }

    private async Task LoadVideosAsync()
    {
        var result = await SpaceQueryService.GetUserVideosAsync(_model!.Id);
        _videos = result.Success ? result.Data : null;
    }

    private async Task LoadEditRecordsAsync()
    {
        var page = Math.Max(1, EditRecordsPage);
        var result = await SpaceQueryService.GetUserEditRecordsAsync(_model!.Id, currentPage: page);
        _editRecords = result.Success ? result.Data : null;
    }

    private string _basePath => string.IsNullOrWhiteSpace(Id) ? "/space/index" : $"/space/index/{Id}";

    /// <summary>
    /// 生成 Tab 切换的 URL 模板（{0} 为 tab key）。
    /// </summary>
    private string GetTabHref()
    {
        return $"{_basePath}?tab={{0}}";
    }

    /// <summary>
    /// 生成分页 URL 模板，保留当前 tab 参数。
    /// </summary>
    private string GetPaginationHref(string pageParamName)
    {
        return $"{_basePath}?tab={_activeTab}&{pageParamName}={{0}}";
    }

    private async Task LoadPeripheriesAsync()
    {
        var result = await PeripheryQueryService.GetUserOverviewPeripheriesAsync(_model!.Id);
        _peripheries = result.Success ? result.Data : null;
    }

    private async Task LoadHeatMapsAsync()
    {
        var signInTask = SpaceQueryService.GetUserHeatMapAsync(_model!.Id, UserHeatMapType.SignInDays);
        var editTask = SpaceQueryService.GetUserHeatMapAsync(_model.Id, UserHeatMapType.EditRecords);

        await Task.WhenAll(signInTask, editTask);

        _signInHeatMap = signInTask.Result.Success ? signInTask.Result.Data : null;
        _editHeatMap = editTask.Result.Success ? editTask.Result.Data : null;
    }
}
