@page "/bind-steam/{ReturnUrl}"

@using CnGalWebSite.DataModel.ViewModel.Space

@inject ISpaceCommandService SpaceCommandService
@inject NavigationManager NavigationManager
@implements IDisposable

<CgPageMeta Title="绑定 Steam 账号" />

@if (!string.IsNullOrEmpty(_statusMessage))
{
    <div class="bind-steam-container">
        <CgAlert Variant="@_statusVariant">@_statusMessage</CgAlert>
        <CgButton Variant="outline" Href="@_returnHref">返回</CgButton>
    </div>
}
else
{
    <div class="bind-steam-loading">
        <CgProgressRing />
        <span class="bind-steam-loading__text">正在处理 Steam 绑定...</span>
    </div>
}

@code {
    [Parameter]
    public string? ReturnUrl { get; set; }

    private string? _statusMessage;
    private string _statusVariant = "info";
    private string _returnHref = "/";
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        // 预先计算返回链接
        if (!string.IsNullOrWhiteSpace(ReturnUrl))
        {
            try
            {
                _returnHref = CnGalWebSite.SDK.MainSite.Infrastructure.SdkToolHelper.Base64DecodeUrl(ReturnUrl);
            }
            catch
            {
                _returnHref = "/";
            }
        }

        try
        {
            // 手动从 URL 解析 openid.claimed_id，避免 SupplyParameterFromQuery 对含点号参数名的兼容问题
            var uri = new Uri(NavigationManager.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            var openIdClaimedId = query["openid.claimed_id"];

            if (string.IsNullOrWhiteSpace(openIdClaimedId))
            {
                SetStatus("未收到 Steam 返回的认证信息", "error");
                return;
            }

            var ids = openIdClaimedId.Split("/");
            if (ids.Length < 2)
            {
                SetStatus("Steam 认证信息格式不正确", "error");
                return;
            }

            var steamId = ids.Last();

            var editResult = await SpaceCommandService.GetSpaceEditAsync(_cts!.Token);
            if (!editResult.Success || editResult.Data == null)
            {
                SetStatus(editResult.Error?.Message ?? "无法获取当前个人空间数据", "error");
                return;
            }

            var model = editResult.Data;

            if (model.UserData.SteamIds.Contains(steamId))
            {
                SetStatus("该 Steam 账号已绑定", "info");
                return;
            }

            model.UserData.SteamIds.Add(steamId);

            var submitResult = await SpaceCommandService.SubmitEditAsync(model, _cts!.Token);
            if (submitResult.Success)
            {
                // 绑定成功后，刷新 Steam 相关缓存以拉取最新游玩数据
                var userId = model.UserData.Id ?? string.Empty;
                var refreshResult = await SpaceCommandService.RefreshSteamInfoAsync(userId, _cts!.Token);
                if (refreshResult.Success)
                {
                    SetStatus("已成功绑定 Steam 账号并刷新游玩数据", "success");
                }
                else
                {
                    // 绑定本身成功，但缓存刷新失败，提示用户可稍后手动刷新
                    SetStatus("已成功绑定 Steam 账号，但刷新游玩数据失败，可稍后在个人空间手动刷新", "warning");
                }
            }
            else
            {
                SetStatus(submitResult.Error?.Message ?? "保存 Steam 绑定信息失败", "error");
            }
        }
        catch (OperationCanceledException)
        {
            // Component disposed, ignore.
        }
        catch (Exception ex)
        {
            SetStatus($"发生未知错误：{ex.Message}", "error");
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private void SetStatus(string message, string variant)
    {
        _statusMessage = message;
        _statusVariant = variant;
    }
}

