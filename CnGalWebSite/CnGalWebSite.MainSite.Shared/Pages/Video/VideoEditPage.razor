@page "/videos/create"
@page "/videos/edit/{Id:long}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using CnGalWebSite.DataModel.ViewModel.Videos
@using CnGalWebSite.MainSite.Shared.Components.Features.Video.Editor
@using CnGalWebSite.MainSite.Shared.Services
@using CnGalWebSite.SDK.MainSite.Abstractions
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.SDK.MainSite.Models.VideoEdit
@using System.Text.Json
@inject IVideoCommandService VideoCommandService
@inject NavigationManager NavigationManager
@inject ILocalStorageService LocalStorage
@inject ICgToastService ToastService
@implements IDisposable

<CgPageMeta Title="@(IsCreate ? "发布视频" : "编辑视频")" />

@if (IsLoading)
{
    <section class="video-edit-loading" aria-label="加载中">
        <div class="video-edit-loading-spinner"></div>
        <p>正在获取数据...</p>
    </section>
}
else if (LoadErrorMessage != null)
{
    <section class="video-edit-error">
        <h1>加载失败</h1>
        <p>@LoadErrorMessage</p>
        <CgButton Variant="primary" OnClick="LoadDataAsync">重试</CgButton>
    </section>
}
else if (Model != null)
{
    <article class="video-edit-page">
        <div class="video-edit-layout">
            <VideoEditorSidebar IsCreate="IsCreate"
                                IsSubmitting="IsSubmitting"
                                HasDraftRecovered="HasDraftRecovered"
                                OnDiscardDraft="DiscardDraft"
                                OnSubmit="SubmitAsync"
                                OnCancel="Cancel" />

            <main class="video-edit-main">
                <VideoMainEditor Model="Model.Data.Main" />
                <VideoImagesEditor Model="Model.Data.Images" />
                <VideoRelevancesEditor Model="Model.Data.Relevances" MetaOptions="Model.MetaOptions" />
                <VideoMainPageEditor Model="Model.Data.MainPage" />
            </main>
        </div>

    </article>
}

@code {
    [Parameter]
    public long? Id { get; set; }

    private bool IsCreate => Id is null or <= 0;

    private bool IsLoading = true;
    private string? LoadErrorMessage;

    private bool IsSubmitting = false;

    private VideoEditViewModel? Model;

    private CancellationTokenSource? _cts;
    private System.Threading.Timer? _autoSaveTimer;
    private string DraftKey => IsCreate ? "VideoDraft_Create" : $"VideoDraft_Edit_{Id}";

    private bool HasDraftRecovered = false;
    private CreateVideoViewModel? OriginalData;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadDataAsync();
        _autoSaveTimer = new System.Threading.Timer(AutoSaveCallback, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void AutoSaveCallback(object? state)
    {
        _ = InvokeAsync(async () =>
        {
            if (Model != null && !IsSubmitting && !IsLoading)
            {
                try
                {
                    await LocalStorage.SetItemAsync(DraftKey, Model.Data);
                }
                catch { /* Ignore local storage errors */ }
            }
        });
    }

    public void Dispose()
    {
        _autoSaveTimer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        LoadErrorMessage = null;
        StateHasChanged();

        try
        {
            SdkResult<VideoEditViewModel> result;
            if (IsCreate)
            {
                result = await VideoCommandService.GetVideoCreateTemplateAsync(_cts!.Token);
            }
            else
            {
                result = await VideoCommandService.GetVideoEditAsync(Id!.Value, _cts!.Token);
            }

            if (result.Success && result.Data != null)
            {
                Model = result.Data;
                OriginalData = JsonSerializer.Deserialize<CreateVideoViewModel>(JsonSerializer.Serialize(result.Data.Data));

                // 尝试恢复草稿
                try
                {
                    var draft = await LocalStorage.GetItemAsync<CreateVideoViewModel>(DraftKey);
                    if (draft != null)
                    {
                        Model.Data = draft;
                        HasDraftRecovered = true;
                    }
                }
                catch { }

                // 加载候选列表
                var metaResult = await VideoCommandService.GetVideoEditMetaOptionsAsync(_cts!.Token);
                if (metaResult.Success && metaResult.Data != null)
                {
                    Model.MetaOptions = metaResult.Data;
                }
            }
            else
            {
                LoadErrorMessage = result.Error?.Message ?? "获取编辑数据失败";
            }
        }
        catch (OperationCanceledException)
        {
            // Cancelled, do nothing
        }
        catch (Exception ex)
        {
            LoadErrorMessage = "发生未知错误：" + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task DiscardDraft()
    {
        if (OriginalData != null && Model != null)
        {
            Model.Data = JsonSerializer.Deserialize<CreateVideoViewModel>(JsonSerializer.Serialize(OriginalData))!;
            HasDraftRecovered = false;
            await LocalStorage.RemoveItemAsync(DraftKey);
            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        if (Model == null || IsSubmitting) return;

        var validationResult = Model.Data.Validate();
        if (!validationResult.Successful)
        {
            ToastService.Show("校验失败", validationResult.Error ?? "请检查表单是否填写正确", "error");
            return;
        }

        IsSubmitting = true;
        StateHasChanged();

        try
        {
            var request = new VideoEditRequest
            {
                IsCreate = IsCreate,
                Data = Model.Data
            };

            var result = await VideoCommandService.SubmitEditAsync(request, _cts!.Token);
            if (result.Success)
            {
                await LocalStorage.RemoveItemAsync(DraftKey);
                NavigationManager.NavigateTo($"/videos/index/{result.Data}");
            }
            else
            {
                ToastService.Show("提交失败", result.Error?.Message ?? "提交审核时出现问题", "error");
            }
        }
        catch (OperationCanceledException)
        {
            // Cancelled, do nothing
        }
        catch (Exception ex)
        {
            ToastService.Show("发生错误", ex.Message, "error");
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        if (IsCreate)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            NavigationManager.NavigateTo($"/videos/index/{Id}");
        }
    }
}
