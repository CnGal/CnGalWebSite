@page "/videos/index/{Id:long}"
@inject IVideoQueryService VideoQueryService
@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Search
@using CnGalWebSite.MainSite.Shared.Components.Features.Video.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail

<PageTitle>@(Model is null ? "视频详情" : $"{GetDisplayTitle()} - 视频详情")</PageTitle>

@if (ErrorMessage is not null)
{
    <section class="video-not-found">
        <h1>视频加载失败</h1>
        <p>@ErrorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (Model is not null)
{
    <article class="video-page">
        <header class="video-header">
            <VideoHero Title="@GetDisplayTitle()"
                       BriefIntroduction="@Model.BriefIntroduction"
                       MainPicture="@Model.MainPicture"
                       TypeText="@GetTypeText()"
                       Duration="@Model.Duration"
                       VideoId="@Id"
                       WatchUrl="@(Model.RelatedOutlinks.FirstOrDefault()?.Link ?? Model.RelatedOutlinks.FirstOrDefault()?.DisplayValue)" />

            <div class="video-info-bar">
                <VideoAuthorCard AuthorName="@Model.AuthorName"
                                 AuthorAvatar="@Model.AuthorAvatar"
                                 AuthorId="@Model.AuthorId"
                                 OriginalAuthor="@Model.OriginalAuthor"
                                 IsOriginal="Model.IsAuthorOriginal" />

                <VideoBasicInfo ReaderCount="Model.ReaderCount"
                                CommentCount="Model.CommentCount"
                                Type="@Model.Type"
                                Copyright="Model.Copyright"
                                IsInteractive="Model.IsInteractive"
                                PublishTime="Model.PubishTime"
                                CreateTime="Model.CreateTime"
                                LastEditTime="Model.LastEditTime" />
            </div>
        </header>

        @if (Model.IsHidden)
        {
            <CgAlert Variant="warning" Class="video-hidden-alert">
                当前视频处于隐藏状态，如果你看到了这个提示，请立即联系管理员
            </CgAlert>
        }

        <main class="video-main-content">
            @if (Model.Pictures.Count > 0)
            {
                <EntrySection Title="截图" Icon="mdiImageOutline">
                    <EntryImageGrid Pictures="Model.Pictures" MaxCount="12" EntryName="@Model.Name" DisplayTextOrFallback="DisplayTextOrFallback" />
                </EntrySection>
            }

            @if (!string.IsNullOrWhiteSpace(Model.MainPage))
            {
                <div class="video-prose">
                    <CgHtmlContent Content="@Model.MainPage" />
                </div>
            }
        </main>

        <footer class="video-footer-related">
            <EntrySection Title="相关词条" Icon="mdiLinkVariant" Show="Model.RelatedEntries.Count > 0">
                <EntryCardList>
                    @foreach (var item in Model.RelatedEntries.Take(8))
                    {
                        <li>
                            <EntryCardItem Url="@($"/entries/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="相关文章" Icon="mdiTextBoxOutline" Show="Model.RelatedArticles.Count > 0">
                <EntryCardList>
                    @foreach (var item in Model.RelatedArticles.Take(8))
                    {
                        <li>
                            <EntryCardItem Url="@GetArticleLink(item)" Target="@GetTarget(item.Link)" Image="@item.MainImage" Title="@item.Name" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="相关视频" Icon="mdiAnimationPlayOutline" Show="Model.RelatedVideos.Count > 0">
                <EntryCardList>
                    @foreach (var item in Model.RelatedVideos.Take(8))
                    {
                        <li>
                            <EntryCardItem Url="@($"/videos/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="外部链接" Icon="mdiLinkVariant" Show="Model.RelatedOutlinks.Count > 0">
                <EntryOutlinkList Links="Model.RelatedOutlinks"
                                  MaxCount="8"
                                  GetExternalLinkIcon="GetExternalLinkIcon"
                                  GetExternalLinkImage="GetExternalLinkImage"
                                  GetExternalLinkDescription="GetExternalLinkDescription"
                                  DisplayTextOrFallback="DisplayTextOrFallback" />
            </EntrySection>

            <EntryCard Title="评论入口" Icon="mdiCommentTextOutline" Class="video-card--comment" Show="Model.CanComment" Description="可前往评论区参与讨论，分享你的看法。">
                <a class="video-action-btn" href="@($"/space/comments?type=video&id={Model.Id}")">前往评论区</a>
            </EntryCard>
        </footer>
    </article>
}
else
{
    <section class="video-loading" aria-label="加载中">
        <div class="video-loading-block video-loading-block--wide"></div>
        <div class="video-loading-block"></div>
        <div class="video-loading-block"></div>
    </section>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private VideoDetailViewModel? Model;
    private string? ErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        var result = await VideoQueryService.GetVideoDetailAsync(Id);
        if (result.Success && result.Data is not null)
        {
            ErrorMessage = null;
            Model = result.Data;
            return;
        }

        Model = null;
        ErrorMessage = result.Error?.Message ?? "请稍后重试";
    }

    private string GetDisplayTitle()
    {
        if (Model is null)
        {
            return string.Empty;
        }

        return string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.Name : Model.DisplayName;
    }

    private string GetTypeText()
    {
        if (Model is null || string.IsNullOrWhiteSpace(Model.Type))
        {
            return "视频";
        }

        return Model.Type;
    }

    private static bool IsExternalLink(string? link)
    {
        return string.IsNullOrWhiteSpace(link) is false
               && (link.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                   || link.StartsWith("https://", StringComparison.OrdinalIgnoreCase));
    }

    private static string GetArticleLink(ArticleInforTipViewModel item)
    {
        return IsExternalLink(item.Link) ? item.Link : $"/articles/index/{item.Id}";
    }

    private static string GetTarget(string? link)
    {
        return IsExternalLink(link) ? "_blank" : null;
    }

    private string GetExternalLinkIcon(string displayName)
    {
        var name = displayName?.ToLower() ?? "";
        if (name.Contains("steam")) return "mdiSteam";
        if (name.Contains("bilibili") || name.Contains("b站")) return "mdiTelevisionPlay";
        if (name.Contains("weibo") || name.Contains("微博")) return "mdiWechat"; 
        if (name.Contains("twitter") || name.Contains("x")) return "mdiTwitter";
        if (name.Contains("github")) return "mdiGithub";
        if (name.Contains("youtube")) return "mdiYoutube";
        if (name.Contains("tap") || name.Contains("taptap")) return "mdiGamepadVariantOutline";
        if (name.Contains("qq")) return "mdiQqchat";
        return "mdiEarth";
    }

    private string? GetExternalLinkImage(string displayName)
    {
        var image = displayName switch
        {
            "萌娘百科" => "Moegirl.png",
            "Bangumi" => "Bangumi.png",
            "百度百科" => "BaiDuWiki.png",
            "2DFan" => "2DFan.png",
            "中文维基百科" => "Wiki.png",
            "月幕Galgame" => "YMGal.png",
            "Bilibili" => "bilibili.png",
            "bilibili" => "bilibili.png",
            "WikiData" => "Wikidata.png",
            "微博" => "weibo.png",
            "AcFun" => "AcFun.png",
            "知乎" => "zhihu.png",
            "爱发电" => "Afdian.png",
            "Pixiv" => "pixiv.png",
            "Twitter" => "twitter.png",
            "YouTube" => "Youtube.png",
            "Facebook" => "Facebook.png",
            "官网" => "SmartHome.png",
            "摩点" => "modian.png",
            "小黑盒" => "xiaoheihe.jpg",
            _ => null
        };

        if (string.IsNullOrWhiteSpace(image))
        {
            return null;
        }

        return "https://res.cngal.org/_content/CnGalWebSite.Shared/images/" + image;
    }

    private string? GetExternalLinkDescription(RelevancesKeyValueModel item)
    {
        return item.DisplayName switch
        {
            "VNDB" => item.DisplayValue + (string.IsNullOrWhiteSpace(item.DisplayValue) ? "" : " - ") + "VNDB.org力争成为一个关于视觉小说的全面的信息数据库",
            _ => item.DisplayValue
        };
    }

    private static string DisplayTextOrFallback(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }
}
