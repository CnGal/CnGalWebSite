@page "/videos/index/{Id:long}"
@inject IVideoQueryService VideoQueryService
@inject IExamineQueryService ExamineQueryService
@implements IDisposable
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.MainSite.Shared.Components.Features.Video.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Examine
@using CnGalWebSite.MainSite.Shared.Services

<CgPageMeta Title="@(Model is null ? null : GetDisplayTitle())" Description="@(Model?.BriefIntroduction)" Image="@(Model?.MainPicture)" />

@if (ErrorMessage is not null)
{
    <section class="video-not-found">
        <h1>视频加载失败</h1>
        <p>@ErrorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (Model is not null)
{
    <article class="video-page">
        @if (HasAtmosphere())
        {
            <CgAtmosphere BackgroundPicture="@Model.BackgroundPicture" SmallBackgroundPicture="@Model.SmallBackgroundPicture" />
        }

        <header class="video-header">
            <VideoHero Title="@GetDisplayTitle()"
                       BriefIntroduction="@Model.BriefIntroduction"
                       MainPicture="@Model.MainPicture"
                       TypeText="@GetTypeText()"
                       Duration="@Model.Duration"
                       VideoId="@Id"
                       WatchUrl="@(Model.RelatedOutlinks.FirstOrDefault()?.Link ?? Model.RelatedOutlinks.FirstOrDefault()?.DisplayValue)" />

            <div class="video-info-bar">
                <VideoAuthorCard AuthorName="@Model.AuthorName"
                                 AuthorAvatar="@Model.AuthorAvatar"
                                 AuthorId="@Model.AuthorId"
                                 OriginalAuthor="@Model.OriginalAuthor"
                                 IsOriginal="Model.IsAuthorOriginal"
                                 Ranks="@(Model.AuthorRanks)" />

                <VideoBasicInfo ReaderCount="Model.ReaderCount"
                                CommentCount="Model.CommentCount"
                                Type="@Model.Type"
                                Copyright="Model.Copyright"
                                IsInteractive="Model.IsInteractive"
                                PublishTime="Model.PubishTime"
                                CreateTime="Model.CreateTime"
                                LastEditTime="Model.LastEditTime" />
            </div>
        </header>

        @if (Model.IsHidden)
        {
            <CgAlert Variant="warning" Class="video-hidden-alert">
                当前视频处于隐藏状态，如果你看到了这个提示，请立即联系管理员
            </CgAlert>
        }

        <main class="video-main-content">
            @if (Model.Pictures.Count > 0)
            {
                <EntrySection Title="截图" Icon="mdiImageOutline">
                    <EntryImageGrid Pictures="Model.Pictures" MaxCount="12" EntryName="@Model.Name" DisplayTextOrFallback="ExternalLinkHelper.DisplayTextOrFallback" />
                </EntrySection>
            }

            @if (!string.IsNullOrWhiteSpace(Model.MainPage))
            {
                <div class="video-prose">
                    <CgHtmlContent Content="@Model.MainPage" />
                </div>
            }
        </main>

        <footer class="video-footer-related">
            <EntrySection Title="相关词条" Icon="mdiLinkVariant" Show="Model.RelatedEntries.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="Model.RelatedEntries.Count > 9">
                    @foreach (var item in Model.RelatedEntries)
                    {
                        <li>
                            <EntryCardItem Url="@($"/entries/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" IsSquareCover="item.Type == EntryType.Role || item.Type == EntryType.Staff" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="相关文章" Icon="mdiTextBoxOutline" Show="Model.RelatedArticles.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="Model.RelatedArticles.Count > 9">
                    @foreach (var item in Model.RelatedArticles)
                    {
                        <li>
                            <EntryCardItem Url="@ExternalLinkHelper.GetArticleLink(item)" Target="@ExternalLinkHelper.GetTarget(item.Link)" Image="@item.MainImage" Title="@item.Name" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="相关视频" Icon="mdiAnimationPlayOutline" Show="Model.RelatedVideos.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="Model.RelatedVideos.Count > 9">
                    @foreach (var item in Model.RelatedVideos)
                    {
                        <li>
                            <EntryCardItem Url="@($"/videos/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" Icon="mdiPlayCircleOutline" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="外部链接" Icon="mdiLinkVariant" Show="Model.RelatedOutlinks.Count > 0">
                <EntryOutlinkList Links="Model.RelatedOutlinks"
                                  MaxCount="8"
                                  GetExternalLinkIcon="ExternalLinkHelper.GetExternalLinkIcon"
                                  GetExternalLinkImage="ExternalLinkHelper.GetExternalLinkImage"
                                  GetExternalLinkDescription="ExternalLinkHelper.GetExternalLinkDescription"
                                  DisplayTextOrFallback="ExternalLinkHelper.DisplayTextOrFallback" />
            </EntrySection>

            <CgMiniModeContainer>
                <EditRecordListCard Records="_editRecords" />
            </CgMiniModeContainer>

            <CnGalWebSite.MainSite.Shared.Components.Features.Comment.CommentSection
                Type="CommentType.CommentVideo"
                ObjectId="@Model.Id.ToString()"
                CanComment="Model.CanComment" />
        </footer>
    </article>
}
else
{
    <section class="video-loading" aria-label="加载中">
        <CgProgressRing Size="lg" Color="var(--cg-color-primary)" />
        <span class="video-loading-text">加载中...</span>
    </section>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private VideoDetailViewModel? Model;
    private IReadOnlyList<ExaminedNormalListModel>? _editRecords;
    private string? ErrorMessage;
    private CancellationTokenSource? _cts;

    protected override async Task OnParametersSetAsync()
    {
        if (Model?.Id == Id)
        {
            return;
        }

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        try
        {
            Model = null;
            _editRecords = null;
            ErrorMessage = null;

var videoTask = VideoQueryService.GetVideoDetailAsync(Id, cancellationToken: _cts.Token);
var editRecordsTask = ExamineQueryService.GetVideoEditRecordsAsync(Id, cancellationToken: _cts.Token);

            var result = await videoTask;
            if (result.Success && result.Data is not null)
            {
                ErrorMessage = null;
                Model = result.Data;

                var editRecordsResult = await editRecordsTask;
                _editRecords = editRecordsResult.Success ? editRecordsResult.Data : null;
                return;
            }

            Model = null;
            _editRecords = null;
            ErrorMessage = result.Error?.Message ?? "请稍后重试";
        }
        catch (OperationCanceledException)
        {
            // Component disposed or parameters changed, ignore
        }
    }

    private string GetDisplayTitle()
    {
        if (Model is null)
        {
            return string.Empty;
        }

        return string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.Name : Model.DisplayName;
    }

    private string GetTypeText()
    {
        if (Model is null || string.IsNullOrWhiteSpace(Model.Type))
        {
            return "视频";
        }

        return Model.Type;
    }

    private bool HasAtmosphere()
    {
        if (Model is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(Model.BackgroundPicture) is false
            || string.IsNullOrWhiteSpace(Model.SmallBackgroundPicture) is false;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }

}
