@page "/lotteries/createlottery"
@page "/lotteries/editlottery/{Id:long}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize(Roles = "Admin")]
@using CnGalWebSite.DataModel.ViewModel.Lotteries
@using CnGalWebSite.MainSite.Shared.Components.Features.Lottery.Editor
@using CnGalWebSite.SDK.MainSite.Models
@using System.Text.Json
@using Microsoft.JSInterop
@inject ILotteryCommandService LotteryCommandService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ICgToastService ToastService
@implements IDisposable

<CgPageMeta Title="@(IsCreate ? "创建抽奖" : "编辑抽奖")" />

@if (IsLoading)
{
    <section class="lottery-edit-loading" aria-label="加载中">
        <div class="lottery-edit-loading-spinner"></div>
        <p>正在获取数据...</p>
    </section>
}
else if (LoadErrorMessage != null)
{
    <section class="lottery-edit-error">
        <h1>加载失败</h1>
        <p>@LoadErrorMessage</p>
        <CgButton Variant="primary" OnClick="LoadDataAsync">重试</CgButton>
    </section>
}
else if (Model != null)
{
    <article class="lottery-edit-page">
        <div class="lottery-edit-layout">
            <LotteryEditorSidebar IsCreate="IsCreate"
                                  IsSubmitting="IsSubmitting"
                                  HasDraftRecovered="HasDraftRecovered"
                                  OnDiscardDraft="DiscardDraft"
                                  OnSubmit="SubmitAsync"
                                  OnCancel="Cancel" />

            <main class="lottery-edit-main">
                <LotteryMainEditor Model="Model" EntryGameItems="_entryGameItems" />
                <LotteryIntroEditor Model="Model" />
                <LotteryAwardsEditor Model="Model" ToastService="ToastService" />
            </main>
        </div>

    </article>
}

@code {
    [Parameter]
    public long? Id { get; set; }

    private bool IsCreate => Id is null or <= 0;

    private bool IsLoading = true;
    private string? LoadErrorMessage;

    private bool IsSubmitting = false;

    private EditLotteryModel? Model;

    private System.Threading.Timer? _autoSaveTimer;
    private string DraftKey => IsCreate ? "LotteryDraft_Create" : $"LotteryDraft_Edit_{Id}";

    private bool HasDraftRecovered = false;
    private EditLotteryModel? OriginalData;
    private List<string> _entryGameItems = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        _autoSaveTimer = new System.Threading.Timer(AutoSaveCallback, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void AutoSaveCallback(object? state)
    {
        _ = InvokeAsync(async () =>
        {
            if (Model != null && !IsSubmitting && !IsLoading)
            {
                try
                {
                    var json = JsonSerializer.Serialize(Model);
                    await JS.InvokeVoidAsync("localStorage.setItem", DraftKey, json);
                }
                catch { /* Ignore local storage errors */ }
            }
        });
    }

    public void Dispose()
    {
        _autoSaveTimer?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        LoadErrorMessage = null;
        StateHasChanged();

        try
        {
            // 获取游戏词条列表
            var itemsResult = await LotteryCommandService.GetEntryGameItemsAsync();
            if (itemsResult.Success && itemsResult.Data != null)
            {
                _entryGameItems = itemsResult.Data;
            }

            if (IsCreate)
            {
                Model = new EditLotteryModel
                {
                    BeginTime = DateTime.Now,
                    EndTime = DateTime.Now,
                    LotteryTime = DateTime.Now,
                };
            }
            else
            {
                var result = await LotteryCommandService.GetLotteryEditAsync(Id!.Value);
                if (result.Success && result.Data != null)
                {
                    Model = result.Data;
                }
                else
                {
                    LoadErrorMessage = result.Error?.Message ?? "获取抽奖编辑数据失败";
                    return;
                }
            }

            OriginalData = JsonSerializer.Deserialize<EditLotteryModel>(JsonSerializer.Serialize(Model));

            // 尝试恢复草稿
            try
            {
                var draftStr = await JS.InvokeAsync<string>("localStorage.getItem", DraftKey);
                if (!string.IsNullOrWhiteSpace(draftStr))
                {
                    var draft = JsonSerializer.Deserialize<EditLotteryModel>(draftStr);
                    if (draft != null)
                    {
                        Model = draft;
                        HasDraftRecovered = true;
                    }
                }
            }
            catch { }
        }
        catch (Exception ex)
        {
            LoadErrorMessage = "发生未知错误：" + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task DiscardDraft()
    {
        if (OriginalData != null)
        {
            Model = JsonSerializer.Deserialize<EditLotteryModel>(JsonSerializer.Serialize(OriginalData))!;
            HasDraftRecovered = false;
            await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        if (Model == null || IsSubmitting) return;

        var validationResult = Model.Validate();
        if (!validationResult.Successful)
        {
            ToastService.Show("校验失败", validationResult.Error ?? "请检查表单是否填写正确", "error");
            return;
        }

        IsSubmitting = true;
        StateHasChanged();

        try
        {
            SdkResult<long> result;

            if (IsCreate)
            {
                result = await LotteryCommandService.CreateLotteryAsync(Model);
            }
            else
            {
                result = await LotteryCommandService.EditLotteryAsync(Model);
            }

            if (result.Success)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
                NavigationManager.NavigateTo($"/lotteries/index/{result.Data}");
            }
            else
            {
                ToastService.Show(IsCreate ? "创建失败" : "编辑失败", result.Error?.Message ?? "提交时出现问题", "error");
            }
        }
        catch (Exception ex)
        {
            ToastService.Show("发生错误", ex.Message, "error");
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        if (IsCreate)
        {
            NavigationManager.NavigateTo("/lotteries");
        }
        else
        {
            NavigationManager.NavigateTo($"/lotteries/index/{Id}");
        }
    }
}
