@page "/entries/index/{Id:int}"
@inject IEntryQueryService EntryQueryService
@inject IPlayedGameQueryService PlayedGameQueryService
@inject IPeripheryQueryService PeripheryQueryService
@inject IFavoriteFolderQueryService FavoriteFolderQueryService
@inject IExamineQueryService ExamineQueryService
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.Search
@using CnGalWebSite.DataModel.ViewModel.Peripheries
@using CnGalWebSite.DataModel.ViewModel.Favorites
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.MainSite.Shared.Services
@using CnGalWebSite.Extensions
@using CnGalWebSite.SDK.MainSite.Infrastructure

<CgPageMeta Title="@(Model?.Name)" Description="@(Model?.BriefIntroduction)" Image="@(Model?.MainPicture)" />

@if (ErrorMessage is not null)
{
    <section class="entry-not-found">
        <h1>条目加载失败</h1>
        <p>@ErrorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (Model is not null)
{
    <article class="entry-page">
        @if (HasAtmosphere())
        {
            <EntryAtmosphere BackgroundPicture="@Model.BackgroundPicture" SmallBackgroundPicture="@Model.SmallBackgroundPicture" />
        }

        <EntryHero Name="@Model.Name" AnotherName="@Model.AnotherName" BriefIntroduction="@Model.BriefIntroduction"
                   TypeText="@GetTypeText(Model.Type)" IsEdit="Model.IsEdit" HeroImageUrl="@GetHeroImageUrl()"
                   IsSquareCover="IsSquareCover()" ProductionGroups="Model.ProductionGroups" Publishers="Model.Publishers"
                   BuildEntryUrl="BuildEntryUrl" EntryId="Id" />

        <EntrySpecialTips IsHidden="Model.IsHidden" Type="Model.Type" />

        <section class="entry-layout" aria-label="详情布局">
            @* 移动端：两个容器 display:contents，所有 cell 参与统一 order 排序
               桌面端：两个容器变为独立 flex 列，各列卡片紧密堆叠 *@

            <div class="entry-main-col">
                <div class="entry-cell entry-cell--audio">
                    <EntryCard Title="音频" Icon="mdiMusicCircleOutline" Show="Model.Audio.Count > 0">
                        <EntryAudioList Audio="Model.Audio" MaxCount="6" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--pictures">
                    <EntrySection Title="图片" Icon="mdiImageOutline" Show="Model.Pictures.Count > 0">
                        <EntryImageGrid Pictures="Model.Pictures" MaxCount="12" EntryName="@Model.Name" DisplayTextOrFallback="ExternalLinkHelper.DisplayTextOrFallback" />
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--mainpage">
                    <EntryCard Title="正文主页" Icon="mdiTextBoxOutline" Show="!string.IsNullOrWhiteSpace(Model.MainPage)">
                        <CgHtmlContent Content="@Model.MainPage" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--news">
                    <EntryCard Title="动态时间线" Icon="mdiTimelineTextOutline" Show="Model.NewsOfEntry.Count > 0">
                        <EntryNewsList News="Model.NewsOfEntry" MaxCount="10" GetNewsLink="GetNewsLink" GetTarget="ExternalLinkHelper.GetTarget" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--videos">
                    <EntrySection Title="相关视频" Icon="mdiAnimationPlayOutline" Show="Model.VideoRelevances.Count > 0">
                        <EntryCardList LimitCount="9" ShowExpandButton="Model.VideoRelevances.Count > 9">
                            @foreach (var item in Model.VideoRelevances)
                            {
                                <li>
                                    <EntryCardItem Url="@($"/videos/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" Icon="mdiPlayCircleOutline" />
                                </li>
                            }
                        </EntryCardList>
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--relevances">
                    @RenderRelevancesBlocks
                </div>

                <div class="entry-cell entry-cell--articles">
                    <EntrySection Title="相关文章" Icon="mdiTextBoxOutline" Show="Model.ArticleRelevances.Count > 0">
                        <EntryCardList LimitCount="9" ShowExpandButton="Model.ArticleRelevances.Count > 9">
                            @foreach (var item in Model.ArticleRelevances)
                            {
                                <li>
                                    <EntryCardItem Url="@($"/articles/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" />
                                </li>
                            }
                        </EntryCardList>
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--periphery">
                    <EntryPeripheryCard Model="PeripheryOverview" />
                </div>

                <div class="entry-cell entry-cell--score">
                    @* 仅游戏类词条显示评分区域 *@
                    @if (Model.Type == EntryType.Game)
                    {
                        @* 登录用户使用交互式评分区域（支持编辑后实时刷新），未登录用户使用静态渲染 *@
                        <AuthorizeView>
                            <Authorized>
                                <EntryScoreSection EntryId="Id" />
                            </Authorized>
                            <NotAuthorized>
                                @if (ScoreOverview is not null)
                                {
                                    <EntryScoreOverview Model="ScoreOverview" />
                                }
                            </NotAuthorized>
                        </AuthorizeView>
                    }
                </div>

                <div class="entry-cell entry-cell--comment">
                    <CnGalWebSite.MainSite.Shared.Components.Features.Comment.CommentSection
                        Type="CommentType.CommentEntries"
                        ObjectId="@Model.Id.ToString()"
                        CanComment="Model.CanComment" />
                </div>
            </div>

            <div class="entry-side-col">
                <div class="entry-cell entry-cell--booking">
                    <EntryBookingCard Booking="Model.Booking" ShowGoals="true" />
                </div>

                <div class="entry-cell entry-cell--info">
                    <EntryCard Title="基础信息" Icon="mdiInformationOutline" Show="Model.Information.Count > 0">
                        <EntryInfoList Information="Model.Information" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--tags">
                    <EntryCard Title="标签" Icon="mdiTagMultipleOutline" Show="Model.Tags.Count > 0">
                        <EntryTagList Tags="Model.Tags" MaxCount="24" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--release">
                    <EntrySection Title="发行信息" Icon="mdiCalendarClockOutline" Show="Model.Releases.Count > 0">
                        <EntryReleaseCards Releases="Model.Releases"
                                           GetPlatformIcon="GetPlatformIcon"
                                           GetPlatformImage="GetPlatformImage"
                                           GetPublishPlatformName="GetPublishPlatformName"
                                           GetReleaseTypeText="GetReleaseTypeText"
                                           GetCurrencyPrefix="GetCurrencyPrefix"
                                           GetGamePlatformName="GetGamePlatformName" />
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--drawing">
                    <EntryVerticalDrawingCard Type="Model.Type" Image="@Model.MainPicture" Name="@Model.Name" />
                </div>

                <div class="entry-cell entry-cell--staff">
                    <EntryCard Title="Staff" Icon="mdiAccountGroupOutline" Show="Model.Staffs.Count > 0">
                        <EntryStaffGroupList Staffs="Model.Staffs" MaxGroupCount="8" MaxPositionCount="5" />
                    </EntryCard>
                </div>

                <div class="entry-cell entry-cell--roles">
                    <EntrySection Title="登场角色" Icon="mdiAccountStarOutline" Show="Model.Roles.Count > 0">
                        <EntryRoleList Roles="Model.Roles" MaxCount="8" BuildEntryUrl="BuildEntryUrl" />
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--outlinks">
                    <EntrySection Title="外部链接" Icon="mdiLinkVariant" Show="Model.IsHideOutlink == false && Model.OtherRelevances.Count > 0">
                        <EntryOutlinkList Links="Model.OtherRelevances"
                                          MaxCount="8"
                                          GetExternalLinkIcon="ExternalLinkHelper.GetExternalLinkIcon"
                                          GetExternalLinkImage="ExternalLinkHelper.GetExternalLinkImage"
                                          GetExternalLinkDescription="ExternalLinkHelper.GetExternalLinkDescription"
                                          DisplayTextOrFallback="ExternalLinkHelper.DisplayTextOrFallback" />
                    </EntrySection>
                </div>

                <div class="entry-cell entry-cell--records">
                    <EntryEditRecordCard Records="EditRecords" />
                </div>

                <div class="entry-cell entry-cell--catalog">
                    <EntryCatalogCard Folders="RelateFolders" />
                </div>
            </div>
        </section>
    </article>
}
else
{
    <section class="entry-loading" aria-label="加载中">
        <CgProgressRing Size="lg" Color="var(--cg-color-primary)" />
        <span class="entry-loading-text">加载中...</span>
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EntryDetailViewModel? Model;
    private PlayedGameOverviewViewModel? ScoreOverview;
    private GameOverviewPeripheryListModel? PeripheryOverview;
    private IReadOnlyList<FavoriteFolderOverviewModel>? RelateFolders;
    private IReadOnlyList<ExaminedNormalListModel>? EditRecords;
    private string? ErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (Model?.Id == Id)
        {
            return;
        }

        Model = null;
        ScoreOverview = null;
        PeripheryOverview = null;
        RelateFolders = null;
        EditRecords = null;
        ErrorMessage = null;

        // 并行请求词条详情、周边概览、相关目录、编辑记录
        // 注意：评分概览仅对游戏类型有效，延迟到确认类型后再请求
        var entryTask = EntryQueryService.GetEntryDetailAsync(Id);
        var peripheryTask = PeripheryQueryService.GetEntryOverviewPeripheriesAsync(Id);
        var catalogTask = FavoriteFolderQueryService.GetRelateFavoriteFoldersAsync(FavoriteObjectType.Entry, Id);
        var editRecordsTask = ExamineQueryService.GetEntryEditRecordsAsync(Id);

        var result = await entryTask;
        if (result.Success && result.Data is not null)
        {
            ErrorMessage = null;
            Model = result.Data;

            // 仅游戏类词条加载评分概览
            if (Model.Type == EntryType.Game)
            {
                var scoreResult = await PlayedGameQueryService.GetOverviewAsync(Id);
                ScoreOverview = scoreResult.Success ? scoreResult.Data : null;
            }
            else
            {
                ScoreOverview = null;
            }

            // 加载周边概览
            var peripheryResult = await peripheryTask;
            PeripheryOverview = peripheryResult.Success ? peripheryResult.Data : null;

            // 加载相关目录
            var catalogResult = await catalogTask;
            RelateFolders = catalogResult.Success ? catalogResult.Data : null;

            // 加载编辑记录
            var editRecordsResult = await editRecordsTask;
            EditRecords = editRecordsResult.Success ? editRecordsResult.Data : null;

            return;
        }

        Model = null;
        ScoreOverview = null;
        PeripheryOverview = null;
        RelateFolders = null;
        EditRecords = null;
        ErrorMessage = result.Error?.Message ?? "请稍后重试";
    }


    private bool HasAtmosphere()
    {
        if (Model is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(Model.BackgroundPicture) is false
            || string.IsNullOrWhiteSpace(Model.SmallBackgroundPicture) is false;
    }

    private bool IsSquareCover()
    {
        if (Model is null)
        {
            return false;
        }

        return Model.Type is EntryType.Role or EntryType.Staff;
    }

    private string GetHeroImageUrl()
    {
        if (Model is null)
        {
            return string.Empty;
        }

        if (Model.Type is EntryType.Role or EntryType.Staff)
        {
            return string.IsNullOrWhiteSpace(Model.Thumbnail) ? Model.MainPicture : Model.Thumbnail;
        }

        return string.IsNullOrWhiteSpace(Model.MainPicture) ? Model.Thumbnail : Model.MainPicture;
    }

    private static string BuildEntryUrl(int id)
    {
        return $"/entries/index/{id}";
    }

    private static string GetTypeText(EntryType type)
    {
        return type.GetDisplayName();
    }

    private static string GetNewsLink(NewsModel item)
    {
        return ExternalLinkHelper.IsExternalLink(item.Link) ? item.Link : $"/articles/index/{item.ArticleId}";
    }

    private bool HasRelatedContent()
    {
        if (Model is null)
        {
            return false;
        }

        return Model.VideoRelevances.Count > 0
            || Model.EntryRelevances.Count > 0
            || Model.ArticleRelevances.Count > 0
            || Model.StaffGames.Count > 0;
    }

    private string GetPublishPlatformName(GameReleaseViewModel release)
    {
        if (release.PublishPlatformType == PublishPlatformType.Other && !string.IsNullOrWhiteSpace(release.PublishPlatformName))
        {
            return release.PublishPlatformName;
        }
        return release.PublishPlatformType.GetDisplayName();
    }

    private string GetPlatformIcon(GameReleaseViewModel release)
    {
        if (release.PublishPlatformType == PublishPlatformType.Other && !string.IsNullOrWhiteSpace(release.PublishPlatformName))
        {
            var lowerName = release.PublishPlatformName.ToLower();
            if (lowerName.Contains("b站") || lowerName.Contains("bilibili")) return "mdiTelevisionPlay";
            if (lowerName.Contains("微博")) return "mdiWechat";
        }
        return release.PublishPlatformType switch
        {
            PublishPlatformType.Steam => "mdiSteam",
            PublishPlatformType.AppStore => "mdiApple",
            PublishPlatformType.GooglePlay => "mdiGooglePlay",
            PublishPlatformType.NS => "mdiNintendoSwitch",
            PublishPlatformType.Epic => "mdiGamepadVariantOutline",
            _ => "mdiGamepadVariantOutline"
        };
    }

    private string? GetPlatformImage(GameReleaseViewModel release)
    {
        var image = release.PublishPlatformType switch
        {
            PublishPlatformType.Steam => "Steam.png",
            PublishPlatformType.AppStore => "AppStore.png",
            PublishPlatformType.GooglePlay => "GooglePlay.png",
            PublishPlatformType.DLsite => "DLsite.png",
            PublishPlatformType.NS => "Nintendo_Switch.png",
            PublishPlatformType.TapTap => "TapTap.png",
            PublishPlatformType.Epic => "Epic.png",
            _ => null
        };

        if (image == null && string.IsNullOrWhiteSpace(release.PublishPlatformName) == false)
        {
            var lowerName = release.PublishPlatformName.ToLower();
            if (lowerName.Contains("b站") || lowerName.Contains("bilibili"))
            {
                image = "bilibili.png";
            }
            else if (lowerName.Contains("微博"))
            {
                image = "weibo.png";
            }
            else if (lowerName.Contains("贴吧") || lowerName.Contains("百度"))
            {
                image = "BaiDuWiki.png";
            }
            else if (lowerName.Contains("方块游戏"))
            {
                image = "CraftGame.png";
            }
        }

        if (string.IsNullOrWhiteSpace(image))
        {
            return null;
        }

        return "https://res.cngal.org/_content/CnGalWebSite.Shared/images/" + image;
    }

    private string GetGamePlatformName(GamePlatformType type)
    {
        return type.GetDisplayName();
    }

    private string GetReleaseTypeText(GameReleaseType type)
    {
        return type.GetDisplayName();
    }

    private string GetCurrencyPrefix(CurrencyCode code)
    {
        return code switch
        {
            CurrencyCode.CNY => "¥",
            CurrencyCode.USD => "$",
            CurrencyCode.HKD => "HK$",
            _ => code.ToString() + " "
        };
    }

    private RenderFragment RenderRelevanceGroup(string title, string icon, IEnumerable<EntryInforTipViewModel> sourceItems) => __builder =>
    {
        var items = sourceItems.ToList();
        if (items.Count > 0)
        {
            var displayTitle = items.Count > 4 ? $"{title} ({items.Count})" : title;
            <EntrySection Title="@displayTitle" Icon="@icon" Show="true">
                <EntryCardList LimitCount="9" ShowExpandButton="items.Count > 9">
                    @foreach (var item in items)
                    {
                        <li>
                            <EntryCardItem Url="@BuildEntryUrl(item.Id)" Image="@item.MainImage" Title="@item.Name" IsSquareCover="item.Type == EntryType.Role || item.Type == EntryType.Staff" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>
        }
    };

    private RenderFragment RenderRelevancesBlocks => __builder =>
    {
        @RenderRelevanceGroup("配音作品", "mdiMicrophoneOutline", GetCastWorks())
        @RenderRelevanceGroup("制作作品", "mdiHammerWrench", GetProductionGroupWorks())
        @RenderRelevanceGroup("发行作品", "mdiPublish", GetPublisherWorks())
        @RenderRelevanceGroup("参与作品", "mdiHandshakeOutline", GetParticipationWorks())
        @RenderRelevanceGroup("特别感谢", "mdiHeartOutline", GetAppreciatedParticWorks())

        @RenderRelevanceGroup("相关游戏", "mdiGamepadVariantOutline", GetGameRelevances())
        @RenderRelevanceGroup("相关组织", "mdiDomain", GetGroupRelevances())
        @RenderRelevanceGroup("相关STAFF", "mdiAccountTieOutline", GetStaffRelevances())
        @RenderRelevanceGroup("相关角色", "mdiAccountStarOutline", GetRoleRelevances())
    };

    private IEnumerable<EntryInforTipViewModel> GetCastWorks()
    {
        if (Model is null) return Array.Empty<EntryInforTipViewModel>();
        return Model.StaffGames.Where(s => s.AddInfors != null && s.AddInfors.Any(a => a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.CV)));
    }

    private IEnumerable<EntryInforTipViewModel> GetProductionGroupWorks()
    {
        if (Model is null) return Array.Empty<EntryInforTipViewModel>();
        return Model.StaffGames.Where(s => s.AddInfors != null && s.AddInfors.Any(a => a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.ProductionGroup)));
    }

    private IEnumerable<EntryInforTipViewModel> GetPublisherWorks()
    {
        if (Model is null) return Array.Empty<EntryInforTipViewModel>();
        return Model.StaffGames.Where(s => s.AddInfors != null && s.AddInfors.Any(a => a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.Publisher) &&
            a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.ProductionGroup) == false));
    }

    private IEnumerable<EntryInforTipViewModel> GetParticipationWorks()
    {
        if (Model is null) return Array.Empty<EntryInforTipViewModel>();
        return Model.StaffGames.Where(s => s.AddInfors == null || s.AddInfors.Any(a => a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) != PositionGeneralType.CV && StaffHelper.GetGeneralType(c.DisplayName) != PositionGeneralType.SpecialThanks) &&
            a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.ProductionGroup || StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.Publisher) == false));
    }

    private IEnumerable<EntryInforTipViewModel> GetAppreciatedParticWorks()
    {
        if (Model is null) return Array.Empty<EntryInforTipViewModel>();
        return Model.StaffGames.Where(s => s.AddInfors != null && s.AddInfors.Any(a => a.Contents.Any(c => StaffHelper.GetGeneralType(c.DisplayName) == PositionGeneralType.SpecialThanks)));
    }

    private IEnumerable<EntryInforTipViewModel> GetGameRelevances()
    {
        return Model?.EntryRelevances.Where(s => s.Type == EntryType.Game) ?? Array.Empty<EntryInforTipViewModel>();
    }

    private IEnumerable<EntryInforTipViewModel> GetGroupRelevances()
    {
        return Model?.EntryRelevances.Where(s => s.Type == EntryType.ProductionGroup) ?? Array.Empty<EntryInforTipViewModel>();
    }

    private IEnumerable<EntryInforTipViewModel> GetStaffRelevances()
    {
        return Model?.EntryRelevances.Where(s => s.Type == EntryType.Staff) ?? Array.Empty<EntryInforTipViewModel>();
    }

    private IEnumerable<EntryInforTipViewModel> GetRoleRelevances()
    {
        return Model?.EntryRelevances.Where(s => s.Type == EntryType.Role) ?? Array.Empty<EntryInforTipViewModel>();
    }
}
