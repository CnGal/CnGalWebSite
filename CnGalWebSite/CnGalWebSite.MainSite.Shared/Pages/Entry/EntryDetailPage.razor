@page "/entries/index/{Id:int}"
@inject IEntryQueryService EntryQueryService
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel
@using CnGalWebSite.DataModel.ViewModel.Search

<PageTitle>@(Model is null ? "条目详情" : $"{Model.Name} - 词条详情")</PageTitle>

@if (ErrorMessage is not null)
{
    <section class="entry-not-found">
        <h1>条目加载失败</h1>
        <p>@ErrorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (Model is not null)
{
    <article class="entry-page">
        @if (HasAtmosphere())
        {
            <div class="entry-atmosphere" aria-hidden="true">
                @if (string.IsNullOrWhiteSpace(Model.BackgroundPicture) is false)
                {
                    <div class="entry-atmosphere-bg" style="@($"background-image:url('{Model.BackgroundPicture}')")"></div>
                }
                @if (string.IsNullOrWhiteSpace(Model.SmallBackgroundPicture) is false)
                {
                    <div class="entry-atmosphere-bg entry-atmosphere-bg--small" style="@($"background-image:url('{Model.SmallBackgroundPicture}')")"></div>
                }
            </div>
        }

        <header class="entry-hero @(IsSquareCover() ? "entry-hero--square" : "entry-hero--wide")">
            <div class="entry-hero-side">
                @if (string.IsNullOrWhiteSpace(GetHeroImageUrl()) is false)
                {
                    <img src="@GetHeroImageUrl()" alt="@Model.Name" class="entry-cover" loading="eager" decoding="async" />
                }
                else
                {
                    <div class="entry-cover entry-cover--empty" aria-label="暂无封面">NO IMAGE</div>
                }
            </div>
            <div class="entry-hero-main">
                <div class="entry-hero-top">
                    <span class="entry-type">@GetTypeText(Model.Type)</span>
                    @if (Model.IsEdit)
                    {
                        <span class="entry-status entry-status--edit">可编辑状态</span>
                    }
                </div>
                <h1>@Model.Name</h1>
                @if (string.IsNullOrWhiteSpace(Model.AnotherName) is false)
                {
                    <p class="entry-another-name">别称：@Model.AnotherName</p>
                }
                @if (string.IsNullOrWhiteSpace(Model.BriefIntroduction) is false)
                {
                    <p class="entry-brief">@Model.BriefIntroduction</p>
                }
                @if (Model.ProductionGroups.Count > 0 || Model.Publishers.Count > 0)
                {
                    <div class="entry-people-chips">
                        @if (Model.ProductionGroups.Count > 0)
                        {
                            @foreach (var item in Model.ProductionGroups)
                            {
                                <a href="@BuildEntryUrl(item.Id)" class="entry-chip">制作组：@item.DisplayName</a>
                            }
                        }
                        @if (Model.Publishers.Count > 0)
                        {
                            @foreach (var item in Model.Publishers)
                            {
                                <a href="@BuildEntryUrl(item.Id)" class="entry-chip">发行商：@item.DisplayName</a>
                            }
                        }
                    </div>
                }
            </div>
        </header>

        @if (Model.IsHidden || Model.Type == EntryType.Staff)
        {
            <section class="entry-special-tips" aria-label="特殊提示">
                @if (Model.IsHidden)
                {
                    <p class="entry-tip entry-tip--warning">当前词条处于隐藏状态，请谨慎传播并联系管理员确认。</p>
                }
                @if (Model.Type == EntryType.Staff)
                {
                    <p class="entry-tip entry-tip--danger">该词条可能涉及现实人物，请保持客观描述并谨慎编辑。</p>
                }
            </section>
        }

        <section class="entry-layout entry-layout--desktop" aria-label="桌面详情布局">
            <main class="entry-main-col">
                @if (Model.Audio.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiMusicCircleOutline" />音频</h2>
                        <ul class="entry-audio-list">
                            @foreach (var item in Model.Audio.Take(6))
                            {
                                <li>
                                    <div>
                                        <h3>@item.Name</h3>
                                        @if (string.IsNullOrWhiteSpace(item.BriefIntroduction) is false)
                                        {
                                            <p>@item.BriefIntroduction</p>
                                        }
                                    </div>
                                    <audio controls preload="none" src="@item.Url"></audio>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.Pictures.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiImageOutline" />图片</h2>
                        <ul class="entry-image-grid">
                            @foreach (var item in Model.Pictures.Take(12))
                            {
                                <li>
                                    <a href="@item.Url" target="_blank" rel="noopener noreferrer">
                                        <img src="@item.Url" alt="@DisplayTextOrFallback(item.Note, Model.Name)" loading="lazy" decoding="async" />
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (string.IsNullOrWhiteSpace(Model.MainPage) is false)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiTextBoxOutline" />正文主页</h2>
                        <div class="entry-markdown">
                            @(new MarkupString(Model.MainPage))
                        </div>
                    </section>
                }

                @if (Model.NewsOfEntry.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiTimelineTextOutline" />动态时间线</h2>
                        <ul class="entry-news-list">
                            @foreach (var item in Model.NewsOfEntry.Take(10))
                            {
                                <li>
                                    <a href="@GetNewsLink(item)" target="@GetTarget(item.Link)" rel="noopener noreferrer">@item.Title</a>
                                    <span>@item.HappenedTime.ToString("yyyy-MM-dd")</span>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.VideoRelevances.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiAnimationPlayOutline" />相关视频</h2>
                        <ul class="entry-card-list">
                            @foreach (var item in Model.VideoRelevances.Take(8))
                            {
                                <li>
                                    <a href="@($"/videos/index/{item.Id}")" class="entry-card-item">
                                        <div class="entry-card-item-image">
                                            <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                        </div>
                                        <div class="entry-card-item-content">
                                            <span class="entry-card-item-title">@item.Name</span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }
                
                @if (Model.EntryRelevances.Count > 0 || Model.StaffGames.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiLinkVariant" />相关词条</h2>
                        <ul class="entry-card-list">
                            @foreach (var item in Model.EntryRelevances.Take(8))
                            {
                                <li>
                                    <a href="@BuildEntryUrl(item.Id)" class="entry-card-item">
                                        <div class="entry-card-item-image">
                                            <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                        </div>
                                        <div class="entry-card-item-content">
                                            <span class="entry-card-item-title">@item.Name</span>
                                        </div>
                                    </a>
                                </li>
                            }
                            @foreach (var item in Model.StaffGames.Take(4))
                            {
                                <li>
                                    <a href="@BuildEntryUrl(item.Id)" class="entry-card-item">
                                        <div class="entry-card-item-image">
                                            <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                        </div>
                                        <div class="entry-card-item-content">
                                            <span class="entry-card-item-title">@item.Name</span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }
                
                @if (Model.ArticleRelevances.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiTextBoxOutline" />相关文章</h2>
                        <ul class="entry-card-list">
                            @foreach (var item in Model.ArticleRelevances.Take(8))
                            {
                                <li>
                                    <a href="@GetArticleLink(item)" target="@GetTarget(item.Link)" rel="noopener noreferrer" class="entry-card-item">
                                        <div class="entry-card-item-image">
                                            <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                        </div>
                                        <div class="entry-card-item-content">
                                            <span class="entry-card-item-title">@item.Name</span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.CanComment)
                {
                    <section id="comments" class="entry-card entry-card--comment">
                        <h2><CgMdiIcon Name="mdiCommentTextOutline" />评论入口</h2>
                        <p>可前往评论区参与讨论，分享你的看法与补充信息。</p>
                        <a class="entry-action-btn" href="@($"/space/comments?type=entry&id={Model.Id}")">前往评论区</a>
                    </section>
                }
            </main>

            <aside class="entry-side-col">
                @if (Model.Booking is not null && Model.Booking.Goals.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiGiftOutline" />预约</h2>
                        <p class="entry-booking-count">当前预约：@Model.Booking.BookingCount</p>
                        <ul class="entry-goal-list">
                            @foreach (var goal in Model.Booking.Goals.OrderBy(s => s.Target))
                            {
                                var reached = Model.Booking.BookingCount >= goal.Target;
                                <li class="@(reached ? "entry-goal entry-goal--done" : "entry-goal")">
                                    <span>@goal.Name</span>
                                    <strong>@goal.Target</strong>
                                </li>
                            }
                        </ul>
                        <p class="entry-booking-status">@(Model.Booking.Open ? "预约开放中" : "预约未开放")</p>
                    </section>
                }

                @if (Model.Information.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiInformationOutline" />基础信息</h2>
                        <dl class="entry-info-list">
                            @foreach (var item in Model.Information)
                            {
                                <div>
                                    <dt>@item.Name</dt>
                                    <dd>@(new MarkupString(item.Value))</dd>
                                </div>
                            }
                        </dl>
                    </section>
                }

                @if (Model.Tags.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiTagMultipleOutline" />标签</h2>
                        <ul class="entry-tags">
                            @foreach (var tag in Model.Tags.Take(24))
                            {
                                <li>@tag</li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.Releases.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiCalendarClockOutline" />发行信息</h2>
                        <div class="entry-release-cards">
                            @foreach (var release in Model.Releases)
                            {
                                <div class="entry-release-card">
                                    <div class="entry-release-header">
                                        <div class="entry-release-header-left">
                                            <CgMdiIcon Name="@GetPlatformIcon(release)" />
                                            <strong>@GetPublishPlatformName(release)</strong>
                                        </div>
                                        <span class="entry-release-type">@GetReleaseTypeText(release.Type)</span>
                                    </div>
                                    <div class="entry-release-body">
                                        @if (release.StoreInfor.State != StoreState.None && release.Time != null && release.Time.Value.Date <= DateTime.UtcNow.AddHours(8).Date)
                                        {
                                            <div class="entry-release-price-box">
                                                @if (release.StoreInfor.State == StoreState.NotPublished && release.Type != GameReleaseType.Demo)
                                                {
                                                    <span class="entry-release-state"><CgMdiIcon Name="mdiInformationOutline" />未发售</span>
                                                }
                                                else if (release.StoreInfor.State == StoreState.Takedown)
                                                {
                                                    <span class="entry-release-state"><CgMdiIcon Name="mdiArchiveRemoveOutline" />已下架</span>
                                                }
                                                else if (release.StoreInfor.PriceNow == 0)
                                                {
                                                    <span class="entry-release-state entry-release-state--free"><CgMdiIcon Name="mdiGiftOutline" />免费 (Free)</span>
                                                }
                                                else if (release.StoreInfor.PriceNow > 0)
                                                {
                                                    <div class="entry-release-price-row">
                                                        <CgMdiIcon Name="mdiCurrencyCny" />
                                                        <span>当前价格：</span>
                                                        @if (release.StoreInfor.CutNow > 0 && release.StoreInfor.OriginalPrice.HasValue)
                                                        {
                                                            <s class="entry-release-price-old">@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.OriginalPrice.Value.ToString("0.00")</s>
                                                        }
                                                        <strong class="entry-release-price-now">@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.PriceNow.Value.ToString("0.00")</strong>
                                                        @if (release.StoreInfor.CutNow > 0)
                                                        {
                                                            <span class="entry-release-discount">-@release.StoreInfor.CutNow%</span>
                                                        }
                                                    </div>
                                                    @if (release.StoreInfor.CutLowest > 0 && release.StoreInfor.PriceLowest.HasValue)
                                                    {
                                                        <div class="entry-release-price-row entry-release-price-row--low">
                                                            <CgMdiIcon Name="mdiChartLine" />
                                                            <span>历史最低：</span>
                                                            <strong>@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.PriceLowest.Value.ToString("0.00")</strong>
                                                        </div>
                                                    }
                                                }
                                                else if (release.StoreInfor.PriceNow == null)
                                                {
                                                    <span class="entry-release-state"><CgMdiIcon Name="mdiHelpCircleOutline" />数据未更新</span>
                                                }
                                            </div>
                                        }

                                        <ul class="entry-release-details">
                                            @if (!string.IsNullOrWhiteSpace(release.Name))
                                            {
                                                <li>
                                                    <CgMdiIcon Name="mdiSubtitlesOutline" />
                                                    <span>@release.Name</span>
                                                </li>
                                            }
                                            <li>
                                                <CgMdiIcon Name="@(string.IsNullOrWhiteSpace(release.TimeNote) ? "mdiCalendarCheckOutline" : "mdiClockOutline")" />
                                                <span>@(string.IsNullOrWhiteSpace(release.TimeNote) ? (release.Time?.ToString("yyyy年M月d日") ?? "时间待定") : release.TimeNote)</span>
                                            </li>
                                            @if (release.GamePlatformTypes?.Any() == true)
                                            {
                                                <li>
                                                    <CgMdiIcon Name="mdiMonitorDashboard" />
                                                    <span>@string.Join("、", release.GamePlatformTypes.Select(GetGamePlatformName))</span>
                                                </li>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(release.Engine))
                                            {
                                                <li>
                                                    <CgMdiIcon Name="mdiEngineOutline" />
                                                    <span>@release.Engine</span>
                                                </li>
                                            }
                                            @if (release.StoreInfor.PlayTime > 0)
                                            {
                                                <li>
                                                    <CgMdiIcon Name="mdiGamepadVariantOutline" />
                                                    <span>平均游玩：@((release.StoreInfor.PlayTime / 60.0)?.ToString("0.0")) 小时</span>
                                                </li>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(release.Link))
                                            {
                                                <li>
                                                    <CgMdiIcon Name="mdiLinkVariant" />
                                                    <a href="@release.GetLink()" target="_blank" rel="noopener noreferrer">前往平台商店查看</a>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>
                }

                @if (Model.Roles.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiAccountStarOutline" />登场角色</h2>
                        <ul class="entry-role-list">
                            @foreach (var role in Model.Roles.Take(8))
                            {
                                <li>
                                    <a href="@BuildEntryUrl(role.Id)" class="entry-role-item">
                                        <div class="entry-role-avatar">
                                            <img src="@role.MainImage" alt="@role.Name" loading="lazy" decoding="async" />
                                        </div>
                                        <div class="entry-role-content">
                                            <span class="entry-role-name">@role.Name</span>
                                            @if (!string.IsNullOrWhiteSpace(role.CV))
                                            {
                                                <span class="entry-role-cv">CV: @role.CV</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(role.BriefIntroduction))
                                            {
                                                <span class="entry-role-brief">@role.BriefIntroduction</span>
                                            }
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.IsHideOutlink is false && Model.OtherRelevances.Count > 0)
                {
                    <section class="entry-section">
                        <h2><CgMdiIcon Name="mdiLinkVariant" />外部链接</h2>
                        <ul class="entry-outlink-list">
                            @foreach (var item in Model.OtherRelevances.Take(8))
                            {
                                <li>
                                    <a href="@item.Link" target="_blank" rel="noopener noreferrer" class="entry-outlink-item">
                                        <CgMdiIcon Name="@GetExternalLinkIcon(item.DisplayName)" />
                                        <span>@DisplayTextOrFallback(item.DisplayName, item.DisplayValue)</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }

                @if (Model.Staffs.Count > 0)
                {
                    <section class="entry-card">
                        <h2><CgMdiIcon Name="mdiAccountGroupOutline" />Staff</h2>
                        <ul class="entry-staff-group-list">
                            @foreach (var group in Model.Staffs.Take(8))
                            {
                                <li>
                                    @if (string.IsNullOrWhiteSpace(group.Modifier) is false)
                                    {
                                        <h3>@group.Modifier</h3>
                                    }
                                    @foreach (var position in group.StaffList.Take(5))
                                    {
                                        <p>
                                            <strong>@position.Modifier：</strong>
                                            @string.Join("、", position.Names.Select(s => s.DisplayName))
                                        </p>
                                    }
                                </li>
                            }
                        </ul>
                    </section>
                }
            </aside>
        </section>

        <section class="entry-layout entry-layout--mobile" aria-label="移动端详情布局">
            <div class="entry-mobile-tabs">
                <input type="radio" id="entry-tab-home" name="entry-tab" checked>
                <input type="radio" id="entry-tab-related" name="entry-tab">
                @if (Model.Staffs.Count > 0)
                {
                    <input type="radio" id="entry-tab-staff" name="entry-tab">
                }

                <nav class="entry-mobile-tab-nav" role="tablist" aria-label="详情页标签">
                    <label for="entry-tab-home" role="tab">首页</label>
                    <label for="entry-tab-related" role="tab">相关</label>
                    @if (Model.Staffs.Count > 0)
                    {
                        <label for="entry-tab-staff" role="tab">Staff</label>
                    }
                </nav>

                <div class="entry-mobile-panels">
                    <section class="entry-mobile-panel entry-mobile-panel--home">
                        @if (Model.Booking is not null && Model.Booking.Goals.Count > 0)
                        {
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiGiftOutline" />预约</h2>
                                <p class="entry-booking-count">当前预约：@Model.Booking.BookingCount</p>
                            </section>
                        }
                        @if (Model.Information.Count > 0)
                        {
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiInformationOutline" />基础信息</h2>
                                <dl class="entry-info-list">
                                    @foreach (var item in Model.Information.Take(12))
                                    {
                                        <div>
                                            <dt>@item.Name</dt>
                                            <dd>@item.Value</dd>
                                        </div>
                                    }
                                </dl>
                            </section>
                        }
                        @if (Model.Tags.Count > 0)
                        {
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiTagMultipleOutline" />标签</h2>
                                <ul class="entry-tags">
                                    @foreach (var tag in Model.Tags.Take(24))
                                    {
                                        <li>@tag</li>
                                    }
                                </ul>
                            </section>
                        }
                        @if (Model.Releases.Count > 0)
                        {
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiCalendarClockOutline" />发行信息</h2>
                                <div class="entry-release-cards">
                                    @foreach (var release in Model.Releases)
                                    {
                                        <div class="entry-release-card">
                                            <div class="entry-release-header">
                                                <div class="entry-release-header-left">
                                                    <CgMdiIcon Name="@GetPlatformIcon(release)" />
                                                    <strong>@GetPublishPlatformName(release)</strong>
                                                </div>
                                                <span class="entry-release-type">@GetReleaseTypeText(release.Type)</span>
                                            </div>
                                            <div class="entry-release-body">
                                                @if (release.StoreInfor.State != StoreState.None && release.Time != null && release.Time.Value.Date <= DateTime.UtcNow.AddHours(8).Date)
                                                {
                                                    <div class="entry-release-price-box">
                                                        @if (release.StoreInfor.State == StoreState.NotPublished && release.Type != GameReleaseType.Demo)
                                                        {
                                                            <span class="entry-release-state"><CgMdiIcon Name="mdiInformationOutline" />未发售</span>
                                                        }
                                                        else if (release.StoreInfor.State == StoreState.Takedown)
                                                        {
                                                            <span class="entry-release-state"><CgMdiIcon Name="mdiArchiveRemoveOutline" />已下架</span>
                                                        }
                                                        else if (release.StoreInfor.PriceNow == 0)
                                                        {
                                                            <span class="entry-release-state entry-release-state--free"><CgMdiIcon Name="mdiGiftOutline" />免费 (Free)</span>
                                                        }
                                                        else if (release.StoreInfor.PriceNow > 0)
                                                        {
                                                            <div class="entry-release-price-row">
                                                                <CgMdiIcon Name="mdiCurrencyCny" />
                                                                <span>当前价格：</span>
                                                                @if (release.StoreInfor.CutNow > 0 && release.StoreInfor.OriginalPrice.HasValue)
                                                                {
                                                                    <s class="entry-release-price-old">@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.OriginalPrice.Value.ToString("0.00")</s>
                                                                }
                                                                <strong class="entry-release-price-now">@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.PriceNow.Value.ToString("0.00")</strong>
                                                                @if (release.StoreInfor.CutNow > 0)
                                                                {
                                                                    <span class="entry-release-discount">-@release.StoreInfor.CutNow%</span>
                                                                }
                                                            </div>
                                                            @if (release.StoreInfor.CutLowest > 0 && release.StoreInfor.PriceLowest.HasValue)
                                                            {
                                                                <div class="entry-release-price-row entry-release-price-row--low">
                                                                    <CgMdiIcon Name="mdiChartLine" />
                                                                    <span>历史最低：</span>
                                                                    <strong>@GetCurrencyPrefix(release.StoreInfor.CurrencyCode)@release.StoreInfor.PriceLowest.Value.ToString("0.00")</strong>
                                                                </div>
                                                            }
                                                        }
                                                        else if (release.StoreInfor.PriceNow == null)
                                                        {
                                                            <span class="entry-release-state"><CgMdiIcon Name="mdiHelpCircleOutline" />数据未更新</span>
                                                        }
                                                    </div>
                                                }

                                                <ul class="entry-release-details">
                                                    @if (!string.IsNullOrWhiteSpace(release.Name))
                                                    {
                                                        <li>
                                                            <CgMdiIcon Name="mdiSubtitlesOutline" />
                                                            <span>@release.Name</span>
                                                        </li>
                                                    }
                                                    <li>
                                                        <CgMdiIcon Name="@(string.IsNullOrWhiteSpace(release.TimeNote) ? "mdiCalendarCheckOutline" : "mdiClockOutline")" />
                                                        <span>@(string.IsNullOrWhiteSpace(release.TimeNote) ? (release.Time?.ToString("yyyy年M月d日") ?? "时间待定") : release.TimeNote)</span>
                                                    </li>
                                                    @if (release.GamePlatformTypes?.Any() == true)
                                                    {
                                                        <li>
                                                            <CgMdiIcon Name="mdiMonitorDashboard" />
                                                            <span>@string.Join("、", release.GamePlatformTypes.Select(GetGamePlatformName))</span>
                                                        </li>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(release.Engine))
                                                    {
                                                        <li>
                                                            <CgMdiIcon Name="mdiEngineOutline" />
                                                            <span>@release.Engine</span>
                                                        </li>
                                                    }
                                                    @if (release.StoreInfor.PlayTime > 0)
                                                    {
                                                        <li>
                                                            <CgMdiIcon Name="mdiGamepadVariantOutline" />
                                                            <span>平均游玩：@((release.StoreInfor.PlayTime / 60.0)?.ToString("0.0")) 小时</span>
                                                        </li>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(release.Link))
                                                    {
                                                        <li>
                                                            <CgMdiIcon Name="mdiLinkVariant" />
                                                            <a href="@release.GetLink()" target="_blank" rel="noopener noreferrer">前往平台商店查看</a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>
                        }
                        @if (Model.Audio.Count > 0 || Model.Pictures.Count > 0 || string.IsNullOrWhiteSpace(Model.MainPage) is false || Model.NewsOfEntry.Count > 0 || Model.CanComment)
                        {
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiViewGridOutline" />内容浏览</h2>
                                <ul class="entry-link-list">
                                    @if (Model.Audio.Count > 0)
                                    {
                                        <li>音频：@Model.Audio.Count</li>
                                    }
                                    @if (Model.Pictures.Count > 0)
                                    {
                                        <li>图片：@Model.Pictures.Count</li>
                                    }
                                    @if (string.IsNullOrWhiteSpace(Model.MainPage) is false)
                                    {
                                        <li>正文主页：可阅读</li>
                                    }
                                    @if (Model.NewsOfEntry.Count > 0)
                                    {
                                        <li>动态时间线：@Model.NewsOfEntry.Count</li>
                                    }
                                    @if (Model.CanComment)
                                    {
                                        <li><a href="@($"/space/comments?type=entry&id={Model.Id}")">前往评论区</a></li>
                                    }
                                </ul>
                            </section>
                        }
                    </section>

                    <section class="entry-mobile-panel entry-mobile-panel--related">
                        @if (Model.VideoRelevances.Count > 0)
                        {
                            <section class="entry-section">
                                <h2><CgMdiIcon Name="mdiAnimationPlayOutline" />相关视频</h2>
                                <ul class="entry-card-list">
                                    @foreach (var item in Model.VideoRelevances.Take(8))
                                    {
                                        <li>
                                            <a href="@($"/videos/index/{item.Id}")" class="entry-card-item">
                                                <div class="entry-card-item-image">
                                                    <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                                </div>
                                                <div class="entry-card-item-content">
                                                    <span class="entry-card-item-title">@item.Name</span>
                                                </div>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }

                        @if (Model.EntryRelevances.Count > 0 || Model.StaffGames.Count > 0)
                        {
                            <section class="entry-section">
                                <h2><CgMdiIcon Name="mdiLinkVariant" />相关词条</h2>
                                <ul class="entry-card-list">
                                    @foreach (var item in Model.EntryRelevances.Take(8))
                                    {
                                        <li>
                                            <a href="@BuildEntryUrl(item.Id)" class="entry-card-item">
                                                <div class="entry-card-item-image">
                                                    <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                                </div>
                                                <div class="entry-card-item-content">
                                                    <span class="entry-card-item-title">@item.Name</span>
                                                </div>
                                            </a>
                                        </li>
                                    }
                                    @foreach (var item in Model.StaffGames.Take(4))
                                    {
                                        <li>
                                            <a href="@BuildEntryUrl(item.Id)" class="entry-card-item">
                                                <div class="entry-card-item-image">
                                                    <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                                </div>
                                                <div class="entry-card-item-content">
                                                    <span class="entry-card-item-title">@item.Name</span>
                                                </div>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }

                        @if (Model.ArticleRelevances.Count > 0)
                        {
                            <section class="entry-section">
                                <h2><CgMdiIcon Name="mdiTextBoxOutline" />相关文章</h2>
                                <ul class="entry-card-list">
                                    @foreach (var item in Model.ArticleRelevances.Take(8))
                                    {
                                        <li>
                                            <a href="@GetArticleLink(item)" target="@GetTarget(item.Link)" rel="noopener noreferrer" class="entry-card-item">
                                                <div class="entry-card-item-image">
                                                    <img src="@item.MainImage" alt="@item.Name" loading="lazy" decoding="async" />
                                                </div>
                                                <div class="entry-card-item-content">
                                                    <span class="entry-card-item-title">@item.Name</span>
                                                </div>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }

                        @if (HasRelatedContent() == false && Model.Roles.Count == 0 && (Model.IsHideOutlink || Model.OtherRelevances.Count == 0))
                        {
                            <section class="entry-card entry-card--empty">
                                <h2><CgMdiIcon Name="mdiLinkVariant" />相关内容</h2>
                                <p>暂无相关内容。</p>
                            </section>
                        }

                        @if (Model.Roles.Count > 0)
                        {
                            <section class="entry-section">
                                <h2><CgMdiIcon Name="mdiAccountStarOutline" />登场角色</h2>
                                <ul class="entry-role-list">
                                    @foreach (var role in Model.Roles.Take(8))
                                    {
                                        <li>
                                            <a href="@BuildEntryUrl(role.Id)" class="entry-role-item">
                                                <div class="entry-role-avatar">
                                                    <img src="@role.MainImage" alt="@role.Name" loading="lazy" decoding="async" />
                                                </div>
                                                <div class="entry-role-content">
                                                    <span class="entry-role-name">@role.Name</span>
                                                    @if (!string.IsNullOrWhiteSpace(role.CV))
                                                    {
                                                        <span class="entry-role-cv">CV: @role.CV</span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(role.BriefIntroduction))
                                                    {
                                                        <span class="entry-role-brief">@role.BriefIntroduction</span>
                                                    }
                                                </div>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }

                        @if (Model.IsHideOutlink is false && Model.OtherRelevances.Count > 0)
                        {
                            <section class="entry-section">
                                <h2><CgMdiIcon Name="mdiLinkVariant" />外部链接</h2>
                                <ul class="entry-outlink-list">
                                    @foreach (var item in Model.OtherRelevances.Take(8))
                                    {
                                        <li>
                                            <a href="@item.Link" target="_blank" rel="noopener noreferrer" class="entry-outlink-item">
                                                <CgMdiIcon Name="@GetExternalLinkIcon(item.DisplayName)" />
                                                <span>@DisplayTextOrFallback(item.DisplayName, item.DisplayValue)</span>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }
                    </section>

                    @if (Model.Staffs.Count > 0)
                    {
                        <section class="entry-mobile-panel entry-mobile-panel--staff">
                            <section class="entry-card">
                                <h2><CgMdiIcon Name="mdiAccountGroupOutline" />Staff</h2>
                                <ul class="entry-staff-group-list">
                                    @foreach (var group in Model.Staffs)
                                    {
                                        <li>
                                            @if (string.IsNullOrWhiteSpace(group.Modifier) is false)
                                            {
                                                <h3>@group.Modifier</h3>
                                            }
                                            @foreach (var position in group.StaffList)
                                            {
                                                <p>
                                                    <strong>@position.Modifier：</strong>
                                                    @string.Join("、", position.Names.Select(s => s.DisplayName))
                                                </p>
                                            }
                                        </li>
                                    }
                                </ul>
                            </section>
                        </section>
                    }
                </div>
            </div>
        </section>
    </article>
}
else
{
    <section class="entry-loading" aria-label="加载中">
        <div class="entry-loading-block"></div>
        <div class="entry-loading-block entry-loading-block--wide"></div>
        <div class="entry-loading-block"></div>
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private EntryDetailViewModel? Model;
    private string? ErrorMessage;

    protected override async Task OnParametersSetAsync()
    {
        var result = await EntryQueryService.GetEntryDetailAsync(Id);
        if (result.Success && result.Data is not null)
        {
            ErrorMessage = null;
            Model = result.Data;
            return;
        }

        Model = null;
        ErrorMessage = result.Error?.Message ?? "请稍后重试";
    }

    private bool HasAtmosphere()
    {
        if (Model is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(Model.BackgroundPicture) is false
            || string.IsNullOrWhiteSpace(Model.SmallBackgroundPicture) is false;
    }

    private bool IsSquareCover()
    {
        if (Model is null)
        {
            return false;
        }

        return Model.Type is EntryType.Role or EntryType.Staff;
    }

    private string GetHeroImageUrl()
    {
        if (Model is null)
        {
            return string.Empty;
        }

        if (Model.Type is EntryType.Role or EntryType.Staff)
        {
            return string.IsNullOrWhiteSpace(Model.Thumbnail) ? Model.MainPicture : Model.Thumbnail;
        }

        return string.IsNullOrWhiteSpace(Model.MainPicture) ? Model.Thumbnail : Model.MainPicture;
    }

    private static string BuildEntryUrl(int id)
    {
        return $"/entries/index/{id}";
    }

    private static string DisplayTextOrFallback(string? value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private static string GetTypeText(EntryType type)
    {
        return type switch
        {
            EntryType.Game => "游戏",
            EntryType.Role => "角色",
            EntryType.ProductionGroup => "组织",
            EntryType.Staff => "Staff",
            _ => "词条"
        };
    }

    private static bool IsExternalLink(string? link)
    {
        return string.IsNullOrWhiteSpace(link) is false
               && (link.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
                   || link.StartsWith("https://", StringComparison.OrdinalIgnoreCase));
    }

    private static string GetArticleLink(ArticleInforTipViewModel item)
    {
        return IsExternalLink(item.Link) ? item.Link : $"/articles/index/{item.Id}";
    }

    private static string GetNewsLink(NewsModel item)
    {
        return IsExternalLink(item.Link) ? item.Link : $"/articles/index/{item.ArticleId}";
    }

    private static string? GetTarget(string? link)
    {
        return IsExternalLink(link) ? "_blank" : null;
    }

    private string GetExternalLinkIcon(string displayName)
    {
        var name = displayName?.ToLower() ?? "";
        if (name.Contains("steam")) return "mdiSteam";
        if (name.Contains("bilibili") || name.Contains("b站")) return "mdiTelevisionPlay";
        if (name.Contains("weibo") || name.Contains("微博")) return "mdiWechat"; // close enough if weibo missing
        if (name.Contains("twitter") || name.Contains("x")) return "mdiTwitter";
        if (name.Contains("github")) return "mdiGithub";
        if (name.Contains("youtube")) return "mdiYoutube";
        if (name.Contains("tap") || name.Contains("taptap")) return "mdiGamepadVariantOutline";
        if (name.Contains("qq")) return "mdiQqchat";
        return "mdiEarth";
    }

    private bool HasRelatedContent()
    {
        if (Model is null)
        {
            return false;
        }

        return Model.VideoRelevances.Count > 0
            || Model.EntryRelevances.Count > 0
            || Model.ArticleRelevances.Count > 0
            || Model.StaffGames.Count > 0;
    }

    private string GetPublishPlatformName(GameReleaseViewModel release)
    {
        if (release.PublishPlatformType == PublishPlatformType.Other && !string.IsNullOrWhiteSpace(release.PublishPlatformName))
        {
            return release.PublishPlatformName;
        }
        return release.PublishPlatformType switch
        {
            PublishPlatformType.Steam => "Steam",
            PublishPlatformType.TapTap => "TapTap",
            PublishPlatformType.Epic => "Epic",
            PublishPlatformType.AppStore => "App Store",
            PublishPlatformType.GooglePlay => "Google Play",
            PublishPlatformType.NS => "Nintendo Switch",
            PublishPlatformType.DLsite => "DLsite",
            _ => "其他"
        };
    }

    private string GetPlatformIcon(GameReleaseViewModel release)
    {
        if (release.PublishPlatformType == PublishPlatformType.Other && !string.IsNullOrWhiteSpace(release.PublishPlatformName))
        {
            var lowerName = release.PublishPlatformName.ToLower();
            if (lowerName.Contains("b站") || lowerName.Contains("bilibili")) return "mdiTelevisionPlay";
            if (lowerName.Contains("微博")) return "mdiWechat";
        }
        return release.PublishPlatformType switch
        {
            PublishPlatformType.Steam => "mdiSteam",
            PublishPlatformType.AppStore => "mdiApple",
            PublishPlatformType.GooglePlay => "mdiGooglePlay",
            PublishPlatformType.NS => "mdiNintendoSwitch",
            PublishPlatformType.Epic => "mdiGamepadVariantOutline",
            _ => "mdiGamepadVariantOutline"
        };
    }

    private string GetGamePlatformName(GamePlatformType type)
    {
        return type switch
        {
            GamePlatformType.Windows => "Windows",
            GamePlatformType.Linux => "Linux",
            GamePlatformType.Mac => "macOS",
            GamePlatformType.IOS => "iOS",
            GamePlatformType.Android => "Android",
            GamePlatformType.PS => "PlayStation",
            GamePlatformType.NS => "Nintendo Switch",
            GamePlatformType.DOS => "DOS",
            GamePlatformType.HarmonyOS => "HarmonyOS",
            GamePlatformType.H5 => "H5",
            _ => type.ToString()
        };
    }

    private string GetReleaseTypeText(GameReleaseType type)
    {
        return type switch
        {
            GameReleaseType.Official => "正式版",
            GameReleaseType.Demo => "Demo",
            GameReleaseType.EA => "抢先体验",
            _ => "未知"
        };
    }

    private string GetCurrencyPrefix(CurrencyCode code)
    {
        return code switch
        {
            CurrencyCode.CNY => "¥",
            CurrencyCode.USD => "$",
            CurrencyCode.HKD => "HK$",
            _ => code.ToString() + " "
        };
    }
}
