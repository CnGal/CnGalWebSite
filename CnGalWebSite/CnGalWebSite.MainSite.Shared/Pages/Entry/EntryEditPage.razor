@page "/entries/establish"
@page "/entries/create"
@page "/entries/edit/{Id:int}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Editor
@using CnGalWebSite.MainSite.Shared.Services
@using CnGalWebSite.SDK.MainSite.Abstractions
@using CnGalWebSite.SDK.MainSite.Models
@using System.Text.Json
@using CnGalWebSite.SDK.MainSite.Models.EntryEdit
@using CnGalWebSite.DataModel.ViewModel
@inject IEntryCommandService EntryCommandService
@inject ITagQueryService TagQueryService
@inject NavigationManager NavigationManager
@inject ILocalStorageService LocalStorage
@inject ICgToastService ToastService
@implements IDisposable

<CgPageMeta Title="@(IsCreate ? "创建词条" : "编辑词条")" />

@if (IsLoading)
{
    <section class="entry-edit-loading" aria-label="加载中">
        <div class="entry-edit-loading-spinner"></div>
        <p>正在获取数据...</p>
    </section>
}
else if (LoadErrorMessage != null)
{
    <section class="entry-edit-error">
        <h1>加载失败</h1>
        <p>@LoadErrorMessage</p>
        <CgButton Variant="primary" OnClick="LoadDataAsync">重试</CgButton>
    </section>
}
else if (Model != null)
{
    <article class="entry-edit-page">
        <div class="entry-edit-layout">
            <EntryEditorSidebar IsCreate="IsCreate"
                                IsSubmitting="IsSubmitting"
                                HasDraftRecovered="HasDraftRecovered"
                                EntryType="Model.Data.Main.Type"
                                Model="Model.Data"
                                OnModelChanged="OnSteamImportCompleted"
                                OnDiscardDraft="DiscardDraft"
                                OnSubmit="SubmitAsync"
                                OnCancel="Cancel" />

            <main class="entry-edit-main">
                <EntryMainEditor Model="Model.Data.Main" TypeChanged="OnTypeChanged" />
                <EntryAddInforEditor @ref="_addInforEditorRef" Model="Model.Data.AddInfor" MetaOptions="Model.MetaOptions" />
                <EntryImagesEditor Model="Model.Data.Images" />
                <EntryMainPageEditor Model="Model.Data.MainPage" />
                <EntryRelevancesEditor Model="Model.Data.Relevances" MetaOptions="Model.MetaOptions" />
                <EntryTagsEditor Model="Model.Data.Tags" MetaOptions="Model.MetaOptions" />
                <EntryAudioEditor Model="Model.Data.Audio" />
                <EntryWebsiteEditor Model="Model.Data.Website" />
            </main>
        </div>

    </article>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    [SupplyParameterFromQuery]
    public string? Type { get; set; }

    private bool IsCreate => Id is null || Id <= 0;

    private bool IsLoading = true;
    private string? LoadErrorMessage;

    private bool IsSubmitting = false;

    private EntryEditViewModel? Model;
    private EntryAddInforEditor? _addInforEditorRef;

    private System.Threading.Timer? _autoSaveTimer;
    private string DraftKey => IsCreate ? "EntryDraft_Create" : $"EntryDraft_Edit_{Id}";

    private bool HasDraftRecovered = false;
    private EstablishEntryViewModel? OriginalData;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        try
        {
            await LoadDataAsync();
        }
        catch (OperationCanceledException) { }
        _autoSaveTimer = new System.Threading.Timer(AutoSaveCallback, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void AutoSaveCallback(object? state)
    {
        _ = InvokeAsync(async () =>
        {
            if (Model != null && !IsSubmitting && !IsLoading)
            {
                try
                {
                    await LocalStorage.SetItemAsync(DraftKey, Model.Data);
                }
                catch { /* Ignore local storage errors */ }
            }
        });
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _autoSaveTimer?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        LoadErrorMessage = null;
        StateHasChanged();

        try
        {
            SdkResult<EntryEditViewModel> result;
            if (IsCreate)
            {
                var entryType = Enum.TryParse<EntryType>(Type, true, out var t) ? t : EntryType.Game;
                result = await EntryCommandService.GetEntryCreateTemplateAsync(entryType, _cts!.Token);
            }
            else
            {
                result = await EntryCommandService.GetEntryEditAsync(Id!.Value, _cts!.Token);
            }

            if (result.Success && result.Data != null)
            {
                Model = result.Data;
                OriginalData = JsonSerializer.Deserialize<EstablishEntryViewModel>(JsonSerializer.Serialize(result.Data.Data));

                try
                {
                    var draft = await LocalStorage.GetItemAsync<EstablishEntryViewModel>(DraftKey);
                    if (draft != null)
                    {
                        Model.Data = draft;
                        HasDraftRecovered = true;
                    }
                }
                catch { }

                var metaTask = EntryCommandService.GetEntryEditMetaOptionsAsync(_cts!.Token);
                var tagTreeTask = TagQueryService.GetTagTreeAsync(_cts!.Token);
                await Task.WhenAll(metaTask, tagTreeTask);

                var metaResult = metaTask.Result;
                if (metaResult.Success && metaResult.Data != null)
                {
                    Model.MetaOptions = metaResult.Data;
                }

                var tagTreeResult = tagTreeTask.Result;
                if (tagTreeResult.Success && tagTreeResult.Data != null)
                {
                    Model.MetaOptions.TagTreeItems = tagTreeResult.Data;
                }
            }
            else
            {
                LoadErrorMessage = result.Error?.Message ?? "获取编辑数据失败";
            }
        }
        catch (Exception ex)
        {
            LoadErrorMessage = "发生未知错误：" + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task DiscardDraft()
    {
        if (OriginalData != null && Model != null)
        {
            Model.Data = JsonSerializer.Deserialize<EstablishEntryViewModel>(JsonSerializer.Serialize(OriginalData))!;
            HasDraftRecovered = false;
            await LocalStorage.RemoveItemAsync(DraftKey);
            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        if (Model == null || IsSubmitting) return;

        var validationResult = Model.Data.Validate();
        if (!validationResult.Successful)
        {
            ToastService.Show("校验失败", validationResult.Error ?? "请检查表单是否填写正确", "error");
            return;
        }

        IsSubmitting = true;
        StateHasChanged();

        try
        {
            var request = new EntryEditRequest
            {
                IsCreate = IsCreate,
                Data = Model.Data
            };

            var result = await EntryCommandService.SubmitEditAsync(request, _cts!.Token);
            if (result.Success)
            {
                await LocalStorage.RemoveItemAsync(DraftKey);
                ToastService.Show("提交成功", "已提交，等待审核通过...", "success");
                NavigationManager.NavigateTo($"/entries/index/{result.Data}");
            }
            else
            {
                ToastService.Show("提交失败", result.Error?.Message ?? "提交审核时出现问题", "error");
            }
        }
        catch (Exception ex)
        {
            ToastService.Show("发生错误", ex.Message, "error");
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        if (IsCreate)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            NavigationManager.NavigateTo($"/entries/index/{Id}");
        }
    }

    private async Task OnTypeChanged(EntryType newType)
    {
        if (Model != null)
        {
            Model.Data.Type = newType;
            Model.Data.Main.Type = newType;
            Model.Data.AddInfor.Type = newType;
            Model.Data.Relevances.Type = newType;

            if (_addInforEditorRef != null)
            {
                await _addInforEditorRef.RefreshInformationsAsync(newType);
            }
        }
    }

    private async Task OnSteamImportCompleted()
    {
        if (Model?.Data != null)
        {
            Model.Data.AddInfor.Releases = [.. Model.Data.AddInfor.Releases];
            Model.Data.Images.Images = [.. Model.Data.Images.Images];
        }

        await InvokeAsync(StateHasChanged);
    }
}
