@page "/home/editrecord"

@using CnGalWebSite.DataModel.ViewModel.Home
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.MainSite.Shared.Components.Features.Examine

@inject IExamineQueryService ExamineQueryService
@inject IMainSiteAuthRequestService AuthRequestService

<CgPageMeta Title="编辑记录" />

<div class="edit-record-page">
    @* ── 页面标题 ── *@
    <header class="edit-record-page__header">
        <h1 class="edit-record-page__title">
            <CgMdiIcon Name="mdiHistory" aria-hidden="true"/>
            <span>编辑记录</span>
        </h1>
    </header>

    @if (_isLoading)
    {
        <div class="edit-record-page__loading">
            <CgProgressRing/>
            <span>加载编辑记录中...</span>
        </div>
    }
    else if (_isError)
    {
        <div class="edit-record-page__error">
            <CgMdiIcon Name="mdiAlertCircleOutline" aria-hidden="true"/>
            <p>@_errorMessage</p>
            <a class="cg-btn cg-btn--primary" href="/home/editrecord?ContrastId=@ContrastId&CurrentId=@CurrentId&SelectedId=@SelectedId">重试</a>
            <a href="/" class="cg-btn cg-btn--secondary">返回首页</a>
        </div>
    }
    else if (_overview is not null)
    {
        @* ── 对象信息卡片 ── *@
        <div class="edit-record-page__object-banner">
            @if (!string.IsNullOrWhiteSpace(_overview.Image))
            {
                <img class="edit-record-page__object-image" src="@_overview.Image" alt="@_overview.ObjectName" loading="lazy" />
            }
            <div class="edit-record-page__object-info">
                <h2 class="edit-record-page__object-name">@($"『{_overview.ObjectName}』历史编辑记录总览")</h2>
                @if (!string.IsNullOrWhiteSpace(_overview.ObjectBriefIntroduction))
                {
                    <p class="edit-record-page__object-desc">@_overview.ObjectBriefIntroduction</p>
                }
                <a class="edit-record-page__object-link" href="@GetObjectUrl()">
                    <CgMdiIcon Name="mdiOpenInNew" aria-hidden="true"/>
                    查看详情
                </a>
            </div>
        </div>

        @* ── 主体：左侧时间线 + 右侧详情/对比 ── *@
        <div class="edit-record-page__body">
            <aside class="edit-record-page__sidebar">
                <div class="edit-record-page__sidebar-header">
                    <CgMdiIcon Name="mdiFormatListBulleted" aria-hidden="true"/>
                    <span>编辑记录 (@_overview.Examines.Count)</span>
                </div>
                <EditRecordTimeline Items="@_overview.Examines"
                                    SelectedId="@_selectedId"
                                    ContrastId="@ContrastId"
                                    CurrentId="@_currentId" />
            </aside>
            <main class="edit-record-page__main">
                @* ── 对比版本选择器 (交互岛, 登录门控) ── *@
                <AuthorizeView>
                    <Authorized>
                        <EditRecordContrastPanel ExamineOptions="@_examineOptions"
                                                  ContrastId="@ContrastId"
                                                  CurrentId="@_currentId" />
                    </Authorized>
                    <NotAuthorized>
                        <div class="edit-record-page__login-prompt">
                            <CgMdiIcon Name="mdiLoginVariant" aria-hidden="true" />
                            <span>登录后可选择自定义对比版本</span>
                            <a class="cg-btn cg-btn--primary" href="@AuthRequestService.BuildLoginUrl(GetCurrentUrl())">去登录</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>

                @* ── 对比视图 (始终可见) ── *@
                @if (_isContrastLoading)
                {
                    <div class="edit-record-page__loading">
                        <CgProgressRing/>
                        <span>加载对比数据中...</span>
                    </div>
                }
                else if (_contrastModel is not null)
                {
                    <section class="edit-record-page__contrast-view">
                        <div class="edit-record-page__contrast-column">
                            <h3 class="edit-record-page__contrast-column-title edit-record-page__contrast-column-title--before">
                                <CgMdiIcon Name="mdiFileRestoreOutline" aria-hidden="true"/>
                                对比版本 (#@_contrastId)
                            </h3>
                            <ExaminePreDataView Model="@_contrastModel.BeforeModel"/>
                        </div>
                        <div class="edit-record-page__contrast-column">
                            <h3 class="edit-record-page__contrast-column-title edit-record-page__contrast-column-title--after">
                                <CgMdiIcon Name="mdiFileDocumentCheckOutline" aria-hidden="true"/>
                                当前版本 (#@_currentId)
                            </h3>
                            <ExaminePreDataView Model="@_contrastModel.AfterModel"/>
                        </div>
                    </section>
                }

                @* ── 编辑记录详情 ── *@
                @if (_selectedRecord is not null)
                {
                    <EditRecordDetail Model="@_selectedRecord"/>
                }
                else if (_contrastModel is null && !_isContrastLoading)
                {
                    <div class="edit-record-page__no-selection">
                        <CgMdiIcon Name="mdiCursorDefaultClickOutline" aria-hidden="true"/>
                        <span>请在左侧选择一条编辑记录查看详情</span>
                    </div>
                }
            </main>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery] [Parameter] public long ContrastId { get; set; }

    [SupplyParameterFromQuery] [Parameter] public long CurrentId { get; set; }

    [SupplyParameterFromQuery] [Parameter] public long SelectedId { get; set; }

    private ExaminesOverviewViewModel? _overview;
    private EditRecordAloneViewModel? _selectedRecord;
    private ExamineViewModel? _contrastModel;
    private long _selectedId;
    private long _contrastId;
    private long _currentId;

    private IEnumerable<KeyValuePair<string, string>> _examineOptions = [];
    private bool _isLoading = true;
    private bool _isContrastLoading;
    private bool _isError;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (ContrastId <= 0)
        {
            _isError = true;
            _errorMessage = "缺少必要的编辑记录ID参数";
            _isLoading = false;
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _isError = false;

        var result = await ExamineQueryService.GetExaminesOverviewAsync(ContrastId);

        if (result.Success && result.Data is not null)
        {
            _overview = result.Data;
            _contrastId = ContrastId;
            _currentId = CurrentId > 0 ? CurrentId : _overview.Examines.LastOrDefault()?.Id ?? ContrastId;
            _examineOptions = _overview.Examines
                .Select(e => new KeyValuePair<string, string>(e.Id.ToString(), $"#{e.Id:00000} — {e.ApplyTime:yyyy-MM-dd HH:mm}"))
                .ToList();

            _selectedRecord = _overview.Examines.FirstOrDefault(e => e.Id == SelectedId)
                             ?? _overview.Examines.FirstOrDefault(e => e.Id == ContrastId)
                             ?? _overview.Examines.FirstOrDefault(e => e.IsSelected)
                             ?? _overview.Examines.FirstOrDefault();
            _selectedId = _selectedRecord?.Id ?? 0;

            if (_currentId > 0 && _contrastId > 0 && _contrastId <= _currentId)
            {
                await LoadContrastAsync();
            }
        }
        else
        {
            _isError = true;
            _errorMessage = result.Error?.Message ?? "获取编辑记录概览失败";
        }

        _isLoading = false;
    }

    private async Task LoadContrastAsync()
    {
        _isContrastLoading = true;

        var result = await ExamineQueryService.GetContrastExamineAsync(_contrastId, _currentId);
        if (result.Success && result.Data is not null)
        {
            _contrastModel = result.Data;
        }

        _isContrastLoading = false;
    }

    private string GetCurrentUrl()
    {
        var parameters = new List<string>();
        if (ContrastId > 0) parameters.Add($"ContrastId={ContrastId}");
        if (CurrentId > 0) parameters.Add($"CurrentId={CurrentId}");
        if (SelectedId > 0) parameters.Add($"SelectedId={SelectedId}");
        return $"/home/editrecord?{string.Join("&", parameters)}";
    }

    private string? GetObjectUrl()
    {
        if (_overview is null) return null;
        return _overview.Type switch
        {
            ExaminedNormalListModelType.Entry => $"/entries/index/{_overview.ObjectId}",
            ExaminedNormalListModelType.Article => $"/articles/index/{_overview.ObjectId}",
            ExaminedNormalListModelType.Periphery => $"/peripheries/index/{_overview.ObjectId}",
            ExaminedNormalListModelType.Tag => $"/tags/index/{_overview.ObjectId}",
            ExaminedNormalListModelType.Video => $"/videos/index/{_overview.ObjectId}",
            _ => null
        };
    }
}
