@page "/"
@inject IHomeQueryService HomeQueryService
@using CnGalWebSite.DataModel.ViewModel.Home
@using CnGalWebSite.MainSite.Shared.Components.Features.Home

<PageTitle>CnGal 主站</PageTitle>

@if (ErrorMessage is not null)
{
    <HomeError Message="@ErrorMessage" />
}
else
{
    <div class="home-page">
        <HomeHero Carousels="@Model.Carousels" />

        <div class="home-community-action-section">
            <div class="home-community-left">
                <ul class="home-community-grid">
                    @foreach (var item in Model.CommunityLinks.Take(6).Select((value, index) => new { value, index }))
                    {
                        <HomeLinkCard Url="@item.value.Link"
                                      Title="@item.value.Title"
                                      Text="@item.value.Text"
                                      Target="_blank"
                                      CommunityStyle="true"
                                      Icon="@GetCommunityIcon(item.index)"
                                      IconTone="@GetCommunityTone(item.index)" />
                    }
                </ul>
            </div>
            <div class="home-community-right">
                <a href="/entries/create" class="home-action-btn home-action-btn--primary">
                    <CgMdiIcon Name="mdiPencilPlus" aria-hidden="true" />
                    <span>贡献词条</span>
                </a>
                <a href="/articles/create" class="home-action-btn home-action-btn--secondary">
                    <CgMdiIcon Name="mdiNotePlus" aria-hidden="true" />
                    <span>发布文章</span>
                </a>
            </div>
        </div>

        <div class="home-games-section">
                    <HomeRandomRecommend HotRecommends="@Model.HotRecommends" />

            <HomeSection Title="近期新作" Icon="mdiRocketLaunch" IconColor="var(--cg-color-primary)">
                <ul class="home-game-grid">
                    @foreach (var item in Model.PublishedGames.Take(8))
                    {
                        <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction" Tags="@item.Tags" />
                    }
                </ul>
            </HomeSection>

            <HomeSection Title="近期试玩" Icon="mdiGamepadVariantOutline" IconColor="var(--cg-color-primary)">
                <ul class="home-game-grid">
                    @foreach (var item in Model.RecentlyDemoGames.Take(8))
                    {
                        <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction" Tags="@item.Tags" />
                    }
                </ul>
            </HomeSection>


            @if (Model.ActivityCarousels.Any())
            {
                <HomeSection>
                    <ul class="home-carousel-grid">
                        @foreach (var item in Model.ActivityCarousels.Take(3))
                        {
                            <HomeCarouselCard Link="@item.Link" Image="@item.Image" Note="@item.Note" />
                        }
                    </ul>
                </HomeSection>
            }

            <HomeSection Title="即将发布" Icon="mdiCalendarClock" IconColor="var(--cg-color-primary)">
                <ul class="home-game-grid">
                    @foreach (var item in Model.UpcomingGames.Take(8))
                    {
                        <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction">
                            <small>@DisplayOrUnknown(item.PublishTime)</small>
                        </HomeGameCard>
                    }
                </ul>
            </HomeSection>
        </div>

        <div class="home-grid-layout">
            <div class="home-grid-main">
                <HomeSection Title="最新文章" Icon="mdiNoteEditOutline" IconColor="var(--cg-color-secondary)">
                    <ul class="home-articles-grid">
                        @foreach (var item in Model.LatestArticles.Take(8))
                        {
                            <HomeNewsCard Url="@item.Url" Title="@item.Name" Text="@item.BriefIntroduction" Time="@($"{(string.IsNullOrWhiteSpace(item.OriginalAuthor) ? item.UserName : item.OriginalAuthor)} · {item.PublishTime}")" Image="@item.Image" Category="文章" />
                        }
                    </ul>
                </HomeSection>

                <HomeSection Title="最新视频" Icon="mdiPlayCircle" IconColor="var(--cg-color-primary)">
                    <ul class="home-articles-grid">
                        @foreach (var item in Model.LatestVideos.Take(6))
                        {
                            <HomeNewsCard Url="@item.Url" Title="@item.Name" Time="@($"{item.OriginalAuthor} · {item.PublishTime}")" Image="@item.Image" Category="视频" />
                        }
                    </ul>
                </HomeSection>

                <HomeSection Title="专题推荐" Icon="mdiTextBoxOutline" IconColor="var(--cg-color-primary)">
                    <ul class="home-articles-grid">
                        @foreach (var item in Model.Evaluations.Take(6))
                        {
                            <HomeEvaluationCard Url="@item.Url" Name="@item.Name" Image="@item.Image" Articles="@item.Articles.Take(4)" />
                        }
                    </ul>
                </HomeSection>
            </div>

            <div class="home-grid-sidebar">
                <div class="home-support-row">
                    @if (Model.SupportLink is not null)
                    {
                        <a href="@Model.SupportLink.Link" target="_blank" rel="noopener noreferrer" class="home-support-card">
                            <span class="home-support-card__icon">
                                <CgMdiIcon Name="mdiFlash" aria-hidden="true"/>
                            </span>
                            <strong class="home-support-card__title">@Model.SupportLink.Title</strong>
                            @if (!string.IsNullOrWhiteSpace(Model.SupportLink.Text))
                            {
                                <p class="home-support-card__desc">@Model.SupportLink.Text</p>
                            }
                            <span class="home-support-card__action">
                                前往支持
                                <CgMdiIcon Name="mdiArrowRight" aria-hidden="true"/>
                            </span>
                        </a>
                    }


                    <div class="home-stats-card">
                        <h3 class="home-stats-card__title">CnGal资料站数据</h3>
                        <div class="home-stats-card__grid">
                            <div class="home-stats-card__item">
                                <span class="home-stats-card__label">游戏</span>
                                <span class="home-stats-card__value">@Model.CommunityStats.GamesCount.ToString("N0")</span>
                            </div>
                            <div class="home-stats-card__item">
                                <span class="home-stats-card__label">制作组/发行商</span>
                                <span class="home-stats-card__value">@Model.CommunityStats.GroupsCount.ToString("N0")</span>
                            </div>
                            <div class="home-stats-card__item">
                                <span class="home-stats-card__label">角色</span>
                                <span class="home-stats-card__value">@Model.CommunityStats.RolesCount.ToString("N0")</span>
                            </div>
                            <div class="home-stats-card__item">
                                <span class="home-stats-card__label">制作人员</span>
                                <span class="home-stats-card__value">@Model.CommunityStats.StaffsCount.ToString("N0")</span>
                            </div>
                        </div>
                        <span class="home-stats-card__decor">
                            <CgMdiIcon Name="mdiAccountGroup" aria-hidden="true"/>
                        </span>
                    </div>
                </div>


                <HomeSection Title="角色生日" Icon="mdiCake" IconColor="var(--cg-color-secondary)">
                    @if (Model.Birthdays.Count == 0)
                    {
                        <div class="home-empty-state-card">
                            <div class="home-empty-state-card__icon">
                                <CgMdiIcon Name="mdiCakeVariantOutline" aria-hidden="true"/>
                            </div>
                            <p class="home-empty-state-card__text">好像今天没人过生日欸</p>
                            <a href="/birthday" class="home-empty-state-card__action">
                                <CgMdiIcon Name="mdiCalendarSearch" aria-hidden="true"/>
                                前往生日日历提前准备
                            </a>
                        </div>
                    }
                    else
                    {
                        <ul class="home-list">
                            @foreach (var item in Model.Birthdays.Take(4))
                            {
                                var gameInfor = item.AddInfors.FirstOrDefault(x => x.Modifier == "登场游戏");
                                var gameName = gameInfor?.Contents.FirstOrDefault()?.DisplayName ?? "未知游戏";
                                <HomeRoleCard Url="@($"/entries/index/{item.Id}")"
                                              Name="@item.Name"
                                              Image="@item.MainImage"
                                              GameName="@gameName"
                                              BriefIntroduction="@item.BriefIntroduction"/>
                            }
                        </ul>
                    }
                </HomeSection>

                <HomeSection Title="每周速报" Icon="mdiTextLong" IconColor="var(--cg-color-primary)">
                    @{
                        var latestWeekly = Model.WeeklyNews.FirstOrDefault();
                    }
                    @if (latestWeekly is not null)
                    {
                        <a href="@($"/articles/index/{latestWeekly.Id}")" class="home-weekly-digest-card">
                            <h3>
                                <CgMdiIcon Name="mdiNewspaper" aria-hidden="true" />
                                CnGal 周报
                            </h3>
                            <p>@TrimWeeklyNewsTitle(latestWeekly.Name)</p>
                            <span class="home-weekly-digest-action">立即阅读</span>
                        </a>
                    }
                    else
                    {
                        <div class="home-weekly-digest-card">
                            <h3>
                                <CgMdiIcon Name="mdiNewspaper" aria-hidden="true" />
                                CnGal 周报
                            </h3>
                            <p>暂无最新周报内容</p>
                            <span class="home-weekly-digest-action">敬请期待</span>
                        </div>
                    }
                </HomeSection>

                <HomeSection Title="制作组动态" Icon="mdiAccountGroupOutline" IconColor="var(--cg-color-primary)">
                    <ul class="home-list home-list-connected">
                        @foreach (var item in Model.HomeNews.Take(6))
                        {
                            <HomeNewsCard Url="@GetNewsLink(item)" Target="@GetNewsTarget(item)" Title="@item.Title" Text="@item.Text" Time="@FormatRelativeTime(item.Time)" Image="@item.Image" Category="@item.Type" DevStyle="true" />
                        }
                    </ul>
                </HomeSection>


                <HomeSection Title="公告" Icon="mdiBullhornOutline" IconColor="#f59e0b">
                    <ul class="home-list home-list-connected">
                        @foreach (var item in Model.Announcements.Take(12))
                        {
                            <HomeLinkCard Url="@item.Url" Title="@item.Name" Text="@item.BriefIntroduction" />
                        }
                    </ul>
                </HomeSection>

                <HomeSection Title="近期编辑" Icon="mdiHistory" IconColor="var(--cg-color-primary)">
                    <ul class="home-list home-list-connected">
                        @foreach (var item in Model.RecentlyEditedGames.Take(8))
                        {
                            <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" Horizontal="true">
                                <small>
                                    <CgMdiIcon Name="mdiClockOutline" aria-hidden="true" />
                                    @item.PublishTime
                                </small>
                            </HomeGameCard>
                        }
                    </ul>
                </HomeSection>

                <HomeSection Title="近期留言" Icon="mdiChat" IconColor="var(--cg-color-primary)">
                    <ul class="home-list">
                        @foreach (var item in Model.LatestComments.Take(6))
                        {
                            <HomeCommentCard Url="@item.Url" UserName="@item.UserName" UserImage="@item.UserImage" Content="@item.Content" Time="@item.Time" />
                        }
                    </ul>
                </HomeSection>

                <div class="home-support-tags-panel">
                    <HomeSection Title="热门标签" Icon="mdiTagMultipleOutline" IconColor="var(--cg-color-secondary)">
                        <ul class="home-hot-tags">
                            @foreach (var (item, i) in Model.HotTags.Take(20).Select((v, i) => (v, i)))
                            {
                                <li style="--_tag-hue: @(200 + i * 17 % 160)">
                                    <a href="@item.Url">@item.Name</a>
                                </li>
                            }
                        </ul>
                    </HomeSection>
                </div>
            </div>
        </div>

        <HomeKanban />

        <HomeSection Title="免费游玩" Icon="mdiGiftOutline" IconColor="#10b981">
            <ul class="home-bottom-game-grid">
                @foreach (var item in Model.FreeGames.Take(5))
                {
                    <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction" Tags="@item.Tags" />
                }
            </ul>
        </HomeSection>

        <HomeSection Title="折扣中" Icon="mdiSale" IconColor="#f59e0b">
            <ul class="home-bottom-game-grid">
                @foreach (var item in Model.DiscountGames.Take(5))
                {
                    <HomeGameCard Url="@item.Url" Image="@item.Image" Name="@item.Name" BriefIntroduction="@item.BriefIntroduction">
                        <div class="home-discount-label">
                            <span class="home-discount-cut">-@item.Cut%</span>
                            <span class="home-discount-price">¥ @item.Price.ToString("0.00")</span>
                        </div>
                    </HomeGameCard>
                }
            </ul>
        </HomeSection>

        <HomeSection Title="友情链接" Icon="mdiLink" IconColor="var(--cg-color-text-muted)">
            <ul class="home-friend-link-grid">
                @foreach (var item in Model.FriendLinks.Take(20))
                {
                    <li style="display: flex;">
                        <a href="@item.Url" target="_blank" rel="noopener noreferrer" class="home-friend-link-card" style="width: 100%;">
                            @if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img Src="@item.Image" alt="@item.Name" loading="lazy" decoding="async"/>
                            }
                            <span>@item.Name</span>
                        </a>
                    </li>
                }
            </ul>
        </HomeSection>


        @if (Model.Warnings.Count > 0)
        {
            <HomeWarning Warnings="@Model.Warnings" />
        }
    </div>
}

@code {
    private HomeSummaryViewModel Model = new()
    {
        HeroTitle = "",
        HeroSubtitle = "",
        Carousels = [],
        HotRecommends = [],
        PublishedGames = [],
        RecentlyDemoGames = [],
        UpcomingGames = [],
        ActivityCarousels = [],
        HomeNews = [],
        WeeklyNews = [],
        LatestArticles = [],
        LatestVideos = [],
        FriendLinks = [],
        Birthdays = [],
        Announcements = [],
        RecentlyEditedGames = [],
        CommunityLinks = [],
        Evaluations = [],
        SupportLink = null,
        HotTags = [],
        LatestComments = [],
        FreeGames = [],
        DiscountGames = [],
        CommunityStats = new CnGalWebSite.DataModel.ViewModel.Tables.TableViewModel(),
        Warnings = []
    };

    private string? ErrorMessage;

    protected override async Task OnInitializedAsync()
    {
        var result = await HomeQueryService.GetHomeSummaryAsync();
        if (result.Success && result.Data is not null)
        {
            Model = result.Data;
            return;
        }

        ErrorMessage = result.Error?.Message ?? "请稍后重试";
    }

    private static string DisplayOrUnknown(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "未知" : value;
    }

    private static string TrimWeeklyNewsTitle(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "CnGal每周速报";
        }

        return name.Replace("CnGal每周速报（", "").Replace("）", "");
    }

    private static string GetNewsLink(HomeNewsAloneViewModel model)
    {
        return string.IsNullOrWhiteSpace(model.Link) ? $"/articles/index/{model.ArticleId}" : model.Link;
    }

    private static string? GetNewsTarget(HomeNewsAloneViewModel model)
    {
        return string.IsNullOrWhiteSpace(model.Link) ? null : "_blank";
    }

    private static string GetCommunityIcon(int index)
    {
        return index switch
        {
            1 => "mdiBug",
            2 => "mdiHub",
            3 => "mdiTelevisionClassic",
            4 => "mdiSinaWeibo",
            5 => "mdiCube",
            _ => "mdiQqchat"
        };
    }

    private static string GetCommunityTone(int index)
    {
        return index switch
        {
            1 => "secondary",
            2 => "purple",
            3 => "primary",
            4 => "red",
            5 => "dark",
            _ => "pink"
        };
    }

    private static string FormatRelativeTime(DateTime time)
    {
        var span = DateTime.Now - time;

        if (span.TotalMinutes < 1) return "刚刚";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}分钟前";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}小时前";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays}天前";
        if (span.TotalDays < 365) return $"{(int)(span.TotalDays / 30)}个月前";
        return $"{(int)(span.TotalDays / 365)}年前";
    }
}
