@page "/peripheries/createperiphery"
@page "/peripheries/create"
@page "/peripheries/edit/{Id:long}"

@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using CnGalWebSite.DataModel.ViewModel.Peripheries
@using CnGalWebSite.MainSite.Shared.Components.Features.Periphery.Editor
@using CnGalWebSite.SDK.MainSite.Models.PeripheryEdit
@using System.Text.Json
@using Microsoft.JSInterop
@inject IPeripheryCommandService PeripheryCommandService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@inject ICgToastService ToastService
@implements IDisposable

<CgPageMeta Title="@(IsCreate ? "创建周边" : "编辑周边")" />

@if (IsLoading)
{
    <section class="periphery-edit-loading" aria-label="加载中">
        <div class="periphery-edit-loading-spinner"></div>
        <p>正在获取数据...</p>
    </section>
}
else if (LoadErrorMessage != null)
{
    <section class="periphery-edit-error">
        <h1>加载失败</h1>
        <p>@LoadErrorMessage</p>
        <CgButton Variant="primary" OnClick="LoadDataAsync">重试</CgButton>
    </section>
}
else if (Model != null)
{
    <article class="periphery-edit-page">
        <div class="periphery-edit-layout">
            <PeripheryEditorSidebar IsCreate="IsCreate"
                                    IsSubmitting="IsSubmitting"
                                    HasDraftRecovered="HasDraftRecovered"
                                    OnDiscardDraft="DiscardDraft"
                                    OnSubmit="SubmitAsync"
                                    OnCancel="Cancel" />

            <main class="periphery-edit-main">
                <PeripheryMainEditor Model="Model.Data.Main" />
                <PeripheryImagesEditor Model="Model.Data.Images" />
                <PeripheryRelatedEntriesEditor Model="Model.Data.Entries" MetaOptions="Model.MetaOptions" />
                <PeripheryRelatedPeripheriesEditor Model="Model.Data.Peripheries" MetaOptions="Model.MetaOptions" />
            </main>
        </div>

    </article>
}

@code {
    [Parameter]
    public long? Id { get; set; }

    private bool IsCreate => Id is null or <= 0;

    private bool IsLoading = true;
    private string? LoadErrorMessage;

    private bool IsSubmitting = false;

    private PeripheryEditViewModel? Model;

    private CancellationTokenSource? _cts;
    private System.Threading.Timer? _autoSaveTimer;
    private string DraftKey => IsCreate ? "PeripheryDraft_Create" : $"PeripheryDraft_Edit_{Id}";

    private bool HasDraftRecovered = false;
    private CreatePeripheryViewModel? OriginalData;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadDataAsync();
        _autoSaveTimer = new System.Threading.Timer(AutoSaveCallback, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private void AutoSaveCallback(object? state)
    {
        _ = InvokeAsync(async () =>
        {
            if (Model != null && !IsSubmitting && !IsLoading)
            {
                try
                {
                    var json = JsonSerializer.Serialize(Model.Data);
                    await JS.InvokeVoidAsync("localStorage.setItem", DraftKey, json);
                }
                catch { /* Ignore local storage errors */ }
            }
        });
    }

    public void Dispose()
    {
        _autoSaveTimer?.Dispose();
        _cts?.Cancel();
        _cts?.Dispose();
    }

    private async Task LoadDataAsync()
    {
        IsLoading = true;
        LoadErrorMessage = null;
        StateHasChanged();

        try
        {
            SdkResult<PeripheryEditViewModel> result;
            if (IsCreate)
            {
                result = await PeripheryCommandService.GetPeripheryCreateTemplateAsync(_cts!.Token);
            }
            else
            {
                result = await PeripheryCommandService.GetPeripheryEditAsync(Id!.Value, _cts!.Token);
            }

            if (result.Success && result.Data != null)
            {
                Model = result.Data;
                OriginalData = JsonSerializer.Deserialize<CreatePeripheryViewModel>(JsonSerializer.Serialize(result.Data.Data));

                // 尝试恢复草稿
                try
                {
                    var draftStr = await JS.InvokeAsync<string>("localStorage.getItem", DraftKey);
                    if (!string.IsNullOrWhiteSpace(draftStr))
                    {
                        var draft = JsonSerializer.Deserialize<CreatePeripheryViewModel>(draftStr);
                        if (draft != null)
                        {
                            Model.Data = draft;
                            HasDraftRecovered = true;
                        }
                    }
                }
                catch { }

                // 获取关联候选列表
                var metaResult = await PeripheryCommandService.GetPeripheryEditMetaOptionsAsync(_cts!.Token);
                if (metaResult.Success && metaResult.Data != null)
                {
                    Model.MetaOptions = metaResult.Data;
                }
            }
            else
            {
                LoadErrorMessage = result.Error?.Message ?? "获取编辑数据失败";
            }
        }
        catch (OperationCanceledException)
        {
            // Cancelled, do nothing
        }
        catch (Exception ex)
        {
            LoadErrorMessage = "发生未知错误：" + ex.Message;
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task DiscardDraft()
    {
        if (OriginalData != null && Model != null)
        {
            Model.Data = JsonSerializer.Deserialize<CreatePeripheryViewModel>(JsonSerializer.Serialize(OriginalData))!;
            HasDraftRecovered = false;
            await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
            StateHasChanged();
        }
    }

    private async Task SubmitAsync()
    {
        if (Model == null || IsSubmitting) return;

        var validationResult = Model.Data.Validate();
        if (!validationResult.Successful)
        {
            ToastService.Show("校验失败", validationResult.Error ?? "请检查表单是否填写正确", "error");
            return;
        }

        IsSubmitting = true;
        StateHasChanged();

        try
        {
            var request = new PeripheryEditRequest
            {
                IsCreate = IsCreate,
                Data = Model.Data
            };

            var result = await PeripheryCommandService.SubmitEditAsync(request, _cts!.Token);
            if (result.Success)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", DraftKey);
                NavigationManager.NavigateTo($"/peripheries/index/{result.Data}");
            }
            else
            {
                ToastService.Show("提交失败", result.Error?.Message ?? "提交审核时出现问题", "error");
            }
        }
        catch (OperationCanceledException)
        {
            // Cancelled, do nothing
        }
        catch (Exception ex)
        {
            ToastService.Show("发生错误", ex.Message, "error");
        }
        finally
        {
            IsSubmitting = false;
            StateHasChanged();
        }
    }

    private void Cancel()
    {
        if (IsCreate)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            NavigationManager.NavigateTo($"/peripheries/index/{Id}");
        }
    }
}
