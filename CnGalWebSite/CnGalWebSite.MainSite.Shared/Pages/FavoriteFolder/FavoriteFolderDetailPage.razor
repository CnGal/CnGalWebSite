@page "/favoritefolders/index/{Id:long}"

@using CnGalWebSite.SDK.MainSite.Abstractions
@using CnGalWebSite.SDK.MainSite.Models
@using CnGalWebSite.MainSite.Shared.Components.Features.FavoriteFolder
@using CnGalWebSite.MainSite.Shared.Components.DesignSystem

@inject IFavoriteFolderQueryService FavoriteFolderQueryService
@inject NavigationManager NavigationManager

@if (_isNotFound)
{
    <div class="cg-ff-not-found">
        <h1 class="cg-ff-not-found-title">找不到这个收藏夹哦......</h1>
        <div class="cg-ff-not-found-text">可以在个人空间 → 收藏夹 → 编辑中设置收藏夹公开</div>
        <CgButton Variant="primary" OnClick="@(() => NavigationManager.NavigateTo("/"))">返回首页</CgButton>
    </div>
}
else if (_model != null)
{
    <PageTitle>@($"目录 - {_model.Name} - CnGal资料站")</PageTitle>

    <div class="cg-ff-detail-container">
        <FavoriteFolderHero Model="_model" />

        <div class="cg-ff-detail-layout">
            <div class="cg-ff-detail-sidebar">
                <FavoriteFolderInfoCard Model="_model" />
            </div>
            <div class="cg-ff-detail-main">
                @if (_model.IsHidden)
                {
                    <div class="cg-ff-detail-alert">
                        <CgAlert Variant="warning">
                            当前目录处于隐藏状态，如果你看到了这个提示，请立即联系管理员
                        </CgAlert>
                    </div>
                }
                <FavoriteFolderObjectList Model="_model" />
            </div>
        </div>
    </div>
}
else if (_isError)
{
    <div class="cg-ff-not-found">
        <h1 class="cg-ff-not-found-title">加载失败</h1>
        <div class="cg-ff-not-found-text">@_errorMessage</div>
        <CgButton Variant="primary" OnClick="@(() => NavigationManager.NavigateTo("/"))">返回首页</CgButton>
    </div>
}
else
{
    <div class="cg-ff-loading">
        <span>加载中...</span>
    </div>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private FavoriteFolderDetailViewModel? _model;
    private bool _isNotFound;
    private bool _isError;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_model != null && _model.Id != Id)
        {
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        _isNotFound = false;
        _isError = false;
        _model = null;

        var result = await FavoriteFolderQueryService.GetFavoriteFolderDetailAsync(Id);

        if (result.Success && result.Data != null)
        {
            _model = result.Data;
        }
        else if (result.Error?.StatusCode == 404)
        {
            _isNotFound = true;
        }
        else
        {
            _isError = true;
            _errorMessage = result.Error?.Message ?? "未知错误";
        }
    }
}
