@page "/tags/index/{Id:int}"
@inject ITagQueryService TagQueryService
@inject IExamineQueryService ExamineQueryService


@implements IDisposable
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.Tags
@using CnGalWebSite.MainSite.Shared.Components.Features.Tag.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Examine

<CgPageMeta Title="@(_model?.Name)" Description="@(_model?.BriefIntroduction)" Image="@(_model?.MainPicture)" />

@if (_errorMessage is not null)
{
    <section class="tag-not-found">
        <h1>标签加载失败</h1>
        <p>@_errorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (_model is not null)
{
    <article class="tag-page">
        @if (HasAtmosphere())
        {
            <CgAtmosphere BackgroundPicture="@_model.BackgroundPicture" SmallBackgroundPicture="@_model.SmallBackgroundPicture" />
        }

        <header class="tag-header">
            <TagBreadcrumb TagLevels="_model.Taglevels" />

            <TagHero Name="@_model.Name"
                     BriefIntroduction="@_model.BriefIntroduction"
                     MainPicture="@_model.MainPicture"
                     BackgroundPicture="@_model.BackgroundPicture"
                     ReaderCount="_model.ReaderCount"
                     TagId="_model.Id"
                     IsHidden="_model.IsHidden" />
        </header>

        <CgHiddenTip IsHidden="_model.IsHidden" ContentTypeName="标签" />

        <section class="tag-footer-related" aria-label="相关内容">
            <TagChildTags Tags="_model.ChildrenTags" />

            <TagChildEntries Entries="_model.ChildrenEntries" />

            <CgMiniModeContainer>
                <EditRecordListCard Records="_editRecords" />
            </CgMiniModeContainer>
        </section>
    </article>
}
else
{
    <section class="tag-loading" aria-label="加载中">
        <CgProgressRing Size="lg" Color="var(--cg-color-primary)" />
        <span class="tag-loading-text">加载中...</span>
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private TagIndexViewModel? _model;
    private IReadOnlyList<ExaminedNormalListModel>? _editRecords;
    private string? _errorMessage;
    private CancellationTokenSource? _cts;

    protected override async Task OnParametersSetAsync()
    {
        if (_model?.Id == Id)
        {
            return;
        }

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        try
        {
            _model = null;
            _editRecords = null;
            _errorMessage = null;

var tagTask = TagQueryService.GetTagDetailAsync(Id, cancellationToken: _cts.Token);
var editRecordsTask = ExamineQueryService.GetTagEditRecordsAsync(Id, cancellationToken: _cts.Token);

            var result = await tagTask;
            if (result.Success && result.Data is not null)
            {
                _errorMessage = null;
                _model = result.Data;

                var editRecordsResult = await editRecordsTask;
                _editRecords = editRecordsResult.Success ? editRecordsResult.Data : null;
                return;
            }

            _model = null;
            _editRecords = null;
            _errorMessage = result.Error?.Message ?? "请稍后重试";
        }
        catch (OperationCanceledException)
        {
            // Component disposed or parameters changed, ignore
        }
    }

    private bool HasAtmosphere()
    {
        if (_model is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(_model.BackgroundPicture) is false
            || string.IsNullOrWhiteSpace(_model.SmallBackgroundPicture) is false;
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }



}
