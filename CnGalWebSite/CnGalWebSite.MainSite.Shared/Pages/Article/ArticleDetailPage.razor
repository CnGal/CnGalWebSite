@page "/articles/index/{Id:long}"
@inject IArticleQueryService ArticleQueryService
@inject IExamineQueryService ExamineQueryService
@using CnGalWebSite.DataModel.Model
@using CnGalWebSite.DataModel.ViewModel.Admin
@using CnGalWebSite.DataModel.ViewModel.Search
@using CnGalWebSite.MainSite.Shared.Components.Features.Article.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Entry.Detail
@using CnGalWebSite.MainSite.Shared.Components.Features.Examine
@using CnGalWebSite.MainSite.Shared.Services

<PageTitle>@(_model is null ? "文章详情" : $"{GetDisplayTitle()} - 文章详情")</PageTitle>

@if (_errorMessage is not null)
{
    <section class="article-not-found">
        <h1>文章加载失败</h1>
        <p>@_errorMessage</p>
        <a href="/">返回首页</a>
    </section>
}
else if (_model is not null)
{
    <article class="article-page">
        @if (HasAtmosphere())
        {
            <CgAtmosphere BackgroundPicture="@_model.BackgroundPicture" SmallBackgroundPicture="@_model.SmallBackgroundPicture" />
        }

        <header class="article-header">
            <ArticleHero Title="@GetDisplayTitle()"
                         BriefIntroduction="@_model.BriefIntroduction"
                         MainPicture="@_model.MainPicture"
                         TypeText="@GetTypeText(_model.Type)"
                         ArticleId="@_model.Id" />

            <div class="article-info-bar">
                <ArticleAuthor AuthorName="@_model.AuthorName"
                               AuthorAvatar="@_model.AuthorAvatar"
                               AuthorId="@_model.AuthorId"
                               OriginalAuthor="@_model.OriginalAuthor"
                               OriginalLink="@_model.OriginalLink" />

                <ArticleMeta ReaderCount="_model.ReaderCount"
                             ThumbsUpCount="_model.ThumbsUpCount"
                             CommentCount="_model.CommentCount"
                             PublishTime="_model.PubishTime"
                             CreateTime="_model.CreateTime"
                             LastEditTime="_model.LastEditTime" />
            </div>
        </header>

        @if (_model.IsHidden)
        {
            <CgAlert Variant="warning" Class="article-hidden-alert">
                当前文章处于隐藏状态，如果你看到了这个提示，请立即联系管理员
            </CgAlert>
        }

        <main class="article-main-content">
            @if (!string.IsNullOrWhiteSpace(_model.MainPage))
            {
                <div class="article-prose">
                    <CgHtmlContent Content="@_model.MainPage" />
                </div>
            }
        </main>

        <footer class="article-footer-related">
            <EntrySection Title="关联词条" Icon="mdiLinkVariant" Show="_model.RelatedEntries.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="_model.RelatedEntries.Count > 9">
                    @foreach (var item in _model.RelatedEntries)
                    {
                        <li>
                            <EntryCardItem Url="@($"/entries/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" IsSquareCover="item.Type == EntryType.Role || item.Type == EntryType.Staff" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="关联文章" Icon="mdiTextBoxOutline" Show="_model.RelatedArticles.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="_model.RelatedArticles.Count > 9">
                    @foreach (var item in _model.RelatedArticles)
                    {
                        <li>
                            <EntryCardItem Url="@ExternalLinkHelper.GetArticleLink(item)" Target="@ExternalLinkHelper.GetTarget(item.Link)" Image="@item.MainImage" Title="@item.Name" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="关联视频" Icon="mdiAnimationPlayOutline" Show="_model.RelatedVideos.Count > 0">
                <EntryCardList LimitCount="9" ShowExpandButton="_model.RelatedVideos.Count > 9">
                    @foreach (var item in _model.RelatedVideos)
                    {
                        <li>
                            <EntryCardItem Url="@($"/videos/index/{item.Id}")" Image="@item.MainImage" Title="@item.Name" Icon="mdiPlayCircleOutline" />
                        </li>
                    }
                </EntryCardList>
            </EntrySection>

            <EntrySection Title="外部链接" Icon="mdiLinkVariant" Show="_model.RelatedOutlinks.Count > 0">
                <ul class="article-outlink-list">
                    @foreach (var item in _model.RelatedOutlinks.Take(8))
                    {
                        <li>
                            <a href="@item.DisplayValue" target="_blank" rel="noopener noreferrer">
                                <CgMdiIcon Name="mdiEarth" />
                                @(!string.IsNullOrWhiteSpace(item.DisplayName) ? item.DisplayName : item.DisplayValue)
                            </a>
                        </li>
                    }
                </ul>
            </EntrySection>

            <EditRecordListCard Records="_editRecords" />

            <CnGalWebSite.MainSite.Shared.Components.Features.Comment.CommentSection
                Type="CommentType.CommentArticle"
                ObjectId="@_model.Id.ToString()"
                CanComment="_model.CanComment" />
        </footer>
    </article>
}
else
{
    <section class="article-loading" aria-label="加载中">
        <CgProgressRing Size="lg" Color="var(--cg-color-primary)" />
        <span class="article-loading-text">加载中...</span>
    </section>
}

@code {
    [Parameter]
    public long Id { get; set; }

    private ArticleDetailViewModel? _model;
    private IReadOnlyList<ExaminedNormalListModel>? _editRecords;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        if (_model?.Id == Id)
        {
            return;
        }

        _model = null;
        _editRecords = null;
        _errorMessage = null;

        var articleTask = ArticleQueryService.GetArticleDetailAsync(Id);
        var editRecordsTask = ExamineQueryService.GetArticleEditRecordsAsync(Id);

        var result = await articleTask;
        if (result.Success && result.Data is not null)
        {
            _errorMessage = null;
            _model = result.Data;

            var editRecordsResult = await editRecordsTask;
            _editRecords = editRecordsResult.Success ? editRecordsResult.Data : null;
            return;
        }

        _model = null;
        _editRecords = null;
        _errorMessage = result.Error?.Message ?? "请稍后重试";
    }

    private string GetDisplayTitle()
    {
        if (_model is null)
        {
            return string.Empty;
        }

        return string.IsNullOrWhiteSpace(_model.DisplayName) ? _model.Name : _model.DisplayName;
    }

    private static string GetTypeText(ArticleType type)
    {
        return type.GetDisplayName();
    }

    private bool HasAtmosphere()
    {
        if (_model is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(_model.BackgroundPicture) is false
            || string.IsNullOrWhiteSpace(_model.SmallBackgroundPicture) is false;
    }
}
