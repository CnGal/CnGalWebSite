@model ChangeEmailViewModel

<div class="account-page">
    <div class="add-phone-card mdl-card mdl-shadow--2dp">
        <img class="head-logo" src="https://res.cngal.org/_content/CnGalWebSite.Shared/images/head_logo_6th.png">
        <div class="mdl-card__title">
            <h2 class="mdl-card__title-text">修改电子邮箱</h2>
        </div>
        <partial name="_ValidationSummary" />
        <div class="mdl-card__supporting-text">
            <form id="change-email-form" asp-route="AddPhoneNumber">
                <input type="hidden" asp-for="ReturnUrl" />
                <input type="hidden" asp-for="SecondCode" />


                <div class="mdl-textfield mdl-js-textfield mdl-textfield--floating-label">
                    <input class="mdl-textfield__input" type="email" asp-for="Email" autofocus>
                    <label class="mdl-textfield__label" asp-for="Email">电子邮箱</label>
                </div>

                <!--极验-->
                <input id="geetestResult-lotNumber" type="hidden" asp-for="VerifyResult.LotNumber" />
                <input id="geetestResult-captchaOutput" type="hidden" asp-for="VerifyResult.CaptchaOutput" />
                <input id="geetestResult-passToken" type="hidden" asp-for="VerifyResult.PassToken" />
                <input id="geetestResult-genTime" type="hidden" asp-for="VerifyResult.GenTime" />

                <div id="captcha-box"></div>
                <!--极验-->

                <div class="action">
                    <button class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect mdl-button--colored">确定</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>initGeetestCaptcha('change-email-form', 'AccountModify');</script>
}
